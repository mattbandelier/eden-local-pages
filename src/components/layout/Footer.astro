---
import { services, suburbs } from "../../data";
import { serviceHubUrl, suburbHubUrl } from "../../lib/urls";

interface Props {
	variant?: "default" | "wellness";
}

const { variant = "default" } = Astro.props;
const phone = "720-605-7678";
const defaultServiceLinks = services.slice(0, 6).map((service) => ({
	label: service.name,
	href: serviceHubUrl(service.slug),
}));
const wellnessServiceLinks = [
	{ label: "Hormone Optimization", href: "/hormone-optimization/" },
	{ label: "Peptide Therapy Denver", href: "/peptide-therapy/denver/" },
	{ label: "TRT Denver", href: "/male-trt/denver/" },
	{ label: "Medical Weight Loss Denver", href: "/medical-weight-loss/denver/" },
	{ label: "NAD+ IV Therapy", href: "/nad-iv-therapy/greenwood-village/" },
	{ label: "IV Therapy", href: "/iv-therapy/greenwood-village/" },
];
const footerServiceLinks = variant === "wellness" ? wellnessServiceLinks : defaultServiceLinks;
const demandPathLinks =
	variant === "wellness"
		? [
				{ label: "Longevity Clinic Denver", href: "/longevity/" },
				{ label: "Longevity Baseline Visit", href: "/longevity-baseline-visit/" },
				{ label: "$299 Peptide Starter", href: "/peptide-biomarker-consult-denver/" },
				{ label: "Peptide Therapy Denver", href: "/peptide-therapy/denver/" },
				{ label: "TRT Denver", href: "/male-trt/denver/" },
				{ label: "Men's Hormone Optimization", href: "/mens-hormone-optimization/" },
				{ label: "Women's Hormone Optimization", href: "/womens-hormone-optimization/" },
				{ label: "Medical Weight Loss Denver", href: "/medical-weight-loss/denver/" },
				{ label: "Hormone Therapy Cost", href: "/hormone-therapy-cost/" },
				{ label: "Red Light Therapy Denver", href: "/red-light-therapy-denver/" },
				{ label: "Perform Membership", href: "/glp-1-fitness-membership-greenwood-village/" },
				{ label: "Elevate Membership", href: "/elevate-membership-greenwood-village/" },
			]
		: [
				{ label: "Longevity Clinic Denver", href: "/longevity/" },
				{ label: "Longevity Baseline Visit", href: "/longevity-baseline-visit/" },
				{ label: "$299 Peptide Starter", href: "/peptide-biomarker-consult-denver/" },
				{ label: "Medical Spa Denver", href: "/medical-spa-denver/" },
				{ label: "Botox Denver", href: "/botox/denver/" },
				{ label: "Medical Weight Loss Denver", href: "/medical-weight-loss/denver/" },
				{ label: "Red Light Therapy Denver", href: "/red-light-therapy-denver/" },
				{ label: "TRT Denver", href: "/male-trt/denver/" },
				{ label: "Men's Hormone Optimization", href: "/mens-hormone-optimization/" },
				{ label: "Perform Membership", href: "/glp-1-fitness-membership-greenwood-village/" },
				{ label: "Elevate Membership", href: "/elevate-membership-greenwood-village/" },
			];
---

<footer class="bg-eden-navy px-6 py-12 text-white">
	<div class="mx-auto grid max-w-6xl gap-10 md:grid-cols-4">
		<div class="md:col-span-2">
			<p class="text-lg font-semibold">Eden Health Club</p>
			<p class="mt-3 max-w-md text-sm leading-6 text-white/75">
				5990 S University Blvd<br />
				Greenwood Village, CO 80121
			</p>
			<a
				href="https://edenhealthclubs.com/"
				target="_blank"
				rel="noopener"
				class="mt-3 inline-block text-sm text-white/75 underline underline-offset-4 hover:text-white"
			>
				Visit edenhealthclubs.com
			</a>
			<a href="tel:+17206057678" class="mt-4 inline-block text-sm font-semibold text-white underline">{phone}</a>
		</div>
		<div>
			<p class="text-sm font-semibold uppercase text-white">{variant === "wellness" ? "Wellness programs" : "Services"}</p>
			<div class="mt-4 grid gap-2">
				{footerServiceLinks.map((link) => (
					<a href={link.href} class="text-sm text-white/75 hover:text-white">{link.label}</a>
				))}
			</div>
		</div>
		<div>
			<p class="text-sm font-semibold uppercase text-white">Locations</p>
			<div class="mt-4 grid gap-2">
				{suburbs.slice(0, 6).map((suburb) => (
					<a href={suburbHubUrl(suburb.slug)} class="text-sm text-white/75 hover:text-white">{suburb.name}</a>
				))}
			</div>
		</div>
	</div>
	<div class="mx-auto mt-8 max-w-6xl border-t border-white/10 pt-6">
		<p class="text-sm font-semibold uppercase text-white">{variant === "wellness" ? "Denver wellness demand paths" : "Denver demand paths"}</p>
		<div class="mt-4 flex flex-wrap gap-x-5 gap-y-2">
			{demandPathLinks.map((link) => (
				<a href={link.href} class="text-sm text-white/75 hover:text-white">{link.label}</a>
			))}
		</div>
	</div>
	<div class="mx-auto mt-10 max-w-6xl border-t border-white/10 pt-6">
		<div class="flex flex-col gap-3 text-sm text-white/70 sm:flex-row sm:justify-between">
			<p>© 2026 Eden Wellness, LLC. All Rights Reserved.</p>
			<p>
				<a href="https://edenhealthclubs.com/privacy-policy/" target="_blank" rel="noopener" class="hover:text-white">Privacy Policy</a>
				/
				<a href="https://edenhealthclubs.com/terms/" target="_blank" rel="noopener" class="hover:text-white">Terms</a>
			</p>
		</div>
		<p class="mt-6 max-w-4xl text-xs leading-6 text-white/55">
			Eden Health Club services are provided through licensed healthcare providers. Treatment plans are individualized based on medical evaluation. Eden Wellness, LLC offers general health and wellness information but is not a substitute for professional medical advice.
		</p>
	</div>
</footer>
