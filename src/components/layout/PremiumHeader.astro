---
const phone = "720-605-7678";
const phoneHref = "tel:+17206057678";
---

<header class="border-b border-white/10 bg-eden-forest text-white">
	<div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-3 text-sm">
		<a href="/" class="font-semibold tracking-normal">Eden Health Club</a>
		<nav class="hidden items-center gap-6 md:flex" aria-label="Premium landing page navigation">
			<a href="https://edenhealthclubs.com/services/" target="_blank" rel="noopener" class="text-white/80 hover:text-white">Services</a>
			<a href="#lead-form" class="text-white/80 hover:text-white">Contact Us</a>
			<a href="#pricing" class="text-white/80 hover:text-white">Get Pricing</a>
		</nav>
		<div class="flex items-center gap-3">
			<a href={phoneHref} data-phone-link class="hidden font-semibold text-white sm:inline">{phone}</a>
			<a href="#lead-form" class="rounded-md bg-eden-sage px-4 py-2 text-sm font-semibold text-eden-forest">Book a Consult</a>
		</div>
	</div>
</header>

<script>
	import { trackPhoneClick } from "../../lib/tracking";

	document.querySelectorAll<HTMLAnchorElement>("[data-phone-link]").forEach((link) => {
		link.addEventListener("click", () => trackPhoneClick(link.textContent?.trim() || "720-605-7678"));
	});
</script>
