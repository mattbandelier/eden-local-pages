---
import type { Service } from "../../data/types";

interface Props {
	service: Service;
}

const { service } = Astro.props;
const details = [
	["Visit length", service.treatmentDetails.duration],
	["Downtime", service.treatmentDetails.downtime],
	["Comfort", service.treatmentDetails.painLevel],
	["Results timing", service.treatmentDetails.resultsTiming],
	["Typical cadence", service.treatmentDetails.sessionsRecommended],
];
---

<section id="details" class="px-6 py-10">
	<div class="mx-auto max-w-6xl">
		<div class="max-w-3xl">
			<p class="text-sm font-semibold uppercase text-eden-green">Treatment snapshot</p>
			<h2 class="mt-2 text-3xl font-semibold text-eden-navy">What to know before you book.</h2>
			<p class="mt-3 text-base leading-7 text-slate-700">{service.whoItsFor}</p>
		</div>
		<div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
			{details.map(([label, value]) => (
				<div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
					<p class="text-sm font-semibold uppercase text-eden-green">{label}</p>
					<p class="mt-2 text-base leading-6 text-eden-navy">{value}</p>
				</div>
			))}
		</div>
	</div>
</section>
