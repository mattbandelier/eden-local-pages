---
import type { Service, Suburb } from "../../data/types";

interface Props {
	variant: "service-hub" | "suburb-hub" | "combo";
	service?: Service;
	suburb?: Suburb;
	premium?: boolean;
}

const { variant, service, suburb, premium = false } = Astro.props;

if ((variant === "service-hub" || variant === "combo") && !service) {
	throw new Error("Hero requires service for service-hub and combo variants.");
}
if ((variant === "suburb-hub" || variant === "combo") && !suburb) {
	throw new Error("Hero requires suburb for suburb-hub and combo variants.");
}

const content = {
	"service-hub": {
		eyebrow: "Eden Health Club",
		title: `${service?.name} in Greenwood Village`,
		body: service?.longDescription,
	},
	"suburb-hub": {
		eyebrow: "South Denver wellness",
		title: `Eden Health Club in ${suburb?.name}`,
		body: suburb?.neighborhoodBlurb,
	},
	combo: {
		eyebrow: `${suburb?.name}, CO`,
		title: `${service?.name} in ${suburb?.name}`,
		body:
			suburb?.driveTimeMinutes === 0
				? `${service?.shortDescription} Available at Eden's Greenwood Village clinic.`
				: `${service?.shortDescription} ${suburb?.demographicHook}`,
	},
}[variant];

const isCombo = variant === "combo";
const heroPanels: Record<string, { label: string; items: string[] }> = {
	"diamondglow-facial": {
		label: "Before you book",
		items: [
			"60-minute SkinMedica DiamondGlow facial",
			"Exfoliation, extraction, and serum infusion",
			"Transparent service-menu pricing",
			"Minimal downtime for most clients",
		],
	},
	botox: {
		label: "Before you book",
		items: [
			"Natural movement is the goal",
			"Common upper-face plans use 20-50 units",
			"Results build over several days",
			"Full effect is judged around 14 days",
		],
	},
	"lip-filler": {
		label: "Before you book",
		items: [
			"Shape, hydration, and proportion first",
			"Product choice depends on your anatomy",
			"Swelling and bruising are possible",
			"Final refinement appears after swelling settles",
		],
	},
	"dermal-fillers": {
		label: "Before you book",
		items: [
			"Volume support and contour balance",
			"Product choice depends on tissue depth",
			"Swelling and bruising are possible",
			"Pricing is reviewed before treatment",
		],
	},
	"medical-weight-loss": {
		label: "Before you book",
		items: [
			"Medical history and lab review first",
			"Provider-guided eligibility screening",
			"Plans are monitored over time",
			"Program pricing depends on fit",
		],
	},
	"bbl-photofacial": {
		label: "Before you book",
		items: [
			"Built for visible tone and sun-damage concerns",
			"Skin type and timing are screened first",
			"Series planning may be recommended",
			"Downtime varies by settings and skin response",
		],
	},
	"female-bhrt": {
		label: "Before you book",
		items: [
			"Lab review is required",
			"Provider consult before treatment planning",
			"Pellet and non-pellet options may be discussed",
			"Follow-up keeps dosing accountable",
		],
	},
	"male-trt": {
		label: "Before you book",
		items: [
			"Bloodwork is required before treatment",
			"Provider reviews safety and eligibility",
			"Plans are monitored over time",
			"Follow-up labs guide adjustments",
		],
	},
	"peptide-therapy": {
		label: "Before you book",
		items: [
			"Provider-led protocol selection",
			"Baseline screening comes first",
			"Goals guide the recommendation",
			"Not every client is a candidate",
		],
	},
	"prf-hair-restoration": {
		label: "Before you book",
		items: [
			"Consult confirms hair-loss pattern",
			"Series planning is common",
			"Uses your own platelet-rich fibrin",
			"Progress is gradual, not instant",
		],
	},
	"iv-therapy": {
		label: "Before you book",
		items: [
			"Choose by goal: hydration, energy, recovery, or glow",
			"75-minute monitored wellness infusion",
			"Formula selection is confirmed before treatment",
			"Transparent session pricing",
		],
	},
	"nad-iv-therapy": {
		label: "Before you book",
		items: [
			"Route and dose are confirmed first",
			"Visit length depends on the plan",
			"Commonly chosen for wellness routines",
			"Pricing depends on dose and delivery",
		],
	},
	microneedling: {
		label: "Before you book",
		items: [
			"Best for texture, pores, fine lines, and mild acne scarring",
			"Often planned as a series",
			"PRP upgrade may be discussed when appropriate",
			"Downtime depends on treatment depth and skin response",
		],
	},
};
const heroPanel =
	isCombo && service
		? heroPanels[service.slug] ?? {
				label: "Before you book",
				items: [
					service.treatmentDetails.duration,
					service.treatmentDetails.downtime,
					service.consultRequired ? "Provider consult first" : "Fit and timing confirmed before treatment",
					suburb?.driveTimeMinutes === 0 ? "One Greenwood Village clinic" : `Served from Eden's Greenwood Village clinic`,
				],
			}
		: null;
const proofPoints = isCombo
	? [
			suburb?.driveTimeMinutes === 0 ? "One Greenwood Village clinic" : `${suburb?.driveTimeMinutes} min from ${suburb?.name}`,
			service?.consultRequired ? "Provider consult first" : "Service-specific screening",
			"Licensed Eden team",
		]
	: [];

const premiumHeroBodies: Record<string, string> = {
	"diamondglow-facial": "A medical-grade SkinMedica facial for glow, texture, congestion, and serum infusion at Eden's Greenwood Village clinic.",
	botox: "A conservative injectable visit for smoother expression lines, natural movement, and a refreshed look at Eden's Greenwood Village clinic.",
	"lip-filler": "A shape-first lip enhancement visit focused on proportion, hydration, symmetry, and natural-looking balance.",
	"dermal-fillers": "A measured facial balancing visit for volume support, contour refinement, and smoother transitions without an overdone look.",
	"medical-weight-loss": "Medical weight loss near Denver with labs, GLP-1 support, eligibility review, accountability, and a monitored plan.",
	"bbl-photofacial": "A light-based skin visit for visible tone, redness, sun-damage concerns, and clearer skin-quality planning.",
	"female-bhrt": "A lab-guided hormone optimization consult for women who want a clearer plan, provider oversight, and ongoing monitoring.",
	"male-trt": "TRT Denver consults for men comparing testosterone therapy, labs, provider oversight, safety screening, and accountable follow-up.",
	"peptide-therapy": "Peptide therapy Denver consults for recovery, performance, body composition, skin quality, and medically reviewed protocol planning.",
	"prf-hair-restoration": "PRF hair restoration near Denver for men noticing thinning, shedding, receding hairline, or crown-density changes.",
	"iv-therapy": "A monitored wellness infusion visit for hydration, recovery, energy, glow, or goal-based nutrient support.",
	"nad-iv-therapy": "A monitored NAD+ wellness visit with route, dose, visit length, and fit confirmed before you begin.",
	microneedling: "A collagen-focused skin treatment for texture, pores, fine lines, and gradual skin-quality improvement.",
};
const displayBody = premium && service ? premiumHeroBodies[service.slug] ?? content.body : content.body;
const premiumHeroImages: Record<string, string> = {
	"male-trt": "/assets/mens-hormone-optimization.webp",
	"medical-weight-loss": "/assets/fitness-recovery.webp",
	"peptide-therapy": "/assets/mens-hormone-optimization.webp",
	"female-bhrt": "/assets/fitness-recovery.webp",
	"prf-hair-restoration": "/assets/prf-hair-restoration-hero.jpg",
};
const heroImage = premium && service ? premiumHeroImages[service.slug] ?? "/assets/eden-health-club-office.webp" : "/assets/eden-health-club-office.webp";
const heroBackgroundImage = premium ? "/assets/eden-health-club-reception.webp" : heroImage;
const sectionClass =
	premium && isCombo
		? "relative max-w-full overflow-hidden bg-eden-forest text-white"
		: isCombo
			? "relative max-w-full overflow-hidden bg-eden-forest px-6 py-12 text-white sm:py-16 lg:py-20"
			: "bg-white px-6 py-14 sm:py-20";
const heroShellClass =
	premium && isCombo
		? "relative mx-auto grid min-h-[calc(86vh-64px)] max-w-6xl gap-10 px-6 py-12 sm:py-16 lg:grid-cols-[1.02fr_0.98fr] lg:items-center"
		: isCombo
			? "relative mx-auto grid max-w-6xl gap-8 overflow-hidden lg:grid-cols-[1.05fr_0.95fr] lg:items-end"
			: "mx-auto max-w-3xl text-center";
const premiumHighlights = [
	{
		title: "Open now",
		body: "A local Greenwood Village team, not a waitlist or remote-only promise.",
	},
	{
		title: "Under one roof",
		body: "Medical wellness, recovery, training, body composition, and follow-up can connect.",
	},
	{
		title: "Provider-guided",
		body: "Labs, history, eligibility, and goals shape the next step when appropriate.",
	},
	{
		title: "Built to continue",
		body: "The consult can route into a real weekly path inside Eden.",
	},
];
---

<section class={sectionClass}>
	{premium && (
		<>
			<img
				src={heroBackgroundImage}
				alt=""
				width="960"
				height="960"
				loading="eager"
				fetchpriority="high"
				decoding="async"
				class="absolute inset-0 h-full w-full object-cover opacity-45"
				aria-hidden="true"
			/>
			<video
				class="absolute inset-0 hidden h-full w-full object-cover opacity-24 md:block"
				data-deferred-hero-video
				autoplay
				muted
				loop
				playsinline
				preload="none"
				poster={heroBackgroundImage}
				aria-hidden="true"
			>
				<source data-src="https://edenhealthclubs.com/wp-content/uploads/2025/07/edenhealth-hero-video.mp4" type="video/mp4" />
			</video>
		</>
	)}
	<div class={premium ? "absolute inset-0 bg-[linear-gradient(90deg,rgba(28,45,38,0.98),rgba(25,79,57,0.90)_48%,rgba(25,79,57,0.44)),linear-gradient(180deg,rgba(25,79,57,0.08),rgba(25,79,57,0.78))]" : isCombo ? "absolute inset-0 bg-[linear-gradient(135deg,rgba(15,39,51,0.42),rgba(15,39,51,0.14)_45%,rgba(255,255,255,0.06))]" : "hidden"} aria-hidden="true"></div>
	<div class={heroShellClass}>
		<div class="min-w-0">
			{premium && (
				<img
					src="/assets/eden-health-club-logo-white-transparent-tight.png"
					alt="Eden Health Club"
					class="mb-8 h-auto w-36 sm:w-44"
					loading="eager"
					fetchpriority="high"
				/>
			)}
			<p class={premium ? "text-sm font-semibold uppercase tracking-normal text-eden-sage" : isCombo ? "text-sm font-semibold uppercase tracking-wide text-white/75" : "text-sm font-semibold uppercase text-eden-green"}>{premium ? "Look. Feel. Perform." : content.eyebrow}</p>
			<h1 class={premium ? "mt-4 max-w-3xl break-words text-4xl font-semibold leading-tight text-white sm:text-5xl lg:text-6xl" : isCombo ? "mt-4 max-w-full break-words text-3xl font-semibold leading-tight text-white sm:text-6xl" : "mt-4 text-4xl font-semibold leading-tight text-eden-navy sm:text-5xl"}>{content.title}</h1>
			<p class={isCombo ? "mt-6 max-w-full break-words text-base leading-8 text-white/82 sm:text-lg" : "mt-6 text-base leading-8 text-slate-700 sm:text-lg"}>{displayBody}</p>
			{premium && (
				<p class="mt-4 max-w-2xl text-base font-semibold leading-7 text-eden-sage">
					Open now near DTC with medical wellness, body composition, recovery, and training under one roof.
				</p>
			)}
			{isCombo && (
				<div class="mt-8 flex flex-col gap-3 sm:flex-row">
					<a href="#lead-form" class="inline-flex items-center justify-center rounded-md bg-eden-sage px-6 py-3 text-base font-semibold text-eden-forest shadow-sm transition hover:bg-eden-sage/90">
						{service?.ctaText}
					</a>
					<a href={premium ? "tel:+17206057678" : "#details"} data-phone-link={premium ? true : undefined} class="inline-flex items-center justify-center rounded-md border border-white/25 bg-white/10 px-6 py-3 text-base font-semibold text-white transition hover:bg-white/15">
						{premium ? "Call 720-605-7678" : "See details"}
					</a>
				</div>
			)}
			{premium && (
				<div class="mt-8 grid gap-3 text-sm text-white/90 sm:grid-cols-2">
					{premiumHighlights.map((item) => (
						<div class="rounded-lg border border-white/15 bg-white/10 p-4 shadow-sm backdrop-blur">
							<p class="text-lg font-semibold text-white">{item.title}</p>
							<p class="mt-2 leading-6 text-white/75">{item.body}</p>
						</div>
					))}
				</div>
			)}
		</div>
		{isCombo && premium && (
			<div class="relative min-w-0">
				<div class="overflow-hidden rounded-lg border border-white/15 bg-white/10 p-3 shadow-2xl backdrop-blur">
					<img src={heroImage} alt="" class="h-72 w-full rounded-md object-cover sm:h-96" loading="eager" fetchpriority="high" decoding="async" width="960" height="960" />
					<div class="mt-3 grid gap-3 sm:grid-cols-2">
						<div class="rounded-md bg-white p-4 text-eden-navy">
							<p class="text-xs font-semibold uppercase text-eden-green">Local path</p>
							<p class="mt-2 text-lg font-semibold">A real facility you can use week to week.</p>
						</div>
						<div class="rounded-md bg-eden-sage p-4 text-eden-forest">
							<p class="text-xs font-semibold uppercase">Start clear</p>
							<p class="mt-2 text-lg font-semibold">Goals, fit, and next steps before guessing.</p>
						</div>
					</div>
					<div class="mt-3 rounded-md border border-white/10 bg-white/10 p-4">
						<p class="text-xs font-semibold uppercase text-eden-sage">{heroPanel?.label}</p>
						<div class="mt-3 grid gap-2">
							{heroPanel?.items.slice(0, 4).map((item) => (
								<p class="rounded-md bg-white/10 px-3 py-2 text-sm font-medium leading-5 text-white/86">{item}</p>
							))}
						</div>
					</div>
				</div>
			</div>
		)}
		{isCombo && !premium && (
			<div class="min-w-0 overflow-hidden rounded-lg border border-white/15 bg-white/10 shadow-2xl backdrop-blur">
				<img
					src="/assets/eden-health-club-reception.webp"
					alt="Eden Health Club front desk in Greenwood Village"
					width="1024"
					height="768"
					loading="eager"
					fetchpriority="high"
					decoding="async"
					class="hidden aspect-[4/3] w-full object-cover sm:block"
				/>
				<div class="p-5">
					<p class="text-sm font-semibold uppercase tracking-wide text-white/70">{heroPanel?.label}</p>
					<ul class="mt-4 grid gap-3">
						{heroPanel?.items.map((item) => (
							<li class="min-w-0 break-words rounded-md bg-white/10 px-4 py-3 text-sm font-medium text-white">{item}</li>
						))}
					</ul>
					<div class="mt-5 grid gap-2 border-t border-white/10 pt-5">
						{proofPoints.map((point) => (
							<p class="text-sm text-white/78">{point}</p>
						))}
					</div>
				</div>
			</div>
		)}
	</div>
</section>
