---
import type { Service } from "../../data/types";

interface Props {
	service: Service;
}

const { service } = Astro.props;
---

<nav class="fixed inset-x-0 bottom-0 z-30 grid grid-cols-2 border-t border-slate-200 bg-white/95 px-4 py-3 shadow-[0_-10px_30px_rgba(15,39,51,0.12)] backdrop-blur md:hidden" aria-label="Contact Eden">
	<a
		href="tel:+17206057678"
		data-phone-link
		class="mr-2 rounded-md border border-eden-navy/15 px-4 py-3 text-center text-sm font-semibold text-eden-navy"
	>
		Call
	</a>
	<a
		href="#lead-form"
		class="ml-2 rounded-md bg-eden-sage px-4 py-3 text-center text-sm font-semibold text-eden-forest"
	>
		{service.consultRequired ? "Consult" : "Book"}
	</a>
</nav>
