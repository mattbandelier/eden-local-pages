---
import type { Service } from "../../data/types";
import { isIndexableCombo } from "../../lib/indexing";
import { comboUrl, serviceHubUrl } from "../../lib/urls";

interface Props {
	services: Service[];
	suburbSlug?: string | null;
}

const { services, suburbSlug = null } = Astro.props;

function relatedHref(service: Service): string {
	if (suburbSlug && isIndexableCombo(service.slug, suburbSlug)) {
		return comboUrl(service.slug, suburbSlug);
	}

	return serviceHubUrl(service.slug);
}
---

<section class="px-6 py-12">
	<div class="mx-auto max-w-6xl">
		<h2 class="text-3xl font-semibold text-eden-navy">Related services</h2>
		<div class="mt-8 flex gap-4 overflow-x-auto pb-4">
			{services.slice(0, 4).map((service) => (
				<a
					href={relatedHref(service)}
					class="min-w-72 rounded-lg border border-slate-200 bg-white p-5 shadow-sm transition hover:border-eden-green"
				>
					<h3 class="text-lg font-semibold text-eden-navy">{service.name}</h3>
					<p class="mt-3 text-sm leading-6 text-slate-700">{service.shortDescription}</p>
				</a>
			))}
		</div>
	</div>
</section>
