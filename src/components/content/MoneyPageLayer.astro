const content = contentBySlug[service.slug];
---

{content && (
	<section class="bg-eden-paper px-6 py-14">
		<div class="mx-auto max-w-6xl">
			<div class="max-w-3xl">
				<p class="text-sm font-semibold uppercase text-eden-green">{content.eyebrow}</p>
				<h2 class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">{content.heading}</h2>
				<p class="mt-5 text-base leading-8 text-slate-700">{content.intro}</p>
			</div>

			<div class="mt-8 grid gap-5 lg:grid-cols-[1.05fr_0.95fr]">
				<article class="rounded-lg border border-eden-line bg-white p-6 shadow-sm">
					<p class="text-sm font-semibold uppercase text-eden-green">Local search fit</p>
					<h3 class="mt-2 text-2xl font-semibold leading-tight text-eden-navy">
						Why this page deserves to exist for {suburb.name}.
					</h3>
					<p class="mt-4 text-sm leading-7 text-slate-700">
						{localRoute} {suburb.neighborhoodBlurb} This page is written for clients comparing local availability, fit, pricing context, and whether Eden is the right first step for {service.name}.
					</p>
					<div class="mt-5 flex flex-wrap gap-2">
						{localIntentTerms.map((term) => (
							<span class="rounded-full border border-eden-line bg-eden-paper px-3 py-2 text-xs font-semibold text-eden-navy">{term}</span>
						))}
					</div>
				</article>
				<article class="rounded-lg bg-eden-forest p-6 text-white shadow-sm">
					<p class="text-sm font-semibold uppercase text-eden-sage">Local proof</p>
					<h3 class="mt-2 text-2xl font-semibold leading-tight">Built for a real south Denver service area.</h3>
					<ul class="mt-5 space-y-3 text-sm leading-6 text-white/78">
						{localProof.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</article>
			</div>

			<div class="mt-8 grid gap-5 lg:grid-cols-[0.95fr_1.05fr]">
				<article class="rounded-lg bg-eden-forest p-6 text-white shadow-sm">
					<p class="text-sm font-semibold uppercase text-eden-sage">Short answer</p>
					<h3 class="mt-3 text-2xl font-semibold">{content.answerHeading}</h3>
					<p class="mt-4 text-sm leading-7 text-white/78">{content.answerBody}</p>
				</article>
				<div class="grid gap-4 sm:grid-cols-2">
					<article class="rounded-lg border border-eden-line bg-white p-6 shadow-sm">
						<p class="text-sm font-semibold uppercase text-eden-green">Mechanism</p>
						<h3 class="mt-2 text-2xl font-semibold leading-tight text-eden-navy">{content.mechanismHeading}</h3>
						<p class="mt-4 text-sm leading-7 text-slate-700">{content.mechanismBody}</p>
					</article>
					<article class="rounded-lg border border-eden-line bg-white p-6 shadow-sm">
						<p class="text-sm font-semibold uppercase text-eden-green">Best fit</p>
						<h3 class="mt-2 text-2xl font-semibold leading-tight text-eden-navy">{content.audienceHeading}</h3>
						<p class="mt-4 text-sm leading-7 text-slate-700">{content.audienceBody}</p>
					</article>
				</div>
			</div>

			<div class="mt-5 grid gap-4 md:grid-cols-3">
				{content.cards.map((card) => (
					<article class="rounded-lg border border-eden-line bg-white p-5 shadow-sm">
						<h3 class="text-lg font-semibold leading-tight text-eden-navy">{card.title}</h3>
						<p class="mt-3 text-sm leading-6 text-slate-700">{card.body}</p>
					</article>
				))}
			</div>

			<div class="mt-6 grid gap-5 lg:grid-cols-[0.9fr_1.1fr]">
				<article class="rounded-lg border border-eden-line bg-white p-6 shadow-sm">
					<p class="text-sm font-semibold uppercase text-eden-green">Why Eden</p>
					<h3 class="mt-2 text-2xl font-semibold leading-tight text-eden-navy">Eden is not trying to be the busiest option. It is trying to be the clearest one.</h3>
					<ul class="mt-5 space-y-3 text-sm leading-6 text-slate-700">
						{content.whyEden.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</article>
				<article class="rounded-lg border border-eden-line bg-white p-6 shadow-sm">
