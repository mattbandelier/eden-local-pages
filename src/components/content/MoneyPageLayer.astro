					<p class="mt-4 text-sm leading-7 text-slate-700">{content.pairingBody}</p>
					<p class="mt-4 text-sm leading-7 text-slate-700">
						Available {localPhrase}. Request a visit and Eden will confirm the right starting point before you commit.
					</p>
					{service.slug === "medical-weight-loss" && (
						<a href="/glp-1-strength-training-greenwood-village/" class="mt-4 block text-sm font-semibold leading-6 text-eden-green underline underline-offset-4">
							See GLP-1 strength training and muscle support
						</a>
					)}
					<a href="#lead-form" class="mt-5 inline-flex rounded-md bg-eden-sage px-5 py-3 text-sm font-semibold text-eden-forest">
						Start with Eden
					</a>
				</article>
			</div>
		</div>
	</section>
)}
