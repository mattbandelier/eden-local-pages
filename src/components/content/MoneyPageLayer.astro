	},
	"nad-iv-therapy": {
		eyebrow: "NAD+ wellness planning",
		heading: "NAD+ should be chosen for the right reason, route, and pace.",
		intro:
			"NAD+ pages need to be precise: route, dose, visit length, tolerance, and fit matter. Eden should position this as a monitored wellness option, not a miracle claim.",
