const { service, suburb } = Astro.props;
const localPhrase =
	suburb.driveTimeMinutes === 0
		? "at Eden's Greenwood Village clinic"
		: `for ${suburb.name} clients at Eden's Greenwood Village clinic`;
const localRoute =
	suburb.driveTimeMinutes === 0
		? "Eden's flagship clinic is located in Greenwood Village on S University Blvd."
		: `${suburb.name} clients are typically about ${suburb.driveTimeMinutes} minutes from Eden's Greenwood Village clinic.`;
const localIntentTerms = [
	service.targetKeywords.primary,
	...service.targetKeywords.secondary.slice(0, 4),
	...suburb.localKeywords.slice(0, 3),
].filter(Boolean);
const localProof = [
	`Primary area: ${suburb.name}, ${suburb.state}`,
	`Nearby reference points: ${suburb.nearbyLandmarks.slice(0, 2).join(" and ")}`,
	`ZIP context: ${suburb.zipsServed.slice(0, 3).join(", ")}`,
