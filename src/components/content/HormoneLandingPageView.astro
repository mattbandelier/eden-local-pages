---
import type { HormonePage } from "../../data/hormone-pages";
import LeadForm from "./LeadForm.astro";
import Footer from "../layout/Footer.astro";
import PremiumHeader from "../layout/PremiumHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { canonicalUrl, homeUrl } from "../../lib/urls";
import type { JsonLd } from "../../lib/schema-org";

interface Props {
	page: HormonePage;
}

const { page } = Astro.props;
const canonical = canonicalUrl(`/${page.slug}`);
const phone = "720-605-7678";
const phoneHref = "tel:+17206057678";
const pageImageSrc =
	page.slug === "mens-hormone-optimization"
		? "/assets/mens-hormone-optimization.webp"
		: "/assets/eden-health-club-office.webp";
const pageImageAlt =
	page.slug === "mens-hormone-optimization"
		? "Man in a premium Eden Health Club wellness consultation for men's hormone optimization"
		: "Eden Health Club clinical consultation room in Greenwood Village";
const hormoneCredibilityImages = [
	{
		src: pageImageSrc,
		alt: pageImageAlt,
		label: "Provider-led review",
		body: "Start with goals, health history, labs, and fit before a plan is recommended.",
	},
	{
		src: "/assets/eden-health-club-office.webp",
		alt: "Eden Health Club consult room for lab-informed wellness planning",
		label: "Lab-informed planning",
		body: "Use baseline data and follow-up to guide the conversation instead of guessing.",
	},
	{
		src: "/assets/fitness-strength-class.avif",
		alt: "Eden Health Club strength training environment in Greenwood Village",
		label: "Training connection",
		body: "Connect hormone conversations with strength, recovery, and body composition.",
	},
];
const hormonePaths = [
	{
		label: "Men's hormone optimization",
		href: "/mens-hormone-optimization/",
		body: "For men comparing energy, recovery, focus, training response, and lab-backed hormone care.",
	},
	{
		label: "Women's hormone optimization",
		href: "/womens-hormone-optimization/",
		body: "For women looking at sleep, energy, mood, body composition, life stage, labs, and follow-up.",
	},
	{
		label: "Menopause hormone therapy",
		href: "/menopause-hormone-therapy/",
		body: "For perimenopause and menopause questions around symptoms, options, safety, and next steps.",
	},
	{
		label: "Hormone therapy cost",
		href: "/hormone-therapy-cost/",
		body: "For comparing consults, labs, monitoring, follow-up, and the real cost of a responsible plan.",
	},
	{
		label: "Hormone optimization model",
		href: "/hormone-optimization/",
		body: "For the big-picture Eden Blueprint: test, treat, train, track, and optimize.",
	},
].filter((item) => item.href !== `/${page.slug}/`);
const blueprint = [
	{ step: "01", label: "Test", body: "Clarify the baseline with the right lab context and health history." },
	{ step: "02", label: "Treat", body: "Build a provider-led plan only when fit is clear." },
	{ step: "03", label: "Train", body: "Connect the plan to strength, recovery, and body composition." },
	{ step: "04", label: "Track", body: "Follow what changes through labs, goals, and real-world response." },
	{ step: "05", label: "Optimize", body: "Adjust the plan with follow-up instead of leaving you to guess." },
];
const schema: JsonLd[] = [
	{
		"@context": "https://schema.org",
		"@type": "MedicalBusiness",
		"@id": `${canonical}#medical-business`,
		name: "Eden Health Club",
		url: canonical,
		telephone: "+17206057678",
		address: {
			"@type": "PostalAddress",
			streetAddress: "5990 S University Blvd",
			addressLocality: "Greenwood Village",
			addressRegion: "CO",
			postalCode: "80121",
			addressCountry: "US",
		},
		geo: {
			"@type": "GeoCoordinates",
			latitude: 39.6088,
			longitude: -104.9583,
		},
		hasMap:
			"https://www.google.com/maps/search/?api=1&query=Eden%20Health%20Club%205990%20S%20University%20Blvd%20Greenwood%20Village%20CO%2080121",
		priceRange: "$$",
		medicalSpecialty: ["FunctionalMedicine"],
		areaServed: ["Denver", "Greenwood Village", "Denver Tech Center", "Cherry Hills Village", "Centennial", "Littleton", "Lone Tree"],
		sameAs: [
			"https://edenhealthclubs.com/",
			"https://www.facebook.com/edenhealthclubs",
			"https://www.instagram.com/edenhealthclubs",
			"https://www.tiktok.com/@edenhealthclubs",
		],
	},
	{
		"@context": "https://schema.org",
		"@type": page.kind === "authority" ? "MedicalWebPage" : "WebPage",
		"@id": `${canonical}#webpage`,
		url: canonical,
		name: page.title,
		description: page.description,
		about: {
			"@id": `${canonical}#service`,
		},
		isPartOf: {
			"@type": "WebSite",
			name: "Eden Health Club Landing Pages",
			url: homeUrl(),
		},
		reviewedBy: page.kind === "authority" ? {
			"@type": "Person",
			name: "Christina Matheus, NP",
			jobTitle: "Nurse Practitioner",
		} : undefined,
	},
	{
		"@context": "https://schema.org",
		"@type": "Service",
		"@id": `${canonical}#service`,
		name: page.h1,
		serviceType: "Performance Medicine Consult",
		url: canonical,
		description: page.description,
		provider: {
			"@id": `${canonical}#medical-business`,
			"@type": "MedicalBusiness",
			name: "Eden Health Club",
		},
		areaServed: "Denver, Greenwood Village, DTC, Cherry Hills, Centennial, Littleton, Lone Tree",
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		"@id": `${canonical}#faq`,
		mainEntity: page.faqs.map((faq) => ({
			"@type": "Question",
			name: faq.question,
			acceptedAnswer: {
				"@type": "Answer",
				text: faq.answer,
			},
		})),
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{ "@type": "ListItem", position: 1, name: "Home", item: homeUrl() },
			{ "@type": "ListItem", position: 2, name: page.h1, item: canonical },
		],
	},
];
---

<BaseLayout title={page.title} description={page.description} canonicalUrl={canonical} jsonLd={schema}>
	<PremiumHeader servicesHref="#blueprint" pricingHref="#consult" contactHref="#lead-form" />
	<main class="bg-eden-paper text-eden-navy">
		<section class="relative overflow-hidden bg-eden-forest text-white">
			<div class="absolute inset-0">
				<img src={pageImageSrc} alt="" class="h-full w-full object-cover opacity-28" loading="eager" />
				<div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(25,79,57,0.98),rgba(25,79,57,0.88)_54%,rgba(25,79,57,0.36))]"></div>
			</div>
			<div class="relative mx-auto grid max-w-6xl gap-8 px-6 py-12 sm:py-16 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
				<div>
					<p class="text-sm font-semibold uppercase tracking-normal text-eden-sage">{page.eyebrow}</p>
					<h1 class="mt-4 max-w-3xl text-4xl font-semibold leading-tight text-white sm:text-6xl">{page.h1}</h1>
					<p class="mt-5 max-w-2xl text-base leading-8 text-white/86 sm:text-lg">{page.subhead}</p>
					<div class="mt-7 flex flex-col gap-3 sm:flex-row">
						<a href="#lead-form" class="rounded-md bg-eden-sage px-6 py-3 text-center text-base font-semibold text-eden-forest shadow-sm transition hover:bg-eden-sage/90">
							{page.primaryCta}
						</a>
						<a href="#blueprint" class="rounded-md border border-white/35 px-6 py-3 text-center text-base font-semibold text-white transition hover:bg-white/10">
							{page.secondaryCta}
						</a>
					</div>
					<div class="mt-6 grid gap-3 text-sm font-medium text-white/86 sm:grid-cols-3">
						<div class="border-l border-eden-sage/70 pl-4">Provider-led consult</div>
						<div class="border-l border-eden-sage/70 pl-4">Labs before the plan</div>
						<div class="border-l border-eden-sage/70 pl-4">Near DTC</div>
					</div>
				</div>
				<div class="rounded-lg border border-white/15 bg-white/95 p-5 text-eden-navy shadow-xl sm:p-6">
					<p class="text-sm font-semibold uppercase text-eden-green">{page.panelLabel}</p>
					<h2 class="mt-3 text-2xl font-semibold leading-tight">Use the consult to understand the right next step.</h2>
					<div class="mt-5 grid gap-3 sm:grid-cols-2">
						{page.panelItems.map((item) => (
							<div class="rounded-md border border-eden-line bg-eden-paper px-4 py-3">
								<p class="text-sm font-semibold text-eden-navy">{item}</p>
								<p class="mt-1 text-xs leading-5 text-slate-600">Reviewed before a plan is recommended.</p>
							</div>
						))}
					</div>
					<p class="mt-5 rounded-md bg-eden-forest px-4 py-3 text-sm font-semibold leading-6 text-white">
						Data is where many clinics stop. At Eden, it is where the plan starts.
					</p>
				</div>
			</div>
		</section>

		<section class="border-y border-eden-line bg-white px-6 py-5">
			<div class="mx-auto grid max-w-6xl gap-3 sm:grid-cols-4">
				{page.trust.map((item) => (
					<div class="rounded-md border border-eden-line bg-eden-paper px-4 py-3 text-sm font-semibold text-eden-navy">{item}</div>
				))}
			</div>
		</section>

		<section class="bg-white px-6 py-12 sm:py-14" aria-labelledby="hormone-credibility-heading">
			<div class="mx-auto max-w-6xl">
				<div class="max-w-3xl">
					<p class="text-sm font-semibold uppercase text-eden-green">What makes it credible</p>
					<h2 id="hormone-credibility-heading" class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
						Real consults, lab context, and the training environment to support the plan.
					</h2>
				</div>
				<div class="mt-7 grid gap-4 md:grid-cols-3">
					{hormoneCredibilityImages.map((item) => (
						<article class="overflow-hidden rounded-lg border border-eden-line bg-eden-paper shadow-sm">
							<img src={item.src} alt={item.alt} class="aspect-[4/3] w-full object-cover" loading="lazy" />
							<div class="p-5">
								<h3 class="text-lg font-semibold text-eden-navy">{item.label}</h3>
								<p class="mt-2 text-sm leading-6 text-slate-700">{item.body}</p>
							</div>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="px-6 py-12 sm:py-14">
			<div class="mx-auto grid max-w-6xl gap-7 lg:grid-cols-[0.95fr_1.05fr] lg:items-stretch">
				<div class="overflow-hidden rounded-lg border border-eden-line bg-white shadow-sm">
					<img src={pageImageSrc} alt={pageImageAlt} class="aspect-[4/3] w-full object-cover lg:aspect-[5/3]" loading="lazy" />
					<div class="grid gap-3 border-t border-eden-line bg-white p-5 sm:grid-cols-3">
						{page.takeaways.map((item) => (
							<div class="rounded-md bg-eden-paper p-3 text-sm font-semibold leading-5 text-eden-navy">{item}</div>
						))}
					</div>
				</div>

				<div class="grid gap-5 lg:grid-cols-[minmax(0,0.9fr)_minmax(340px,0.95fr)]">
					<div class="rounded-lg border border-eden-line bg-white p-6 shadow-sm">
						<p class="text-sm font-semibold uppercase text-eden-green">Good fit when</p>
						<h2 class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">{page.experienceTitle}</h2>
						<p class="mt-4 text-base leading-7 text-slate-700">{page.experienceIntro}</p>
						<div class="mt-6 grid gap-3">
							{page.experiences.map((item) => (
								<div class="rounded-md border border-eden-line bg-eden-paper p-3 text-sm font-medium leading-6 text-eden-navy">{item}</div>
							))}
						</div>
						{page.kind === "authority" && (
							<p class="mt-5 text-sm leading-6 text-slate-600">Medically reviewed by Christina Matheus, NP. Reviewed July 2, 2026.</p>
						)}
					</div>

					<LeadForm
						serviceSlug={page.serviceSlug}
						suburbSlug="greenwood-village"
						heading={page.formHeading}
						subheading={page.formSubheading}
						submitText={page.primaryCta}
					/>
				</div>
			</div>
		</section>

		<section id="blueprint" class="bg-white px-6 py-12 sm:py-16">
			<div class="mx-auto max-w-6xl">
				<div class="max-w-3xl">
					<p class="text-sm font-semibold uppercase text-eden-green">How Eden works</p>
					<h2 class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">Test. Treat. Train. Track. Optimize.</h2>
					<p class="mt-4 text-base leading-8 text-slate-700">{page.blueprintIntro}</p>
				</div>
				<div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
					{blueprint.map((item) => (
						<div class={`rounded-lg border p-5 ${item.label === "Train" ? "border-eden-green bg-eden-paper shadow-sm" : "border-eden-line bg-white"}`}>
							<p class="text-xs font-semibold uppercase tracking-normal text-eden-green">{item.step}</p>
							<h3 class="mt-2 text-xl font-semibold text-eden-navy">{item.label}</h3>
							<p class="mt-2 text-sm leading-6 text-slate-700">{item.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="bg-eden-forest px-6 py-12 text-white sm:py-16">
			<div class="mx-auto max-w-6xl">
				<div class="max-w-3xl">
					<p class="text-sm font-semibold uppercase text-eden-sage">Why Eden</p>
					<h2 class="mt-3 text-3xl font-semibold leading-tight sm:text-4xl">Provider-led hormone care connected to the rest of your life.</h2>
				</div>
				<div class="mt-8 grid gap-4 md:grid-cols-3">
					{page.whyEden.map((item) => (
						<div class="rounded-lg border border-white/14 bg-white/8 p-6">
							<h3 class="text-xl font-semibold">{item.title}</h3>
							<p class="mt-3 text-sm leading-7 text-white/76">{item.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="px-6 py-12 sm:py-16">
			<div class="mx-auto grid max-w-6xl gap-5 lg:grid-cols-2">
				{page.authoritySections.map((section) => (
					<article class="rounded-lg border border-eden-line bg-white p-6 shadow-sm sm:p-7">
						<p class="text-sm font-semibold uppercase text-eden-green">{section.eyebrow}</p>
						<h2 class="mt-3 text-2xl font-semibold leading-tight text-eden-navy">{section.title}</h2>
						<p class="mt-4 rounded-md border border-eden-line bg-eden-paper p-4 text-base font-semibold leading-7 text-eden-navy">{section.answer}</p>
						<p class="mt-4 text-base leading-8 text-slate-700">{section.body}</p>
						{section.bullets && (
							<ul class="mt-5 grid gap-2 sm:grid-cols-2">
								{section.bullets.map((bullet) => <li class="rounded-md bg-eden-paper px-4 py-3 text-sm font-semibold text-eden-navy">{bullet}</li>)}
							</ul>
						)}
					</article>
				))}
			</div>
		</section>

		<section id="consult" class="bg-white px-6 py-12 sm:py-16">
			<div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[0.86fr_1.14fr] lg:items-start">
				<div>
					<p class="text-sm font-semibold uppercase text-eden-green">Start here</p>
					<h2 class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">Request the consult. Eden will help route the right next step.</h2>
					<p class="mt-4 text-base leading-8 text-slate-700">
						This is a consult request, not a treatment commitment. Eden will follow up about fit, timing, baseline labs, and what makes sense for your goals.
					</p>
					{page.offerLine && <p class="mt-5 rounded-md border border-eden-line bg-eden-paper p-4 text-sm font-semibold text-eden-navy">{page.offerLine}</p>}
					<a href={phoneHref} data-phone-link class="mt-5 inline-block text-sm font-semibold text-eden-green underline underline-offset-4">Call {phone}</a>
				</div>
				<LeadForm serviceSlug={page.serviceSlug} suburbSlug="greenwood-village" heading={page.formHeading} subheading={page.formSubheading} submitText={page.primaryCta} />
			</div>
		</section>

		<section class="px-6 py-12 sm:py-16" aria-labelledby="hormone-paths-heading">
			<div class="mx-auto max-w-6xl">
				<div class="max-w-3xl">
					<p class="text-sm font-semibold uppercase text-eden-green">Compare hormone paths</p>
					<h2 id="hormone-paths-heading" class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">Choose the page closest to the question you are asking.</h2>
					<p class="mt-4 text-base leading-8 text-slate-700">
						Eden keeps hormone conversations provider-led and lab-informed. These related pages help route the consult by search intent, life stage, cost questions, and the broader Eden Blueprint.
					</p>
				</div>
				<div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
					{hormonePaths.map((item) => (
						<a href={item.href} class="rounded-lg border border-eden-line bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-eden-green hover:shadow-md">
							<h3 class="text-lg font-semibold text-eden-navy">{item.label}</h3>
							<p class="mt-3 text-sm leading-6 text-slate-700">{item.body}</p>
							<span class="mt-5 inline-block text-sm font-semibold text-eden-green">Open guide</span>
						</a>
					))}
				</div>
			</div>
		</section>

		<section class="px-6 py-12 sm:py-16" aria-labelledby="hormone-faq-heading">
			<div class="mx-auto max-w-4xl">
				<p class="text-sm font-semibold uppercase text-eden-green">FAQ</p>
				<h2 id="hormone-faq-heading" class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">Questions people ask before booking.</h2>
				<div class="mt-8 grid gap-4">
					{page.faqs.map((faq) => (
						<details class="rounded-lg border border-eden-line bg-white p-5 shadow-sm">
							<summary class="cursor-pointer text-base font-semibold text-eden-navy">{faq.question}</summary>
							<p class="mt-3 text-sm leading-7 text-slate-700">{faq.answer}</p>
						</details>
					))}
				</div>
			</div>
		</section>

		<div class="fixed inset-x-0 bottom-0 z-40 border-t border-eden-line bg-white/96 px-4 py-3 shadow-2xl backdrop-blur md:hidden">
			<div class="mx-auto flex max-w-md items-center gap-3">
				<p class="min-w-0 flex-1 text-xs font-semibold leading-5 text-eden-navy">Provider-led consult near DTC.</p>
				<a href="#lead-form" class="shrink-0 rounded-md bg-eden-sage px-4 py-2 text-sm font-semibold text-eden-forest">{page.primaryCta}</a>
			</div>
		</div>
	</main>
	<Footer />
</BaseLayout>
