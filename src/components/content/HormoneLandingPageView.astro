---
import type { HormonePage } from "../../data/hormone-pages";
import LeadForm from "./LeadForm.astro";
import Footer from "../layout/Footer.astro";
import PremiumHeader from "../layout/PremiumHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { canonicalUrl, homeUrl } from "../../lib/urls";
import type { JsonLd } from "../../lib/schema-org";

interface Props {
	page: HormonePage;
}

const { page } = Astro.props;
const canonical = canonicalUrl(`/${page.slug}`);
const phone = "720-605-7678";
const phoneHref = "tel:+17206057678";
const blueprint = [
	{ step: "01", label: "Test", body: "Clarify the baseline with the right lab context and health history." },
	{ step: "02", label: "Treat", body: "Build a provider-led plan only when fit is clear." },
	{ step: "03", label: "Train", body: "Connect the plan to strength, recovery, and body composition." },
	{ step: "04", label: "Track", body: "Follow what changes through labs, goals, and real-world response." },
	{ step: "05", label: "Optimize", body: "Adjust the plan with follow-up instead of leaving you to guess." },
];
const schema: JsonLd[] = [
	{
		"@context": "https://schema.org",
		"@type": "MedicalBusiness",
		"@id": `${canonical}#medical-business`,
		name: "Eden Health Club",
		url: canonical,
		telephone: "+17206057678",
		address: {
			"@type": "PostalAddress",
			streetAddress: "5990 S University Blvd",
			addressLocality: "Greenwood Village",
			addressRegion: "CO",
			postalCode: "80121",
			addressCountry: "US",
		},
		geo: {
			"@type": "GeoCoordinates",
			latitude: 39.6088,
			longitude: -104.9583,
		},
		hasMap:
			"https://www.google.com/maps/search/?api=1&query=Eden%20Health%20Club%205990%20S%20University%20Blvd%20Greenwood%20Village%20CO%2080121",
		priceRange: "$$",
		medicalSpecialty: ["FunctionalMedicine"],
		areaServed: ["Denver", "Greenwood Village", "Denver Tech Center", "Cherry Hills Village", "Centennial", "Littleton", "Lone Tree"],
		sameAs: [
			"https://edenhealthclubs.com/",
			"https://www.facebook.com/edenhealthclubs",
			"https://www.instagram.com/edenhealthclubs",
			"https://www.tiktok.com/@edenhealthclubs",
		],
	},
	{
		"@context": "https://schema.org",
		"@type": page.kind === "authority" ? "MedicalWebPage" : "WebPage",
		"@id": `${canonical}#webpage`,
		url: canonical,
		name: page.title,
		description: page.description,
		about: {
			"@id": `${canonical}#service`,
		},
		isPartOf: {
			"@type": "WebSite",
			name: "Eden Health Club Landing Pages",
			url: homeUrl(),
		},
		reviewedBy: page.kind === "authority" ? {
			"@type": "Person",
			name: "Christina Matheus, NP",
			jobTitle: "Nurse Practitioner",
		} : undefined,
	},
	{
		"@context": "https://schema.org",
		"@type": "Service",
		"@id": `${canonical}#service`,
		name: page.h1,
		serviceType: "Performance Medicine Consult",
		url: canonical,
		description: page.description,
		provider: {
			"@id": `${canonical}#medical-business`,
			"@type": "MedicalBusiness",
			name: "Eden Health Club",
		},
		areaServed: "Denver, Greenwood Village, DTC, Cherry Hills, Centennial, Littleton, Lone Tree",
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		"@id": `${canonical}#faq`,
		mainEntity: page.faqs.map((faq) => ({
			"@type": "Question",
			name: faq.question,
			acceptedAnswer: {
				"@type": "Answer",
				text: faq.answer,
			},
		})),
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{ "@type": "ListItem", position: 1, name: "Home", item: homeUrl() },
			{ "@type": "ListItem", position: 2, name: page.h1, item: canonical },
		],
	},
];
---

<BaseLayout title={page.title} description={page.description} canonicalUrl={canonical} jsonLd={schema}>
	<PremiumHeader servicesHref="#blueprint" pricingHref="#consult" contactHref="#lead-form" />
	<main class="bg-[#F7F2E7] text-[#1E3A2F]">
		<section class="relative overflow-hidden bg-[#1E3A2F] text-white">
			<div class="absolute inset-0">
				<img src="/assets/eden-health-club-reception.webp" alt="" class="h-full w-full object-cover opacity-22" loading="eager" />
				<div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(30,58,47,0.98),rgba(30,58,47,0.86)_50%,rgba(30,58,47,0.44))]"></div>
			</div>
			<div class="relative mx-auto grid max-w-6xl gap-10 px-6 py-14 sm:py-18 lg:grid-cols-[1.02fr_0.98fr] lg:items-center">
				<div>
					<p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-[#D8BD82]">{page.eyebrow}</p>
					<h1 class="mt-5 max-w-3xl font-serif text-5xl font-semibold leading-[0.98] sm:text-6xl lg:text-7xl">{page.h1}</h1>
					<p class="mt-6 max-w-2xl text-base leading-8 text-white/84 sm:text-lg">{page.subhead}</p>
					<div class="mt-8 flex flex-col gap-3 sm:flex-row">
						<a href="#lead-form" class="rounded-md bg-[#B8935A] px-6 py-3 text-center text-base font-semibold text-white shadow-sm hover:bg-[#A8824C]">
							{page.primaryCta}
						</a>
						<a href="#blueprint" class="rounded-md border border-white/35 px-6 py-3 text-center text-base font-semibold text-white hover:bg-white/10">
							{page.secondaryCta}
						</a>
					</div>
					<p class="mt-5 text-sm leading-6 text-white/70">
						Eden Health Club is located at 5990 S University Blvd in Greenwood Village, minutes from DTC and South Denver.
					</p>
				</div>
				<div class="rounded-lg border border-white/16 bg-[#F7F2E7]/96 p-5 text-[#1E3A2F] shadow-2xl sm:p-6">
					<div class="flex items-center justify-between border-b border-[#1E3A2F]/15 pb-4">
						<p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-[#8E5F32]">{page.panelLabel}</p>
						<span class="rounded-full border border-[#B8935A]/35 px-3 py-1 font-mono text-[11px] uppercase tracking-[0.14em] text-[#8E5F32]">Reviewed</span>
					</div>
					<div class="mt-5 grid gap-3">
						{page.panelItems.map((item) => (
							<div class="flex items-center justify-between rounded-md border border-[#1E3A2F]/12 bg-white/72 px-4 py-3">
								<span class="text-sm font-semibold">{item}</span>
								<span class="font-mono text-xs uppercase tracking-[0.14em] text-[#8E5F32]">Included</span>
							</div>
						))}
					</div>
					<p class="mt-5 border-t border-[#1E3A2F]/12 pt-4 text-sm leading-6 text-[#5E645A]">
						Data is where they stop. It's where we start.
					</p>
				</div>
			</div>
		</section>

		<section class="border-y border-[#1E3A2F]/10 bg-white px-6 py-5">
			<div class="mx-auto grid max-w-6xl gap-3 sm:grid-cols-4">
				{page.trust.map((item) => (
					<div class="rounded-md border border-[#1E3A2F]/10 bg-[#F7F2E7] px-4 py-3 font-mono text-xs font-semibold uppercase tracking-[0.13em] text-[#1E3A2F]">{item}</div>
				))}
			</div>
		</section>

		<section class="px-6 py-12 sm:py-16">
			<div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[0.72fr_1.28fr]">
				<div>
					<p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-[#8E5F32]">Key takeaways</p>
					<h2 class="mt-3 font-serif text-3xl font-semibold leading-tight text-[#1E3A2F] sm:text-4xl">What to know before you book.</h2>
					{page.kind === "authority" && (
						<p class="mt-4 text-sm leading-6 text-[#5E645A]">Medically reviewed by Christina Matheus, NP. Reviewed July 2, 2026.</p>
					)}
				</div>
				<div class="grid gap-3">
					{page.takeaways.map((item) => (
						<div class="rounded-lg border border-[#1E3A2F]/12 bg-white p-5 text-base leading-7 text-[#23261F] shadow-sm">{item}</div>
					))}
				</div>
			</div>
		</section>

		<section class="bg-white px-6 py-12 sm:py-16">
			<div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
				<div>
					<p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-[#8E5F32]">Experience check</p>
					<h2 class="mt-3 font-serif text-4xl font-semibold leading-tight text-[#1E3A2F]">{page.experienceTitle}</h2>
					<p class="mt-4 text-base leading-7 text-[#5E645A]">{page.experienceIntro}</p>
				</div>
				<div class="grid gap-3 sm:grid-cols-2">
					{page.experiences.map((item) => (
						<div class="rounded-lg border border-[#1E3A2F]/12 bg-[#F7F2E7] p-5 text-sm font-medium leading-6 text-[#23261F]">{item}</div>
					))}
				</div>
			</div>
		</section>

		<section id="blueprint" class="px-6 py-12 sm:py-16">
			<div class="mx-auto max-w-6xl">
				<div class="max-w-3xl">
					<p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-[#8E5F32]">The Eden Blueprint</p>
					<h2 class="mt-3 font-serif text-4xl font-semibold leading-tight text-[#1E3A2F]">Test. Treat. Train. Track. Optimize.</h2>
					<p class="mt-4 text-base leading-8 text-[#5E645A]">{page.blueprintIntro}</p>
				</div>
				<div class="mt-8 grid gap-3 md:grid-cols-5">
					{blueprint.map((item) => (
						<div class={`rounded-lg border p-5 ${item.label === "Train" ? "border-[#B8935A] bg-white shadow-md" : "border-[#1E3A2F]/12 bg-white/70"}`}>
							<p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-[#8E5F32]">{item.step}</p>
							<h3 class="mt-3 text-xl font-semibold text-[#1E3A2F]">{item.label}</h3>
							<p class="mt-2 text-sm leading-6 text-[#5E645A]">{item.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="bg-[#1E3A2F] px-6 py-12 text-white sm:py-16">
			<div class="mx-auto max-w-6xl">
				<div class="max-w-3xl">
					<p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-[#D8BD82]">Why Eden</p>
					<h2 class="mt-3 font-serif text-4xl font-semibold leading-tight">Provider-led performance medicine, not a treat-and-forget clinic.</h2>
				</div>
				<div class="mt-8 grid gap-4 md:grid-cols-3">
					{page.whyEden.map((item) => (
						<div class="rounded-lg border border-white/14 bg-white/8 p-6">
							<h3 class="text-xl font-semibold">{item.title}</h3>
							<p class="mt-3 text-sm leading-7 text-white/76">{item.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="bg-white px-6 py-12 sm:py-16">
			<div class="mx-auto grid max-w-6xl gap-5">
				{page.authoritySections.map((section) => (
					<article class="rounded-lg border border-[#1E3A2F]/12 bg-[#F7F2E7] p-6 sm:p-8">
						<p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-[#8E5F32]">{section.eyebrow}</p>
						<h2 class="mt-3 font-serif text-3xl font-semibold leading-tight text-[#1E3A2F]">{section.title}</h2>
						<p class="mt-4 rounded-md border border-[#B8935A]/28 bg-white p-4 text-base font-medium leading-7 text-[#23261F]">{section.answer}</p>
						<p class="mt-4 text-base leading-8 text-[#5E645A]">{section.body}</p>
						{section.bullets && (
							<ul class="mt-5 grid gap-2 sm:grid-cols-2">
								{section.bullets.map((bullet) => <li class="rounded-md bg-white px-4 py-3 text-sm font-semibold text-[#1E3A2F]">{bullet}</li>)}
							</ul>
						)}
					</article>
				))}
			</div>
		</section>

		<section id="consult" class="px-6 py-12 sm:py-16">
			<div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
				<div>
					<p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-[#8E5F32]">Start here</p>
					<h2 class="mt-3 font-serif text-4xl font-semibold leading-tight text-[#1E3A2F]">Request the consult. Eden will help route the right next step.</h2>
					<p class="mt-4 text-base leading-8 text-[#5E645A]">
						This is a consult request, not a treatment commitment. Eden will follow up about fit, timing, baseline labs, and what makes sense for your goals.
					</p>
					{page.offerLine && <p class="mt-5 rounded-md border border-[#B8935A]/28 bg-white p-4 text-sm font-semibold text-[#1E3A2F]">{page.offerLine}</p>}
					<a href={phoneHref} data-phone-link class="mt-5 inline-block text-sm font-semibold text-[#8E5F32] underline underline-offset-4">Call {phone}</a>
				</div>
				<LeadForm serviceSlug={page.serviceSlug} suburbSlug="greenwood-village" heading={page.formHeading} subheading={page.formSubheading} submitText={page.primaryCta} />
			</div>
		</section>

		<section class="bg-white px-6 py-12 sm:py-16" aria-labelledby="hormone-faq-heading">
			<div class="mx-auto max-w-4xl">
				<p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-[#8E5F32]">FAQ</p>
				<h2 id="hormone-faq-heading" class="mt-3 font-serif text-4xl font-semibold leading-tight text-[#1E3A2F]">Questions people ask before booking.</h2>
				<div class="mt-8 grid gap-4">
					{page.faqs.map((faq) => (
						<details class="rounded-lg border border-[#1E3A2F]/12 bg-[#F7F2E7] p-5">
							<summary class="cursor-pointer text-base font-semibold text-[#1E3A2F]">{faq.question}</summary>
							<p class="mt-3 text-sm leading-7 text-[#5E645A]">{faq.answer}</p>
						</details>
					))}
				</div>
			</div>
		</section>

		<div class="fixed inset-x-0 bottom-0 z-40 border-t border-[#1E3A2F]/10 bg-white/96 px-4 py-3 shadow-2xl backdrop-blur md:hidden">
			<div class="mx-auto flex max-w-md items-center gap-3">
				<p class="min-w-0 flex-1 text-xs font-semibold leading-5 text-[#1E3A2F]">Provider-led consult near DTC.</p>
				<a href="#lead-form" class="shrink-0 rounded-md bg-[#B8935A] px-4 py-2 text-sm font-semibold text-white">{page.primaryCta}</a>
			</div>
		</div>
	</main>
	<Footer />
</BaseLayout>
