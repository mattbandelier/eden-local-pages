---
import type { Service } from "../../data/types";
import { comboUrl, serviceHubUrl } from "../../lib/urls";

interface Props {
	services: readonly Service[];
	heading?: string;
	suburbSlug?: string | null;
	limit?: number;
}

const { services, heading = "Services", suburbSlug = null, limit } = Astro.props;
const visibleServices = limit ? services.slice(0, limit) : services;
---

<section class="px-6 py-12">
	<div class="mx-auto max-w-6xl">
		<h2 class="text-3xl font-semibold text-eden-navy">{heading}</h2>
		<div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{visibleServices.map((service) => (
				<a
					href={suburbSlug ? comboUrl(service.slug, suburbSlug) : serviceHubUrl(service.slug)}
					class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm transition hover:border-eden-green"
				>
					<p class="text-xs font-semibold uppercase text-eden-green">{service.category.replace("-", " ")}</p>
					<h3 class="mt-2 text-xl font-semibold text-eden-navy">{service.name}</h3>
					<p class="mt-3 text-sm leading-6 text-slate-700">{service.shortDescription}</p>
				</a>
			))}
		</div>
	</div>
</section>
