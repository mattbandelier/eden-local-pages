---

<section id="premium-start" class="bg-eden-paper px-6 py-12 sm:py-14">
	<div class="mx-auto grid max-w-6xl gap-7 lg:grid-cols-[0.95fr_1.05fr] lg:items-stretch">
		<div class="overflow-hidden rounded-lg border border-eden-line bg-white shadow-sm">
			<img src={content.image.src} alt={content.image.alt} class="aspect-[4/3] w-full object-cover lg:aspect-[5/3]" loading="eager" />
			<div class="grid gap-3 border-t border-eden-line bg-white p-5 sm:grid-cols-3">
				{content.proof.map((item) => (
					<div class="rounded-md bg-eden-paper p-3 text-sm font-semibold leading-5 text-eden-navy">{item}</div>
				))}
			</div>
		</div>

		<div class="grid gap-5 lg:grid-cols-[minmax(0,0.86fr)_minmax(340px,0.94fr)]">
			<div class="rounded-lg border border-eden-line bg-white p-6 shadow-sm">
				<p class="text-sm font-semibold uppercase text-eden-green">{content.eyebrow}</p>
				<h2 class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">{content.heading}</h2>
				<p class="mt-4 text-base leading-7 text-slate-700">{content.body}</p>
				<BookingCTA
					serviceSlug={service.slug}
					serviceName={service.name}
					serviceCategory={service.category}
					label={service.ctaText}
					class="mt-6 inline-flex rounded-md bg-eden-green px-5 py-3 text-sm font-semibold text-white hover:bg-eden-forest"
				/>

				<div class="mt-6 grid gap-3">
					<p class="text-sm font-semibold uppercase text-eden-green">Good fit when</p>
					{content.fit.map((item) => (
						<div class="rounded-md border border-eden-line bg-eden-paper p-3 text-sm font-medium leading-6 text-eden-navy">{item}</div>
					))}
				</div>

				<div class="mt-6 grid gap-2 text-sm leading-6 text-slate-700">
					<p class="font-semibold text-eden-navy">Why clients choose Eden here</p>
					{content.compare.map((item) => (
						<p>{item}</p>
					))}
				</div>
			</div>

			<LeadForm
				serviceSlug={service.slug}
				suburbSlug={suburb.slug}
				heading={content.formHeading}
				subheading={content.formSubheading}
				submitText={service.ctaText}
			/>
		</div>
	</div>
</section>
