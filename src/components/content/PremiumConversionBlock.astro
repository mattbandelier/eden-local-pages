---
import type { Service, Suburb } from "../../data/types";
import LeadForm from "./LeadForm.astro";
import BookingCTA from "./BookingCTA.astro";

interface Props {
	service: Service;
	suburb: Suburb;
}

interface PremiumConversionContent {
	eyebrow: string;
	heading: string;
	body: string;
	formHeading: string;
	formSubheading: string;
	proof: string[];
	fit: string[];
	compare: string[];
	image: {
		src: string;
		alt: string;
	};
}

const { service, suburb } = Astro.props;

const defaultContent: PremiumConversionContent = {
	eyebrow: `${service.name} near ${suburb.name}`,
	heading: `Start with a focused ${service.name} consult at Eden.`,
	body: `Tell Eden what you are considering, what you want to avoid, and when you want to be seen. The team will help confirm whether ${service.name} is the right starting point or whether another Eden service fits better.`,
	formHeading: `Book your ${service.name} consult`,
	formSubheading: "Share your goal and Eden will follow up about fit, timing, and next steps.",
	proof: ["4.9 Google rating", "Greenwood Village near DTC", "Medical wellness + aesthetics"],
	fit: ["You want a clear recommendation before treatment", "You are comparing options near South Denver", "You want a premium clinic experience"],
	compare: ["Pricing and fit before commitment", "Local access near DTC", "Related services under one roof"],
	image: {
		src: "/assets/eden-health-club-reception.webp",
		alt: "Eden Health Club reception in Greenwood Village",
