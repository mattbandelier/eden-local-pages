const content = {
	...defaultContent,
	...(contentBySlug[service.slug] ?? {}),
} satisfies PremiumConversionContent;

const searchTerms =
	content.searchTerms && content.searchTerms.length
		? content.searchTerms
		: [service.targetKeywords.primary, ...service.targetKeywords.secondary.slice(0, 4)].filter(Boolean);
const pathway = content.pathway && content.pathway.length ? content.pathway : defaultContent.pathway;
---

<section id="premium-start" class="bg-eden-paper px-6 py-12 sm:py-16">
	<div class="mx-auto max-w-6xl">
		<div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
			<div>
				<p class="text-sm font-semibold uppercase text-eden-green">{content.eyebrow}</p>
				<h2 class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">{content.heading}</h2>
			</div>
			<p class="text-base leading-8 text-slate-700">{content.body}</p>
		</div>

		<div class="mt-8 grid gap-7 lg:grid-cols-[0.92fr_1.08fr] lg:items-stretch">
			<div class="overflow-hidden rounded-lg border border-eden-line bg-white p-3 shadow-lg">
				<img src={content.image.src} alt={content.image.alt} class="aspect-[4/3] w-full rounded-md object-cover lg:aspect-[5/3]" loading="eager" />
				<div class="grid gap-3 bg-white py-4 sm:grid-cols-3">
					{content.proof.map((item) => (
						<div class="rounded-md bg-eden-paper p-3 text-sm font-semibold leading-5 text-eden-navy">{item}</div>
					))}
				</div>
				<div class="rounded-md bg-eden-forest p-5 text-white">
					<p class="text-xs font-semibold uppercase text-eden-sage">Common starting points</p>
					<div class="mt-3 flex flex-wrap gap-2">
						{searchTerms.map((term) => (
							<span class="rounded-full border border-white/15 bg-white/10 px-3 py-2 text-xs font-semibold text-white">{term}</span>
						))}
					</div>
				</div>
			</div>

			<div class="grid gap-5 lg:grid-cols-[minmax(0,0.86fr)_minmax(340px,0.94fr)]">
				<div class="rounded-lg border border-eden-line bg-white p-6 shadow-sm">
					<p class="text-sm font-semibold uppercase text-eden-green">Why Eden</p>
					<h3 class="mt-2 text-2xl font-semibold leading-tight text-eden-navy">A clearer first step than a disconnected clinic visit.</h3>

					<div class="mt-6 grid gap-3">
						<p class="text-sm font-semibold uppercase text-eden-green">Good fit if</p>
						{content.fit.map((item) => (
							<div class="rounded-md border border-eden-line bg-eden-paper p-3 text-sm font-medium leading-6 text-eden-navy">{item}</div>
						))}
					</div>

					<div class="mt-6 grid gap-2 text-sm leading-6 text-slate-700">
						<p class="font-semibold text-eden-navy">What makes the consult more useful</p>
						{content.compare.map((item) => (
							<p>{item}</p>
						))}
					</div>
				</div>

				<LeadForm
					serviceSlug={service.slug}
					suburbSlug={suburb.slug}
					heading={content.formHeading}
					subheading={content.formSubheading}
					submitText={service.ctaText}
				/>
			</div>
		</div>

		<div class="mt-8 rounded-lg bg-eden-forest p-5 text-white shadow-lg sm:p-7">
			<div class="grid gap-6 lg:grid-cols-[0.86fr_1.14fr] lg:items-end">
				<div>
					<p class="text-sm font-semibold uppercase text-eden-sage">Eden method</p>
					<h3 class="mt-3 text-3xl font-semibold leading-tight">Start measured, then keep the path moving.</h3>
				</div>
				<p class="text-base leading-8 text-white/78">
					The goal is not another loose wellness promise. Eden turns interest into a local plan with screening, provider review, and follow-through when the fit is right.
				</p>
			</div>
			<div class="mt-7 grid gap-4 md:grid-cols-3">
				{pathway.map((item) => (
					<div class="rounded-lg border border-white/15 bg-white/10 p-5 backdrop-blur">
						<div class="flex h-9 w-9 items-center justify-center rounded-full bg-eden-sage text-sm font-semibold text-eden-forest">{item.label}</div>
						<h3 class="mt-4 text-xl font-semibold text-white">{item.title}</h3>
						<p class="mt-3 text-sm leading-6 text-white/75">{item.body}</p>
					</div>
				))}
			</div>
		</div>
	</div>
</section>
