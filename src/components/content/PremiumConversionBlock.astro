---
import type { Service, Suburb } from "../../data/types";
import LeadForm from "./LeadForm.astro";

interface Props {
	service: Service;
	suburb: Suburb;
}

interface PremiumConversionContent {
	eyebrow: string;
	heading: string;
	body: string;
	formHeading: string;
	formSubheading: string;
	proof: string[];
	fit: string[];
	compare: string[];
	searchTerms?: string[];
	pathway?: Array<{
		label: string;
		title: string;
		body: string;
	}>;
	image: {
		src: string;
		alt: string;
	};
}

const { service, suburb } = Astro.props;

