---
import type { Service } from "../../data/types";
import Button from "../ui/Button.astro";

interface Props {
	pricing: Service["pricing"];
	consultRequired: boolean;
	ctaText: string;
}

const { pricing, consultRequired, ctaText } = Astro.props;
const priceLabel =
	pricing.model === "consult-required" || consultRequired || pricing.startingAt === undefined
		? "Consult required"
		: `Starting at $${pricing.startingAt}`;
---

<section class="px-6 py-12">
	<div class="mx-auto max-w-3xl rounded-lg border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
		<p class="text-sm font-semibold uppercase text-eden-green">Pricing</p>
		<h2 class="mt-2 text-3xl font-semibold text-eden-navy">{priceLabel}</h2>
		{pricing.note && <p class="mt-3 text-base leading-7 text-slate-700">{pricing.note}</p>}
		<div class="mt-6">
			<Button href="#lead-form" size="lg">{ctaText}</Button>
		</div>
	</div>
</section>
