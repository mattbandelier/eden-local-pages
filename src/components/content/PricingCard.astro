---
import type { Service } from "../../data/types";
import Button from "../ui/Button.astro";

interface Props {
	pricing: Service["pricing"];
	consultRequired: boolean;
	ctaText: string;
}

const { pricing, consultRequired, ctaText } = Astro.props;
const priceLabel =
	pricing.model === "consult-required" || consultRequired || pricing.startingAt === undefined
		? "Consult required"
		: `Starting at $${pricing.startingAt}`;
---

<section class="px-6 py-12">
	<div class="mx-auto grid max-w-6xl gap-6 rounded-lg border border-slate-200 bg-white p-6 shadow-sm sm:p-8 lg:grid-cols-[1fr_auto] lg:items-center">
		<div>
			<p class="text-sm font-semibold uppercase text-eden-green">Pricing and next step</p>
			<h2 class="mt-2 text-3xl font-semibold text-eden-navy">{priceLabel}</h2>
			{pricing.note && <p class="mt-3 max-w-3xl text-base leading-7 text-slate-700">{pricing.note}</p>}
		</div>
		<div class="lg:text-right">
			<Button href="#lead-form" size="lg">{ctaText}</Button>
			<p class="mt-3 text-sm leading-6 text-slate-600">
				Our team confirms timing, fit, and pricing details before your visit.
			</p>
		</div>
	</div>
</section>
