---
interface Props {
	benefits: string[];
	heading?: string;
	intro?: string;
}

const { benefits, heading = "What this delivers", intro } = Astro.props;
---

<section class="px-6 py-12">
	<div class="mx-auto max-w-6xl">
		<div class="max-w-3xl">
			<p class="text-sm font-semibold uppercase text-eden-green">Best-fit outcomes</p>
			<h2 class="mt-2 text-3xl font-semibold text-eden-navy">{heading}</h2>
			{intro && <p class="mt-3 text-base leading-7 text-slate-700">{intro}</p>}
		</div>
		<ul class="mt-8 grid gap-4 md:grid-cols-2">
			{benefits.map((benefit) => (
				<li class="flex gap-3 rounded-lg border border-slate-200 bg-white p-5 text-base text-slate-700 shadow-sm">
					<svg class="mt-1 h-5 w-5 shrink-0 text-eden-green" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
						<path fill-rule="evenodd" d="M16.704 5.29a1 1 0 0 1 .006 1.414l-7.6 7.67a1 1 0 0 1-1.42 0L3.29 9.936a1 1 0 1 1 1.42-1.408l3.69 3.723 6.89-6.955a1 1 0 0 1 1.414-.006Z" clip-rule="evenodd" />
					</svg>
					<span>{benefit}</span>
				</li>
			))}
		</ul>
	</div>
</section>
