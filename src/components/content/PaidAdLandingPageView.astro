---
import type { PaidAdPage } from "../../data/paid-ad-pages";
import { faqItemsJsonLd } from "../../lib/schema-org";
import { ORIGIN } from "../../lib/urls";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BookingCTA from "./BookingCTA.astro";

interface Props {
	page: PaidAdPage;
}

const { page } = Astro.props;
const canonicalUrl = `${ORIGIN}/${page.slug}/`;
const booking = {
	serviceSlug: page.serviceSlug,
	serviceName: page.serviceName,
	serviceCategory: page.serviceCategory,
	label: "Book a Consult",
};
const primaryCtaClass = "inline-flex min-h-12 items-center justify-center rounded-md bg-eden-sage px-6 py-3 text-center text-base font-semibold text-eden-forest shadow-sm transition hover:bg-white focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-eden-forest";
const darkCtaClass = "inline-flex min-h-12 items-center justify-center rounded-md bg-eden-forest px-6 py-3 text-center text-base font-semibold text-white shadow-sm transition hover:bg-eden-green focus:outline-none focus:ring-2 focus:ring-eden-green focus:ring-offset-2";
const jsonLd = [
	{
		"@context": "https://schema.org",
		"@type": "MedicalBusiness",
		"@id": `${canonicalUrl}#medical-business`,
		name: "Eden Health Club",
		url: canonicalUrl,
		telephone: "+17206057678",
		image: `${ORIGIN}${page.heroImage}`,
		priceRange: "$$",
		address: {
			"@type": "PostalAddress",
			streetAddress: "5990 S University Blvd",
			addressLocality: "Greenwood Village",
			addressRegion: "CO",
			postalCode: "80121",
			addressCountry: "US",
		},
		aggregateRating: {
			"@type": "AggregateRating",
			ratingValue: "4.9",
			reviewCount: "122",
		},
		areaServed: ["Greenwood Village", "Denver", "Denver Tech Center"],
	},
	{
		"@context": "https://schema.org",
		"@type": "Service",
		"@id": `${canonicalUrl}#service`,
		name: page.serviceName,
		serviceType: page.keyword,
		description: page.description,
		url: canonicalUrl,
		provider: { "@id": `${canonicalUrl}#medical-business` },
		areaServed: "Denver metro",
	},
	faqItemsJsonLd(canonicalUrl, page.faqs),
];
---

<BaseLayout
	title={page.title}
	description={page.description}
	canonicalUrl={canonicalUrl}
	ogImage={`${ORIGIN}${page.heroImage}`}
	jsonLd={jsonLd}
	noindex={true}
	preloadImages={[page.heroImage]}
>
	<header class="absolute inset-x-0 top-0 z-30 border-b border-white/20 bg-eden-forest/80 px-5 py-3 backdrop-blur-sm sm:px-6">
		<div class="mx-auto flex max-w-6xl items-center justify-between gap-4">
			<img src="/assets/eden-health-club-logo-white-transparent-tight.png" alt="Eden Health Club" width="190" height="56" class="h-10 w-auto object-contain" />
			<div class="hidden sm:block">
				<BookingCTA {...booking} class={primaryCtaClass} />
			</div>
		</div>
	</header>

	<main class="bg-white pb-20 text-eden-navy md:pb-0">
		<section class="relative flex min-h-[min(78svh,720px)] items-end overflow-hidden bg-eden-forest px-5 pb-14 pt-28 text-white sm:px-6 sm:pb-16">
			<img
				src={page.heroImage}
				alt={page.heroAlt}
				width="1600"
				height="1067"
				fetchpriority="high"
				decoding="async"
				class="absolute inset-0 h-full w-full object-cover"
			/>
			<div class="absolute inset-0 bg-eden-forest/78"></div>
			<div class="relative mx-auto w-full max-w-6xl">
				<div class="max-w-3xl">
					<p class="text-sm font-semibold uppercase text-eden-sage">Greenwood Village · Serving Denver Metro</p>
					<h1 class="mt-4 break-words text-4xl font-semibold leading-tight text-white sm:text-5xl lg:text-6xl">{page.h1}</h1>
					<p class="mt-5 max-w-2xl text-lg leading-8 text-white/90">{page.subhead}</p>
					<div class="mt-7 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
						<BookingCTA {...booking} class={primaryCtaClass} />
						<div class="flex items-center gap-3 rounded-md border border-white/25 bg-eden-forest/70 px-4 py-3" aria-label="Rated 4.9 out of 5 from more than 122 reviews">
							<span class="text-lg text-eden-sage" aria-hidden="true">★★★★★</span>
							<span class="text-sm font-semibold">4.9 stars / 122+ reviews</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="bg-white px-5 py-14 sm:px-6 sm:py-18" aria-labelledby={`${page.slug}-audience`}>
			<div class="mx-auto max-w-6xl">
				<p class="text-sm font-semibold uppercase text-eden-green">What it is for</p>
				<h2 id={`${page.slug}-audience`} class="mt-3 max-w-3xl text-3xl font-semibold leading-tight sm:text-4xl">{page.audienceTitle}</h2>
				<!-- {{CLINICAL_REVIEW}}: Christina/Shannon must approve all efficacy and candidacy language in this section before launch. -->
				<p class="mt-5 max-w-3xl text-base leading-8 text-slate-700">{page.audienceIntro}</p>
				<div class="mt-8 grid gap-4 md:grid-cols-3">
					{page.audience.map((item) => (
						<article class="rounded-md border border-eden-line bg-eden-paper p-6">
							<h3 class="text-lg font-semibold">{item.title}</h3>
							<p class="mt-3 text-sm leading-7 text-slate-700">{item.body}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="bg-eden-paper px-5 py-14 sm:px-6 sm:py-18" aria-labelledby={`${page.slug}-why`}>
			<div class="mx-auto max-w-6xl">
				<p class="text-sm font-semibold uppercase text-eden-green">Why Eden</p>
				<h2 id={`${page.slug}-why`} class="mt-3 text-3xl font-semibold leading-tight sm:text-4xl">Local care, accountable providers</h2>
				<div class="mt-8 grid gap-x-8 gap-y-6 sm:grid-cols-2 lg:grid-cols-4">
					{[
						["Physician-led", "Clinical oversight supports thoughtful evaluation and treatment planning."],
						["Licensed providers", "Meet with a qualified local provider who can assess candidacy and risks."],
						["Greenwood Village", "Visit Eden near DTC at 5990 S University Blvd, serving the Denver metro."],
						["Not a franchise", "Your plan is built by Eden's local team, not handed down from a national script."],
					].map(([title, body]) => (
						<div class="border-l-2 border-eden-green pl-5">
							<h3 class="text-lg font-semibold">{title}</h3>
							<p class="mt-2 text-sm leading-7 text-slate-700">{body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="bg-eden-forest px-5 py-14 text-white sm:px-6 sm:py-18" aria-labelledby={`${page.slug}-steps`}>
			<div class="mx-auto max-w-6xl">
				<p class="text-sm font-semibold uppercase text-eden-sage">What to expect</p>
				<h2 id={`${page.slug}-steps`} class="mt-3 text-3xl font-semibold leading-tight sm:text-4xl">A clear three-step visit</h2>
				<div class="mt-9 grid gap-8 md:grid-cols-3">
					{[
						["1", "Book your consult", "Choose an available time in Eden's Zenoti booking flow."],
						["2", "Meet your provider", "Review your goals, history, candidacy, risks, and alternatives."],
						["3", "Choose your plan", "See the recommended next steps and transparent price before deciding."],
					].map(([number, title, body]) => (
						<div>
							<div class="flex h-10 w-10 items-center justify-center rounded-full bg-eden-sage text-sm font-semibold text-eden-forest">{number}</div>
							<h3 class="mt-4 text-xl font-semibold">{title}</h3>
							<p class="mt-3 text-sm leading-7 text-white/80">{body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="bg-white px-5 py-14 sm:px-6 sm:py-18" aria-labelledby={`${page.slug}-pricing`}>
			<div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[1fr_0.72fr] lg:items-center">
				<div>
					<p class="text-sm font-semibold uppercase text-eden-green">Transparent pricing</p>
					<h2 id={`${page.slug}-pricing`} class="mt-3 text-3xl font-semibold leading-tight sm:text-4xl">{page.pricingTitle}</h2>
					<p class="mt-5 max-w-2xl text-base leading-8 text-slate-700">{page.pricingBody}</p>
					<p class="mt-4 max-w-2xl text-sm leading-7 text-slate-600">{page.pricingNote}</p>
				</div>
				<div class="rounded-md border border-eden-line bg-eden-paper p-6 sm:p-8">
					<p class="text-sm font-semibold uppercase text-eden-green">Consult to build your plan</p>
					<p class="mt-3 text-xl font-semibold">No surprise treatment package at checkout.</p>
					<BookingCTA {...booking} class={`${darkCtaClass} mt-6 w-full`} />
				</div>
			</div>
		</section>

		<section class="bg-eden-paper px-5 py-14 sm:px-6 sm:py-18" aria-labelledby={`${page.slug}-faq`}>
			<div class="mx-auto max-w-3xl">
				<p class="text-sm font-semibold uppercase text-eden-green">FAQ</p>
				<h2 id={`${page.slug}-faq`} class="mt-3 text-3xl font-semibold leading-tight sm:text-4xl">Questions before you book</h2>
				<div class="mt-8 divide-y divide-eden-line rounded-md border border-eden-line bg-white">
					{page.faqs.map((faq) => (
						<details class="group p-5">
							<summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-base font-semibold">
								<span>{faq.question}</span>
								<span class="text-eden-green transition group-open:rotate-180" aria-hidden="true">+</span>
							</summary>
							<p class="mt-4 text-sm leading-7 text-slate-700">{faq.answer}</p>
						</details>
					))}
				</div>
			</div>
		</section>

		<section class="bg-white px-5 py-14 sm:px-6 sm:py-18" aria-labelledby={`${page.slug}-reviews`}>
			<div class="mx-auto max-w-6xl text-center">
				<p class="text-sm font-semibold uppercase text-eden-green">Local trust</p>
				<h2 id={`${page.slug}-reviews`} class="mt-3 text-4xl font-semibold">4.9 out of 5</h2>
				<p class="mt-3 text-lg font-semibold text-eden-green" aria-hidden="true">★★★★★</p>
				<p class="mx-auto mt-4 max-w-2xl text-base leading-8 text-slate-700">Based on 122+ reviews. Eden Health Club is a local, physician-led practice in Greenwood Village, not a franchise. Individual experiences vary.</p>
			</div>
		</section>

		<section class="bg-eden-forest px-5 py-14 text-white sm:px-6 sm:py-16">
			<div class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-7 md:flex-row md:items-center">
				<div>
					<p class="text-sm font-semibold uppercase text-eden-sage">Greenwood Village · Serving Denver Metro</p>
					<h2 class="mt-3 max-w-2xl text-3xl font-semibold leading-tight sm:text-4xl">Start with a conversation about your goals.</h2>
				</div>
				<BookingCTA {...booking} class={`${primaryCtaClass} w-full md:w-auto`} />
			</div>
		</section>
	</main>

	<footer class="bg-eden-navy px-5 py-8 text-center text-sm text-white/70 sm:px-6">
		<p>Eden Health Club · 5990 S University Blvd · Greenwood Village, CO 80121</p>
	</footer>

	<div class="fixed inset-x-0 bottom-0 z-40 border-t border-eden-line bg-white p-3 shadow-[0_-4px_16px_rgba(28,45,38,0.12)] md:hidden">
		<BookingCTA {...booking} class={`${darkCtaClass} w-full`} />
	</div>
</BaseLayout>
