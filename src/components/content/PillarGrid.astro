---
const pillars = [
	{
		title: "Functional Medicine",
		body: "Hormones, weight management, peptide protocols, and lab-guided plans built around clinical context.",
	},
	{
		title: "Beauty + Aesthetics",
		body: "Injectables, skin treatments, and regenerative aesthetics with natural-looking, expert-led results.",
	},
	{
		title: "Wellness + Recovery",
		body: "IV therapy, NAD+ support, and recovery services for demanding bodies and full calendars.",
	},
	{
		title: "Fitness + Performance",
		body: "A performance-minded wellness home for members who want to look better, feel better, and perform better.",
	},
];
---

<section class="px-6 py-12">
	<div class="mx-auto max-w-6xl">
		<h2 class="text-3xl font-semibold text-eden-navy">Four pillars under one roof</h2>
		<div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
			{pillars.map((pillar) => (
				<div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
					<h3 class="text-lg font-semibold text-eden-navy">{pillar.title}</h3>
					<p class="mt-3 text-sm leading-6 text-slate-700">{pillar.body}</p>
				</div>
			))}
		</div>
	</div>
</section>
