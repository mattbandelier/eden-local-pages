---
interface Props {
	currentPath?: string;
	variant?: "combo" | "hub";
}

const { currentPath = "", variant = "combo" } = Astro.props;

const moneyPages = [
	{
		label: "Botox in Greenwood Village",
		href: "/botox/greenwood-village/",
		intent: "Expression lines, prevention, and natural-looking wrinkle relaxer planning.",
		group: "Injectables",
	},
	{
		label: "DiamondGlow facial",
		href: "/diamondglow-facial/greenwood-village/",
		intent: "Medical-grade glow, pores, hydration, and pre-event skin polish.",
		group: "Skin",
	},
	{
		label: "Lip filler",
		href: "/lip-filler/greenwood-village/",
		intent: "Shape, hydration, border support, and subtle lip proportion.",
		group: "Injectables",
	},
	{
		label: "Dermal fillers",
		href: "/dermal-fillers/greenwood-village/",
		intent: "Facial balancing, volume support, folds, contour, and proportion.",
		group: "Injectables",
	},
	{
		label: "Microneedling",
		href: "/microneedling/greenwood-village/",
		intent: "Texture, pores, fine lines, collagen support, and gradual skin quality.",
		group: "Skin",
	},
	{
		label: "BBL photofacial",
		href: "/bbl-photofacial/greenwood-village/",
		intent: "Tone, redness, brown spots, visible sun damage, and skin clarity.",
		group: "Skin",
	},
	{
		label: "IV therapy",
		href: "/iv-therapy/greenwood-village/",
		intent: "Hydration, recovery, energy, glow, immunity, and active lifestyle support.",
		group: "Wellness",
	},
	{
		label: "NAD+ IV therapy",
		href: "/nad-iv-therapy/greenwood-village/",
		intent: "NAD+ route, dose, tolerance, recovery routines, and longevity-minded support.",
		group: "Wellness",
	},
	{
		label: "Medical weight loss",
		href: "/medical-weight-loss/greenwood-village/",
		intent: "Provider-guided screening, bloodwork, eligibility, and monitored follow-up.",
		group: "Wellness",
	},
	{
		label: "Medical weight loss Denver",
		href: "/medical-weight-loss/denver/",
		intent: "Denver search path for provider-guided weight-loss screening, labs, monitoring, and follow-up.",
		group: "Wellness",
	},
	{
		label: "Red light therapy Denver",
		href: "/red-light-therapy-denver/",
		intent: "Recovery, readiness, sauna, compression, IV therapy, and performance support near DTC.",
		group: "Recovery",
	},
	{
		label: "Strength training",
		href: "/strength-training-greenwood-village/",
		intent: "Coached strength for body composition, longevity, medical weight loss support, and performance.",
		group: "Fitness",
	},
	{
		label: "Group fitness classes",
		href: "/group-fitness-classes-greenwood-village/",
		intent: "Small-format coaching, community, and accountability inside Eden's wellness facility.",
		group: "Fitness",
	},
	{
		label: "GLP-1 strength training",
		href: "/glp-1-strength-training-greenwood-village/",
		intent: "Muscle preservation, InBody tracking, recovery, and strength support around weight loss.",
		group: "Fitness",
	},
	{
		label: "Perform Membership",
		href: "/glp-1-fitness-membership-greenwood-village/",
		intent: "Supported membership path for weight-loss clients who need strength, check-ins, and recovery.",
		group: "Fitness",
	},
	{
		label: "Elevate Membership",
		href: "/elevate-membership-greenwood-village/",
		intent: "Premium fitness, recovery, body composition, biomarker context, and wellness guidance.",
		group: "Fitness",
	},
	{
		label: "Medical weight loss fitness",
		href: "/medical-weight-loss-fitness-greenwood-village/",
		intent: "Bridge medical weight loss into strength, InBody tracking, recovery, and long-term maintenance.",
		group: "Fitness",
	},
	{
		label: "Performance Lab",
		href: "/performance-lab-greenwood-village/",
		intent: "Baseline assessment for training, recovery, body composition, and performance direction.",
		group: "Fitness",
	},
	{
		label: "Hormone optimization",
		href: "/hormone-optimization/",
		intent: "Provider-led hormone evaluation connected to labs, training, recovery, and follow-up.",
		group: "Hormones",
	},
	{
		label: "Men's hormone optimization",
		href: "/mens-hormone-optimization/",
		intent: "Lab-backed consult for men comparing energy, recovery, focus, training, and hormone fit.",
		group: "Hormones",
	},
	{
		label: "Women's hormone optimization",
		href: "/womens-hormone-optimization/",
		intent: "Provider-led consult for women comparing sleep, mood, energy, body composition, and labs.",
		group: "Hormones",
	},
	{
		label: "Menopause hormone therapy",
		href: "/menopause-hormone-therapy/",
		intent: "Perimenopause and menopause consult path for symptoms, labs, options, and next steps.",
		group: "Hormones",
	},
	{
		label: "Hormone therapy cost",
		href: "/hormone-therapy-cost/",
		intent: "Cost guide for consults, labs, monitoring, follow-up, and comparing Denver hormone care.",
		group: "Hormones",
	},
	{
		label: "Female BHRT",
		href: "/female-bhrt/greenwood-village/",
		intent: "Lab-guided hormone evaluation, symptoms, history, and follow-up planning.",
		group: "Hormones",
	},
	{
		label: "Men's TRT",
		href: "/male-trt/greenwood-village/",
		intent: "Lab-guided testosterone evaluation, safety review, and accountable monitoring.",
		group: "Hormones",
	},
	{
		label: "TRT Denver",
		href: "/male-trt/denver/",
		intent: "Denver path for men comparing low T symptoms, labs, provider review, and follow-up.",
		group: "Hormones",
	},
	{
		label: "Women's hormones Denver",
		href: "/female-bhrt/denver/",
		intent: "Denver path for lab-guided hormone evaluation, symptoms, life stage, and provider review.",
		group: "Hormones",
	},
	{
		label: "Peptide therapy",
		href: "/peptide-therapy/greenwood-village/",
		intent: "Provider-led protocol fit for recovery, performance, sleep, skin, or body composition goals.",
		group: "Wellness",
	},
	{
		label: "PRF hair restoration",
		href: "/prf-hair-restoration/greenwood-village/",
		intent: "Hair thinning candidacy, timeline, expectations, and series planning.",
		group: "Regenerative",
	},
];

const visiblePages = moneyPages.filter((page) => page.href !== currentPath);
const featuredPages =
	variant === "hub"
		? visiblePages
		: [
				...visiblePages.filter((page) => ["Injectables", "Skin"].includes(page.group)).slice(0, 5),
				...visiblePages.filter((page) => page.group === "Wellness").slice(0, 4),
				...visiblePages.filter((page) => page.group === "Fitness").slice(0, 6),
				...visiblePages.filter((page) => page.group === "Recovery").slice(0, 2),
				...visiblePages.filter((page) => page.group === "Hormones").slice(0, 4),
			];
---

<section class="bg-white px-6 py-14 sm:py-16" aria-labelledby="priority-money-links-heading">
	<div class="mx-auto max-w-6xl">
		<div class="grid gap-6 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
			<div>
				<p class="text-sm font-semibold uppercase text-eden-green">Plan your next visit</p>
				<h2 id="priority-money-links-heading" class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
					Popular Eden services clients compare before booking.
				</h2>
				<p class="mt-4 text-base leading-7 text-slate-700">
					If you are deciding where to start, these pages help narrow the choice by goal, timing, and provider fit near Greenwood Village, DTC, Denver, and South Denver.
				</p>
				<a href="/medical-spa-denver/" class="mt-5 inline-block text-sm font-semibold text-eden-green">
					Explore the Denver med spa hub
				</a>
			</div>
			<div class="grid gap-3 sm:grid-cols-2">
				{featuredPages.map((page) => (
					<a href={page.href} class="rounded-lg border border-eden-line bg-eden-paper p-5 transition hover:-translate-y-0.5 hover:border-eden-green hover:bg-white hover:shadow-sm">
						<div class="flex items-start justify-between gap-4">
							<h3 class="text-base font-semibold text-eden-navy">{page.label}</h3>
							<span class="shrink-0 rounded-full bg-white px-3 py-1 text-xs font-semibold text-eden-green">{page.group}</span>
						</div>
						<p class="mt-3 text-sm leading-6 text-slate-700">{page.intent}</p>
						<span class="mt-4 inline-block text-sm font-semibold text-eden-green">Open page</span>
					</a>
				))}
			</div>
		</div>
	</div>
</section>
