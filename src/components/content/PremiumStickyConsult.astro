---
import type { Service } from "../../data/types";

interface Props {
	service: Service;
}

const { service } = Astro.props;
---

<div
	data-premium-sticky-consult
	class="pointer-events-none fixed bottom-5 right-5 z-40 hidden max-w-xs translate-y-3 rounded-lg border border-white/20 bg-eden-forest/95 p-3 text-white opacity-0 shadow-2xl backdrop-blur transition duration-200 md:block"
>
	<p class="text-xs font-semibold uppercase text-eden-sage">Open now in Greenwood Village</p>
	<p class="mt-1 text-sm leading-5 text-white/82">
		Start with a consult, then route to the right medical wellness, recovery, or optimization path.
	</p>
	<a href="#lead-form" class="mt-3 block rounded-md bg-eden-sage px-4 py-3 text-center text-sm font-semibold text-eden-forest">
		{service.ctaText}
	</a>
</div>

<script>
	const stickyConsult = document.querySelector<HTMLElement>("[data-premium-sticky-consult]");
	const updateStickyConsult = () => {
		if (!stickyConsult) return;
		const shouldShow = window.scrollY > window.innerHeight * 0.55;
		stickyConsult.classList.toggle("opacity-0", !shouldShow);
		stickyConsult.classList.toggle("translate-y-3", !shouldShow);
		stickyConsult.classList.toggle("pointer-events-none", !shouldShow);
	};

	updateStickyConsult();
	window.addEventListener("scroll", updateStickyConsult, { passive: true });
	window.addEventListener("resize", updateStickyConsult);
</script>
