---
import type { Service } from "../../data/types";

interface Props {
	service: Service;
}

const { service } = Astro.props;
---

<section class="px-6 py-8">
	<div class="mx-auto max-w-6xl rounded-lg border border-slate-200 bg-slate-50 p-5">
		<p class="text-sm leading-6 text-slate-700">
			For the complete Eden Health Club service overview, visit
			<a
				href={service.internalPageUrl}
				target="_blank"
				rel="noopener"
				class="font-semibold text-eden-navy underline underline-offset-4 hover:text-eden-green"
			>
				{service.name} at edenhealthclubs.com
			</a>.
		</p>
	</div>
</section>
