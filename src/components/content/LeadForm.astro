---
interface Props {
	serviceSlug: string;
	suburbSlug: string | null;
	heading?: string;
	subheading?: string;
	submitText?: string;
	messageLabel?: string;
	goalOptions?: string[];
	compact?: boolean;
	underButtonText?: string;
	hiddenMessage?: string;
	workflowKey?: string;
	offerName?: string;
	offerValue?: string;
}

const {
	serviceSlug,
	suburbSlug = null,
	heading = "Book a consult",
	subheading = "We'll reach out within one business day.",
	submitText = "Request a consult",
	messageLabel = "Anything you'd like us to know",
	goalOptions = [],
	compact = false,
	underButtonText = "",
	hiddenMessage = "",
	workflowKey = "",
	offerName = "",
	offerValue = "",
} = Astro.props;
---

<section id="lead-form" class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
	<h2 class="text-2xl font-semibold tracking-tight text-eden-navy">{heading}</h2>
	<p class="mt-1 text-sm text-slate-600">{subheading}</p>

	<form
		class="mt-6 space-y-4"
		data-lead-form
		data-service-slug={serviceSlug}
		data-suburb-slug={suburbSlug ?? ""}
		novalidate
	>
		{compact ? (
			<label class="block">
				<span class="text-sm font-medium text-eden-navy">Name</span>
				<input
					type="text"
					name="fullName"
					required
					autocomplete="name"
					class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-3 text-base focus:border-eden-green focus:outline-none focus:ring-1 focus:ring-eden-green"
				/>
			</label>
		) : (
			<div class="grid gap-4 sm:grid-cols-2">
				<label class="block">
					<span class="text-sm font-medium text-eden-navy">First name</span>
					<input
						type="text"
						name="firstName"
						autocomplete="given-name"
						class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-eden-green focus:outline-none focus:ring-1 focus:ring-eden-green"
					/>
				</label>
				<label class="block">
					<span class="text-sm font-medium text-eden-navy">Last name</span>
					<input
						type="text"
						name="lastName"
						autocomplete="family-name"
						class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-eden-green focus:outline-none focus:ring-1 focus:ring-eden-green"
					/>
				</label>
			</div>
		)}

		<label class="block">
			<span class="text-sm font-medium text-eden-navy">
				Phone <span class="text-eden-green">*</span>
			</span>
			<input
				type="tel"
				name="phone"
				required
				autocomplete="tel"
				inputmode="tel"
				class:list={[
					"mt-1 block w-full rounded-md border border-slate-300 px-3 focus:border-eden-green focus:outline-none focus:ring-1 focus:ring-eden-green",
					compact ? "py-3 text-base" : "py-2 text-sm",
				]}
			/>
		</label>

		<label class="block">
			<span class="text-sm font-medium text-eden-navy">
				Email <span class="text-eden-green">*</span>
			</span>
			<input
				type="email"
				name="email"
				required
				autocomplete="email"
				class:list={[
					"mt-1 block w-full rounded-md border border-slate-300 px-3 focus:border-eden-green focus:outline-none focus:ring-1 focus:ring-eden-green",
					compact ? "py-3 text-base" : "py-2 text-sm",
				]}
			/>
		</label>

		{!compact && (
			<label class="flex items-start gap-3">
				<input
					type="checkbox"
					name="smsOptIn"
					class="mt-1 h-4 w-4 rounded border-slate-300 text-eden-green focus:ring-eden-green"
				/>
				<span class="text-sm text-slate-700">
					I agree to receive SMS messages from Eden Health Club. Reply STOP at any time to opt out. Message &amp; data rates may apply.
				</span>
			</label>
		)}

		{!compact && (
			<label class="block">
				<span class="text-sm font-medium text-eden-navy">{messageLabel}</span>
				{goalOptions.length ? (
					<select
						name="message"
						class="mt-1 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm focus:border-eden-green focus:outline-none focus:ring-1 focus:ring-eden-green"
					>
						<option value="">Choose one</option>
						{goalOptions.map((option) => (
							<option value={option}>{option}</option>
						))}
					</select>
				) : (
					<textarea
						name="message"
						rows="3"
						class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-eden-green focus:outline-none focus:ring-1 focus:ring-eden-green"
					></textarea>
				)}
			</label>
		)}

		<div class="hidden" aria-hidden="true">
			<label>
				Website
				<input type="text" name="website" tabindex="-1" autocomplete="off" />
			</label>
			<input type="hidden" name="sourcePage" data-attribution-field="sourcePage" />
			<input type="hidden" name="utmSource" data-attribution-field="utmSource" />
			<input type="hidden" name="utmMedium" data-attribution-field="utmMedium" />
			<input type="hidden" name="utmCampaign" data-attribution-field="utmCampaign" />
			<input type="hidden" name="utmTerm" data-attribution-field="utmTerm" />
			<input type="hidden" name="utmContent" data-attribution-field="utmContent" />
			<input type="hidden" name="gclid" data-attribution-field="gclid" />
			<input type="hidden" name="gbraid" data-attribution-field="gbraid" />
			<input type="hidden" name="wbraid" data-attribution-field="wbraid" />
			<input type="hidden" name="fbclid" data-attribution-field="fbclid" />
			<input type="hidden" name="gclsrc" data-attribution-field="gclsrc" />
			<input type="hidden" name="gadSource" data-attribution-field="gadSource" />
			<input type="hidden" name="gadCampaignId" data-attribution-field="gadCampaignId" />
			{workflowKey && <input type="hidden" name="workflowKey" value={workflowKey} />}
			{offerName && <input type="hidden" name="offerName" value={offerName} />}
			{offerValue && <input type="hidden" name="offerValue" value={offerValue} />}
			{hiddenMessage && <input type="hidden" name="hiddenMessage" value={hiddenMessage} />}
		</div>

		<button
			type="submit"
			class="w-full rounded-md bg-eden-green px-6 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-eden-green/90 focus:outline-none focus:ring-2 focus:ring-eden-green focus:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-60"
		>
			{submitText}
		</button>

		{underButtonText && <p class="text-center text-sm font-semibold text-slate-600">{underButtonText}</p>}

		<div
			data-lead-form-success
			hidden
			class="rounded-md border border-eden-green bg-eden-green/5 p-4 text-sm text-eden-navy"
		>
			Thanks. We received your information and will reach out within one business day.
		</div>

		<div
			data-lead-form-error
			hidden
			class="rounded-md border border-red-300 bg-red-50 p-4 text-sm text-red-900"
		>
			{compact ? "Something went wrong. Please try again." : <span>Something went wrong. Please try again, or call us at <a href="tel:+17206057678" class="underline">720-605-7678</a>.</span>}
		</div>
	</form>
</section>

<script>
	import { getAttribution, initAttribution } from "../../lib/attribution";
	import { trackLeadSubmit, trackLeadSubmitAttempt, trackLeadSubmitError } from "../../lib/tracking";

	type AttributionSnapshot = ReturnType<typeof getAttribution>;

	const ATTRIBUTION_FIELD_MAP = {
		utmSource: "utm_source",
		utmMedium: "utm_medium",
		utmCampaign: "utm_campaign",
		utmTerm: "utm_term",
		utmContent: "utm_content",
		gclid: "gclid",
		gbraid: "gbraid",
		wbraid: "wbraid",
		fbclid: "fbclid",
		gclsrc: "gclsrc",
		gadSource: "gad_source",
		gadCampaignId: "gad_campaignid",
	} as const;

	function currentPage(): string {
		return `${window.location.origin}${window.location.pathname}${window.location.search}${window.location.hash}`;
	}

	function attributionValue(attribution: AttributionSnapshot, key: keyof typeof ATTRIBUTION_FIELD_MAP): string | null {
		const paramName = ATTRIBUTION_FIELD_MAP[key];
		const params = new URLSearchParams(window.location.search);
		return params.get(paramName) || attribution.lastTouch[paramName] || attribution.firstTouch[paramName] || null;
	}

	function syncHiddenAttributionFields(form: HTMLFormElement, attribution: AttributionSnapshot): void {
		form.querySelectorAll<HTMLInputElement>("[data-attribution-field]").forEach((input) => {
			const field = input.dataset.attributionField || "";
			if (field === "sourcePage") {
				input.value = currentPage();
				return;
			}
			if (field in ATTRIBUTION_FIELD_MAP) {
				input.value = attributionValue(attribution, field as keyof typeof ATTRIBUTION_FIELD_MAP) || "";
			}
		});
	}

	function getGaClientId(): string | null {
		const match = document.cookie.match(/(?:^|;\s*)_ga=([^;]+)/);
		if (!match) return null;

		const cookieValue = decodeURIComponent(match[1]);
		const parts = cookieValue.split(".");
		if (parts.length >= 4) {
			return `${parts[parts.length - 2]}.${parts[parts.length - 1]}`;
		}

		return cookieValue || null;
	}

	function combinedMessage(fd: FormData): string | null {
		const visibleMessage = ((fd.get("message") as string) || "").trim();
		const hiddenContext = ((fd.get("hiddenMessage") as string) || "").trim();

		if (visibleMessage && hiddenContext) {
			return `${visibleMessage}\n\n${hiddenContext}`;
		}

		return visibleMessage || hiddenContext || null;
	}

	function initLeadForm(form: HTMLFormElement) {
		initAttribution();
		const serviceSlug = form.dataset.serviceSlug || "";
		const suburbSlug = form.dataset.suburbSlug || null;
		const successEl = form.querySelector<HTMLElement>("[data-lead-form-success]");
		const errorEl = form.querySelector<HTMLElement>("[data-lead-form-error]");
		const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');

		form.addEventListener("submit", async (e) => {
			e.preventDefault();
			if (successEl) successEl.hidden = true;
			if (errorEl) errorEl.hidden = true;
			if (submitBtn) submitBtn.disabled = true;

			trackLeadSubmitAttempt(serviceSlug, suburbSlug);

			const attribution = getAttribution();
			syncHiddenAttributionFields(form, attribution);
			const fd = new FormData(form);
			const fullName = ((fd.get("fullName") as string) || "").trim();
			const [derivedFirstName, ...derivedLastNameParts] = fullName.split(/\s+/).filter(Boolean);
			const payload = {
				firstName: (fd.get("firstName") as string) || derivedFirstName || null,
				lastName: (fd.get("lastName") as string) || derivedLastNameParts.join(" ") || null,
				phone: (fd.get("phone") as string) || "",
				email: (fd.get("email") as string) || "",
				smsOptIn: fd.get("smsOptIn") === "on",
				message: combinedMessage(fd),
				service: serviceSlug,
				suburb: suburbSlug,
				sourcePage: currentPage(),
				utmSource: attributionValue(attribution, "utmSource"),
				utmMedium: attributionValue(attribution, "utmMedium"),
				utmCampaign: attributionValue(attribution, "utmCampaign"),
				utmTerm: attributionValue(attribution, "utmTerm"),
				utmContent: attributionValue(attribution, "utmContent"),
				gclid: attributionValue(attribution, "gclid"),
				gbraid: attributionValue(attribution, "gbraid"),
				wbraid: attributionValue(attribution, "wbraid"),
				fbclid: attributionValue(attribution, "fbclid"),
				gclsrc: attributionValue(attribution, "gclsrc"),
				gadSource: attributionValue(attribution, "gadSource"),
				gadCampaignId: attributionValue(attribution, "gadCampaignId"),
				workflowKey: (fd.get("workflowKey") as string) || null,
				offerName: (fd.get("offerName") as string) || null,
				offerValue: (fd.get("offerValue") as string) || null,
				gaClientId: getGaClientId(),
				referrer: document.referrer || null,
				firstTouch: attribution.firstTouch,
				lastTouch: attribution.lastTouch,
				submittedAt: new Date().toISOString(),
				website: (fd.get("website") as string) || "",
			};

			try {
				const res = await fetch("/api/lead/", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify(payload),
				});
				const data = await res.json();
				if (res.ok && data.success) {
					if (typeof window !== "undefined") {
						window.dataLayer = window.dataLayer || [];
						window.dataLayer.push({
							user_email: payload.email,
							user_phone: payload.phone,
						});
					}
					trackLeadSubmit(serviceSlug, suburbSlug, payload.smsOptIn);
					if (successEl) successEl.hidden = false;
					form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>("input, textarea, select").forEach((el) => {
						if (el.type !== "hidden") el.value = "";
						if (el.type === "checkbox") (el as HTMLInputElement).checked = false;
					});
				} else {
					trackLeadSubmitError(serviceSlug, suburbSlug, data.error || "unknown");
					if (errorEl) errorEl.hidden = false;
				}
			} catch {
				trackLeadSubmitError(serviceSlug, suburbSlug, "network");
				if (errorEl) errorEl.hidden = false;
			} finally {
				if (submitBtn) submitBtn.disabled = false;
			}
		});
	}

	document.querySelectorAll<HTMLFormElement>("[data-lead-form]").forEach(initLeadForm);
</script>
