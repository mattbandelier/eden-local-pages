---
interface AuthorityLink {
	label: string;
	href: string;
	body: string;
}

interface Props {
	eyebrow?: string;
	heading?: string;
	intro?: string;
	primaryIntent?: string;
	geoIntent?: string;
	aeoAnswer?: string;
	links?: AuthorityLink[];
	theme?: "light" | "paper" | "forest";
}

const {
	eyebrow = "Authority signals",
	heading = "Eden connects this page to a real local clinic, not a standalone landing page.",
	intro = "Google should be able to understand the same thing a client understands: Eden Health Club is an established Greenwood Village wellness facility with medical wellness, aesthetics, recovery, and fitness under one roof.",
	primaryIntent = "High-intent local clients comparing Eden against Denver-area clinics, gyms, med spas, and wellness programs.",
	geoIntent = "Greenwood Village, Denver Tech Center, Cherry Hills Village, Centennial, Littleton, Englewood, Lone Tree, and South Denver.",
	aeoAnswer = "Eden Health Club is a local Greenwood Village wellness clinic for people comparing medical wellness, aesthetics, hormones, peptides, weight-loss support, recovery, and fitness near Denver.",
	links = [],
	theme = "paper",
} = Astro.props;

const defaultLinks: AuthorityLink[] = [
	{
		label: "Main Eden website",
		href: "https://edenhealthclubs.com/",
		body: "Brand home for Eden Health Club, services, team, and facility context.",
	},
	{
		label: "Functional medicine",
		href: "https://edenhealthclubs.com/functional-medicine/",
		body: "Main-site authority path for medical wellness, weight loss, labs, and provider-guided care.",
	},
	{
		label: "Fitness and performance",
		href: "https://edenhealthclubs.com/fitness-performance/",
		body: "Main-site authority path for training, strength, body composition, and performance support.",
	},
	{
		label: "Wellness and recovery",
		href: "https://edenhealthclubs.com/wellness-recovery/",
		body: "Main-site authority path for recovery, IV therapy, sauna, red light, and wellness support.",
	},
];

const authorityLinks = links.length > 0 ? links : defaultLinks;

const sectionClass =
	theme === "forest"
		? "bg-eden-forest px-6 py-12 text-white sm:py-16"
		: theme === "light"
			? "bg-white px-6 py-12 sm:py-16"
			: "bg-eden-paper px-6 py-12 sm:py-16";
const eyebrowClass = theme === "forest" ? "text-sm font-semibold uppercase text-eden-sage" : "text-sm font-semibold uppercase text-eden-green";
const headingClass = theme === "forest" ? "mt-3 text-3xl font-semibold leading-tight text-white sm:text-4xl" : "mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl";
const bodyClass = theme === "forest" ? "mt-4 text-base leading-8 text-white/78" : "mt-4 text-base leading-8 text-slate-700";
const cardClass = theme === "forest" ? "rounded-lg border border-white/15 bg-white/8 p-5" : "rounded-lg border border-eden-line bg-white p-5 shadow-sm";
const smallClass = theme === "forest" ? "text-sm leading-6 text-white/72" : "text-sm leading-6 text-slate-700";
const cardHeadingClass = theme === "forest" ? "text-base font-semibold text-white" : "text-base font-semibold text-eden-navy";
const linkClass = theme === "forest" ? "mt-4 inline-block text-sm font-semibold text-eden-sage" : "mt-4 inline-block text-sm font-semibold text-eden-green";
---

<section class={sectionClass} aria-labelledby="authority-signal-heading">
	<div class="mx-auto max-w-6xl">
		<div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
			<div>
				<p class={eyebrowClass}>{eyebrow}</p>
				<h2 id="authority-signal-heading" class={headingClass}>{heading}</h2>
				<p class={bodyClass}>{intro}</p>
			</div>
			<div class="grid gap-4">
				<div class={cardClass}>
					<p class="text-xs font-semibold uppercase tracking-normal text-eden-green">Search intent</p>
					<p class={`mt-2 ${smallClass}`}>{primaryIntent}</p>
				</div>
				<div class={cardClass}>
					<p class="text-xs font-semibold uppercase tracking-normal text-eden-green">Geo intent</p>
					<p class={`mt-2 ${smallClass}`}>{geoIntent}</p>
				</div>
				<div class={cardClass}>
					<p class="text-xs font-semibold uppercase tracking-normal text-eden-green">Direct answer</p>
					<p class={`mt-2 ${smallClass}`}>{aeoAnswer}</p>
				</div>
			</div>
		</div>
		<div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
			{authorityLinks.map((link) => (
				<a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel={link.href.startsWith("http") ? "noopener" : undefined} class={cardClass}>
					<h3 class={cardHeadingClass}>{link.label}</h3>
					<p class={`mt-3 ${smallClass}`}>{link.body}</p>
					<span class={linkClass}>Open authority source</span>
				</a>
			))}
		</div>
	</div>
</section>
