---
import "../styles/global.css";
import StructuredData from "../components/seo/StructuredData.astro";
import type { JsonLd } from "../lib/schema-org";
import { ORIGIN } from "../lib/urls";

interface Props {
	title: string;
	description: string;
	canonicalUrl: string;
	ogImage?: string;
	jsonLd?: JsonLd[];
}

const { title, description, canonicalUrl, ogImage, jsonLd = [] } = Astro.props;
const resolvedOgImage = ogImage ?? `${ORIGIN}/og-default.svg`;
const ga4MeasurementId = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID ?? "G-80TZN3GM35";
const googleAdsConversionId = import.meta.env.PUBLIC_GOOGLE_ADS_CONVERSION_ID ?? "AW-17041568244";
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={resolvedOgImage} />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<StructuredData items={jsonLd} />

		{ga4MeasurementId && googleAdsConversionId && (
			<>
				{/* Direct Google tag: bypasses the flagged GTM container while preserving GA4 + Ads measurement. */}
				<script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4MeasurementId}`}></script>
				<script is:inline define:vars={{ ga4MeasurementId, googleAdsConversionId }}>
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					window.gtag = window.gtag || gtag;
					gtag('js', new Date());
					gtag('config', ga4MeasurementId);
					gtag('config', googleAdsConversionId);
				</script>
			</>
		)}
	</head>
	<body class="min-h-screen bg-white text-eden-navy antialiased">
		<slot />
	</body>
</html>
