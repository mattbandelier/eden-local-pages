---
import "../styles/global.css";
import StructuredData from "../components/seo/StructuredData.astro";
import type { JsonLd } from "../lib/schema-org";
import { ORIGIN } from "../lib/urls";

interface Props {
	title: string;
	description: string;
	canonicalUrl: string;
	ogImage?: string;
	jsonLd?: JsonLd[];
	noindex?: boolean;
	preloadImages?: string[];
}

const { title, description, canonicalUrl, ogImage, jsonLd = [], noindex = false, preloadImages = [] } = Astro.props;
const resolvedOgImage = ogImage ?? `${ORIGIN}/og-default.svg`;
const gtmId = import.meta.env.PUBLIC_GTM_CONTAINER_ID;
const clarityProjectId = import.meta.env.PUBLIC_CLARITY_PROJECT_ID;
const callRailSwapJsUrl = import.meta.env.PUBLIC_CALLRAIL_SWAP_JS_URL;
const metaPixelId = import.meta.env.PUBLIC_META_PIXEL_ID || "1301043457641549";
const uniquePreloadImages = [...new Set(preloadImages)].filter(Boolean).slice(0, 3);
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<title>{title}</title>
		<meta name="description" content={description} />
		{noindex && <meta name="robots" content="noindex,follow" />}
		<link rel="canonical" href={canonicalUrl} />

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={resolvedOgImage} />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		{uniquePreloadImages.map((href) => (
			<link rel="preload" as="image" href={href} fetchpriority="high" />
		))}
		<meta name="generator" content={Astro.generator} />
		<StructuredData items={jsonLd} />

		{(gtmId || metaPixelId || clarityProjectId || callRailSwapJsUrl) && (
			<script is:inline define:vars={{ gtmId, metaPixelId, clarityProjectId, callRailSwapJsUrl }}>
				(function (w, d) {
					var p = new URLSearchParams(w.location.search);
					var source = (p.get("utm_source") || "").toLowerCase();
					var medium = (p.get("utm_medium") || "").toLowerCase();
					var ref = (d.referrer || "").toLowerCase();
					var badSources = ["theoffer", "katalys", "pr_campaigns", "vibe-pixel", "fluscheeitaway", "upfluence"];
					var badMediums = ["affiliate", "earned_media", "ctv", "influencer"];
					var badRefs = ["scamadviser.com", "theoffer"];
					var blocked = badSources.indexOf(source) > -1 || badMediums.indexOf(medium) > -1 || badRefs.some(function (x) { return ref.indexOf(x) > -1; });
					w.edenAnalyticsBlocked = blocked;

					var afterLoadIdle = function (fn) {
						var start = function () {
							if ("requestIdleCallback" in w) {
								w.requestIdleCallback(fn, { timeout: 1500 });
							} else {
								w.setTimeout(fn, 800);
							}
						};
						if (d.readyState === "complete") start();
						else w.addEventListener("load", start, { once: true });
					};

					afterLoadIdle(function () {
						if (gtmId) {
							w.dataLayer = w.dataLayer || [];
							if (blocked) {
								w.dataLayer.push({ event: "eden_analytics_blocked", blocked_source: source, blocked_medium: medium });
							} else {
								w.dataLayer.push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
								var f = d.getElementsByTagName("script")[0];
								var j = d.createElement("script");
								j.async = true;
								j.src = "https://www.googletagmanager.com/gtm.js?id=" + gtmId;
								f.parentNode.insertBefore(j, f);
							}
						}

						if (metaPixelId && !blocked && !w.fbq) {
							(function (f, b, e, v, n, t, s) {
								n = f.fbq = function () { n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments); };
								if (!f._fbq) f._fbq = n;
								n.push = n;
								n.loaded = true;
								n.version = "2.0";
								n.queue = [];
								t = b.createElement(e);
								t.async = true;
								t.src = v;
								s = b.getElementsByTagName(e)[0];
								s.parentNode.insertBefore(t, s);
							})(w, d, "script", "https://connect.facebook.net/en_US/fbevents.js");
							w.fbq("init", metaPixelId);
							w.fbq("track", "PageView");
						}

						if (clarityProjectId && !blocked) {
							(function (c, l, a, r, i, t, y) {
								c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments); };
								t = l.createElement(r);
								t.async = 1;
								t.src = "https://www.clarity.ms/tag/" + i;
								y = l.getElementsByTagName(r)[0];
								y.parentNode.insertBefore(t, y);
							})(w, d, "clarity", "script", clarityProjectId);
						}

						if (callRailSwapJsUrl) {
							var cr = d.createElement("script");
							cr.async = true;
							cr.src = callRailSwapJsUrl;
							d.head.appendChild(cr);
						}
					});
				})(window, document);
			</script>
		)}
	</head>
	<body class="min-h-screen bg-eden-paper text-eden-navy antialiased">
		{gtmId && (
			<noscript>
				<iframe
					src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
					height="0"
					width="0"
					style="display:none;visibility:hidden"
				></iframe>
			</noscript>
		)}
		{metaPixelId && (
			<noscript>
				<img
					height="1"
					width="1"
					style="display:none"
					src={`https://www.facebook.com/tr?id=${metaPixelId}&ev=PageView&noscript=1`}
					alt=""
				/>
			</noscript>
		)}
		<slot />
		<script is:inline>
			(function () {
				var loadHeroVideos = function () {
					if (!window.matchMedia("(min-width: 768px)").matches) return;
					if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
					document.querySelectorAll("video[data-deferred-hero-video]").forEach(function (video) {
						var source = video.querySelector("source[data-src]");
						if (!source || source.src) return;
						source.src = source.getAttribute("data-src") || "";
						video.load();
						var playPromise = video.play();
						if (playPromise && playPromise.catch) playPromise.catch(function () {});
					});
				};
				if ("requestIdleCallback" in window) {
					window.addEventListener("load", function () {
						window.requestIdleCallback(loadHeroVideos, { timeout: 1800 });
					});
				} else {
					window.addEventListener("load", function () {
						window.setTimeout(loadHeroVideos, 900);
					});
				}
			})();
		</script>
	</body>
</html>
