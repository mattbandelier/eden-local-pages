---
import BaseLayout from "../layouts/BaseLayout.astro";
import BookingCTA from "../components/content/BookingCTA.astro";
import { BOOKING_ROUTES } from "../lib/booking";

const canonical = "https://book.edenhealthclubs.com/";
const choices = [
	{ slug: "botox", label: "Aesthetics", body: "Start with an in-office aesthetic consultation for injectables, skin, laser, and treatment planning." },
	{ slug: "medical-weight-loss", label: "Medical Weight Loss", body: "Review medical weight-loss options, labs, eligibility, and provider-guided next steps." },
	{ slug: "female-bhrt", label: "Wellness / HRT", body: "Begin with a provider-led hormone and wellness consultation grounded in history and labs." },
	{ slug: "peptide-therapy", label: "Peptide Therapy", body: "Discuss protocol fit, screening, goals, and follow-up with the Eden team." },
	{ slug: "nad-iv-therapy", label: "NAD+ & Niagen", body: "Start in Wellness, then choose the NAD+ or Niagen IV/IM path that fits your goals." },
	{ slug: "iv-therapy", label: "IV Therapy", body: "Choose from Eden's wellness infusion options with the right formula confirmed before your visit." },
	{ slug: "recovery", label: "Recovery Services", body: "Explore recovery options for restoration, performance, and active-lifestyle support." },
	{ slug: "fitness", label: "Fitness", body: "Start with a fitness consultation for assessment, coaching, performance, and body composition goals." },
];
---

<BaseLayout
	title="Book Eden Health Club | Greenwood Village"
	description="Choose the right Eden Health Club starting point. Booking takes about two minutes and no account is needed until the final step."
	canonicalUrl={canonical}
	brandFonts={true}
>
	<main class="booking-interstitial min-h-screen bg-eden-paper text-eden-navy">
		<section class="border-b border-eden-line bg-eden-forest text-white">
			<div class="mx-auto max-w-6xl px-6 py-14 sm:py-20">
				<p class="text-sm font-semibold uppercase tracking-[0.18em] text-eden-sage">Eden Health Club</p>
				<h1 class="mt-4 max-w-3xl font-serif text-5xl font-medium leading-[0.98] sm:text-7xl">Look. Feel. Perform.</h1>
				<p class="mt-6 max-w-2xl text-base leading-7 text-white/80 sm:text-lg">
					Choose the right place to begin and Eden will take you into the matching booking path.
				</p>
				<div class="mt-8 flex flex-wrap gap-3 text-sm font-semibold">
					<span class="rounded-full border border-white/20 px-4 py-2">About 2 minutes</span>
					<span class="rounded-full border border-white/20 px-4 py-2">No account needed to start</span>
					<span class="rounded-full border border-white/20 px-4 py-2">Greenwood Village near DTC</span>
				</div>
			</div>
		</section>

		<section class="mx-auto grid max-w-6xl gap-8 px-6 py-12 lg:grid-cols-[1fr_0.38fr] lg:py-16">
			<div>
				<p class="text-sm font-semibold uppercase tracking-[0.16em] text-eden-green">Start here</p>
				<h2 class="mt-3 max-w-2xl font-serif text-4xl font-medium leading-tight text-eden-navy sm:text-5xl">What are you here to work on?</h2>
				<div class="mt-8 grid gap-4 sm:grid-cols-2">
					{choices.map((choice) => {
						const route = BOOKING_ROUTES[choice.slug];
						return (
							<article class="flex min-h-52 flex-col justify-between rounded-lg border border-eden-line bg-white p-5 shadow-sm">
								<div>
									<h3 class="font-serif text-2xl font-medium text-eden-navy">{choice.label}</h3>
									<p class="mt-3 text-sm leading-6 text-slate-700">{choice.body}</p>
								</div>
								<BookingCTA
									serviceSlug={choice.slug}
									serviceName={route.serviceName}
									serviceCategory={route.category}
									label="Continue to booking"
									class="mt-6 inline-flex w-full justify-center rounded-md bg-eden-forest px-5 py-3 text-sm font-semibold text-white hover:bg-eden-green"
								/>
							</article>
						);
					})}
				</div>
			</div>

			<aside class="space-y-4 lg:pt-10">
				<div class="rounded-lg bg-white p-5 shadow-sm ring-1 ring-eden-line">
					<p class="text-xs font-semibold uppercase tracking-[0.16em] text-eden-green">Why Eden</p>
					<p class="mt-3 font-serif text-2xl font-medium text-eden-navy">Care that connects the pieces.</p>
					<p class="mt-3 text-sm leading-6 text-slate-700">Aesthetics, wellness, recovery, and fitness in one coordinated clinic experience.</p>
				</div>
				<div class="rounded-lg bg-eden-forest p-5 text-white">
					<p class="text-xs font-semibold uppercase tracking-[0.16em] text-eden-sage">Trust signal</p>
					<p class="mt-3 font-serif text-3xl font-medium">5.0 on Google</p>
					<p class="mt-2 text-sm leading-6 text-white/75">Provider-guided care, clear next steps, and a premium Greenwood Village setting.</p>
				</div>
				<div class="grid grid-cols-2 gap-3">
					<figure class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-eden-line">
						<img src="/assets/eden-provider-dr-buford.webp" alt="Dr. Gregory A. Buford, Eden Health Club provider" class="aspect-[4/5] w-full object-cover" loading="lazy" />
						<figcaption class="p-3 text-xs font-semibold leading-5 text-eden-navy">Dr. Gregory A. Buford, MD</figcaption>
					</figure>
					<figure class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-eden-line">
						<img src="/assets/eden-provider-christina.webp" alt="Christina Matheus-Lozano, Eden Health Club provider" class="aspect-[4/5] w-full object-cover" loading="lazy" />
						<figcaption class="p-3 text-xs font-semibold leading-5 text-eden-navy">Christina Matheus-Lozano, DNP</figcaption>
					</figure>
				</div>
				<img src="/assets/eden-health-club-reception.webp" alt="Eden Health Club reception in Greenwood Village" class="aspect-[4/3] w-full rounded-lg object-cover" loading="lazy" />
			</aside>
		</section>
	</main>
</BaseLayout>
