---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getService, services, suburbs } from "../../data";
import BenefitsList from "../../components/content/BenefitsList.astro";
import CTAStrip from "../../components/content/CTAStrip.astro";
import DecisionSupport from "../../components/content/DecisionSupport.astro";
import FAQAccordion from "../../components/content/FAQAccordion.astro";
import Hero from "../../components/content/Hero.astro";
import HowItWorks from "../../components/content/HowItWorks.astro";
import LocalProximity from "../../components/content/LocalProximity.astro";
import LocalAnswerBlock from "../../components/content/LocalAnswerBlock.astro";
import MainSiteLink from "../../components/content/MainSiteLink.astro";
import MobileActionBar from "../../components/content/MobileActionBar.astro";
import MoneyPageLayer from "../../components/content/MoneyPageLayer.astro";
import PricingCard from "../../components/content/PricingCard.astro";
import PremiumConversionBlock from "../../components/content/PremiumConversionBlock.astro";
import PremiumHeader from "../../components/layout/PremiumHeader.astro";
import PremiumStickyConsult from "../../components/content/PremiumStickyConsult.astro";
import PriorityMoneyLinks from "../../components/content/PriorityMoneyLinks.astro";
import RelatedServices from "../../components/content/RelatedServices.astro";
import TreatmentSnapshot from "../../components/content/TreatmentSnapshot.astro";
import TrustBar from "../../components/content/TrustBar.astro";
import Breadcrumbs from "../../components/layout/Breadcrumbs.astro";
import Footer from "../../components/layout/Footer.astro";
import Header from "../../components/layout/Header.astro";
import { comboJsonLd, type BreadcrumbItem } from "../../lib/schema-org";
import { combinedFaqs } from "../../lib/local-faqs";
import { isIndexableCombo } from "../../lib/indexing";
import { comboMeta } from "../../lib/seo";
import { comboUrl, homeUrl, serviceHubUrl } from "../../lib/urls";

export async function getStaticPaths() {
	return services.flatMap((service) =>
		suburbs.map((suburb) => ({
			params: { service: service.slug, suburb: suburb.slug },
			props: { service, suburb },
		})),
	);
}

const { service, suburb } = Astro.props;
const seo = comboMeta(service, suburb);
const faqs = combinedFaqs(service, suburb);
const relatedServices = service.relatedServices
	.map((slug) => getService(slug))
	.filter((relatedService) => relatedService !== undefined);
const isPremiumMoneyPage = isIndexableCombo(service.slug, suburb.slug);
const wellnessPaidSlugs = ["male-trt", "medical-weight-loss", "peptide-therapy", "female-bhrt"];
const isWellnessPaidPage = isPremiumMoneyPage && wellnessPaidSlugs.includes(service.slug);
const breadcrumbItems: BreadcrumbItem[] = [
	{ label: "Home", href: homeUrl() },
	{ label: isWellnessPaidPage ? "Programs" : "Services", href: serviceHubUrl(service.slug) },
	{ label: service.name, href: serviceHubUrl(service.slug) },
	{ label: suburb.name, href: null },
];
const premiumHeroImages: Record<string, string> = {
	"male-trt": "/assets/mens-hormone-optimization.webp",
	"medical-weight-loss": "/assets/fitness-recovery.webp",
	"peptide-therapy": "/assets/mens-hormone-optimization.webp",
	"female-bhrt": "/assets/fitness-recovery.webp",
	"prf-hair-restoration": "/assets/prf-hair-restoration-female-provider-hero.jpg",
};
const preloadImages = isPremiumMoneyPage
	? [
			"/assets/eden-health-club-reception.webp",
			premiumHeroImages[service.slug] ?? "/assets/eden-health-club-office.webp",
			"/assets/eden-health-club-logo-white-transparent-tight.png",
		]
	: [];
---

<BaseLayout
	title={seo.title}
	description={seo.description}
	canonicalUrl={comboUrl(service.slug, suburb.slug)}
	jsonLd={comboJsonLd(service, suburb, breadcrumbItems)}
	noindex={!isPremiumMoneyPage}
	preloadImages={preloadImages}
>
	{isPremiumMoneyPage ? <PremiumHeader servicesHref="#details" servicesLabel={isWellnessPaidPage ? "Programs" : "Services"} /> : <Header />}
	<Breadcrumbs items={breadcrumbItems} />
	<main class="pb-20 md:pb-0">
		<Hero variant="combo" service={service} suburb={suburb} premium={isPremiumMoneyPage} />
		<LocalProximity suburb={suburb} />
		<TrustBar />
		{isPremiumMoneyPage && <PremiumConversionBlock service={service} suburb={suburb} />}
		{!isPremiumMoneyPage && (
			<CTAStrip
				serviceSlug={service.slug}
				suburbSlug={suburb.slug}
				variant="primary"
				ctaText={service.ctaText}
				consultRequired={service.consultRequired}
				serviceName={service.name}
			/>
		)}
		<LocalAnswerBlock service={service} suburb={suburb} />
		{isPremiumMoneyPage && <MoneyPageLayer service={service} suburb={suburb} />}
		<TreatmentSnapshot service={service} />
		<BenefitsList benefits={service.benefits} intro={service.whoItsFor} />
		{!isPremiumMoneyPage && <DecisionSupport service={service} suburb={suburb} />}
		<HowItWorks steps={service.howItWorks} />
		<div id="pricing">
			<PricingCard pricing={service.pricing} consultRequired={service.consultRequired} ctaText={service.ctaText} />
		</div>
		<FAQAccordion faqs={faqs} heading={`${service.name} questions from ${suburb.name} clients`} />
		{isPremiumMoneyPage && (
			<PriorityMoneyLinks
				currentPath={comboUrl(service.slug, suburb.slug).replace("https://landing.edenhealthclubs.com", "")}
				variant={isWellnessPaidPage ? "wellness" : "combo"}
			/>
		)}
		<RelatedServices services={relatedServices} suburbSlug={suburb.slug} heading={isWellnessPaidPage ? "Related wellness paths" : "Related services"} />
		<MainSiteLink service={service} label={isWellnessPaidPage ? "program" : "service"} />
		{isPremiumMoneyPage ? (
			<section class="bg-eden-forest px-6 py-12 text-white">
				<div class="mx-auto flex max-w-6xl flex-col gap-6 md:flex-row md:items-center md:justify-between">
					<div>
						<p class="text-sm font-semibold uppercase text-eden-sage">Ready when you are</p>
						<h2 class="mt-2 text-3xl font-semibold leading-tight">Start with Eden, then choose the right next step.</h2>
						<p class="mt-3 max-w-2xl text-sm leading-6 text-white/78">
							Share what you are considering. Eden will follow up about fit, timing, pricing context, and whether {service.name} is the right starting point.
						</p>
					</div>
					<a href="#lead-form" class="rounded-md bg-eden-sage px-6 py-3 text-center text-base font-semibold text-eden-forest">
						{service.ctaText}
					</a>
				</div>
			</section>
		) : (
			<CTAStrip
				serviceSlug={service.slug}
				suburbSlug={suburb.slug}
				variant="secondary"
				ctaText={service.ctaText}
				consultRequired={service.consultRequired}
				serviceName={service.name}
			/>
		)}
	</main>
	{isPremiumMoneyPage && <PremiumStickyConsult service={service} />}
	<MobileActionBar service={service} />
	<Footer variant={isWellnessPaidPage ? "wellness" : "default"} />
</BaseLayout>
