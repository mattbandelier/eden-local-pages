			<div class="absolute inset-y-0 right-0 hidden w-1/2 lg:block">
				<img src="/assets/eden-health-club-reception.webp" alt="" class="h-full w-full object-cover opacity-24" loading="lazy" width="1388" height="1000" />
				<div class="absolute inset-0 bg-gradient-to-r from-eden-forest via-eden-forest/78 to-eden-forest/20"></div>
			</div>
			<div class="relative mx-auto max-w-6xl">
				<div class="max-w-3xl">
					<p class="text-sm font-semibold uppercase text-eden-sage">How it works</p>
						<h2 class="mt-3 text-3xl font-semibold leading-tight sm:text-4xl">Start. Review. Plan. Follow.</h2>
					<p class="mt-4 text-base leading-8 text-white/78">
						Start with one visit, one price, and clinical review before choosing the peptide path that fits.
					</p>
				</div>
				<div class="relative mt-8 grid gap-4 md:grid-cols-4">
					{process.map((item, index) => (
						<div class="rounded-lg border border-white/15 bg-white/10 p-5 backdrop-blur">
