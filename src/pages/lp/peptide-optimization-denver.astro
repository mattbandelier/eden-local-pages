				<div class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
					<div>
						<p class="text-sm font-semibold uppercase text-eden-green">Why Eden</p>
						<h2 class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
							The advantage is what happens after the review.
						</h2>
						<p class="mt-4 text-base leading-8 text-slate-700">
							Online clinics can sell access. Single-service clinics can sell one modality. Eden can connect provider-guided wellness with recovery, training, InBody, labs, and a premium local facility.
						</p>
					</div>
					<div class="hidden overflow-hidden rounded-lg border border-eden-line bg-eden-paper shadow-sm md:block">
						<div class="grid grid-cols-[0.72fr_1fr_1fr] bg-eden-forest text-sm font-semibold text-white">
							<div class="p-4">Decision point</div>
							<div class="border-l border-white/10 p-4">Eden path</div>
							<div class="border-l border-white/10 p-4">Generic alternative</div>
						</div>
						{differentiators.map(([label, eden, other]) => (
							<div class="grid grid-cols-[0.72fr_1fr_1fr] border-t border-eden-line text-sm">
								<div class="bg-white p-4 font-semibold text-eden-navy">{label}</div>
								<div class="border-l border-eden-line p-4 leading-6 text-slate-700">{eden}</div>
								<div class="border-l border-eden-line p-4 leading-6 text-slate-600">{other}</div>
							</div>
						))}
					</div>
					<div class="grid gap-4 md:hidden">
						{differentiators.map(([label, eden, other]) => (
							<div class="rounded-lg border border-eden-line bg-eden-paper p-5">
								<p class="text-sm font-semibold uppercase text-eden-green">{label}</p>
								<div class="mt-4 rounded-md bg-white p-4">
									<p class="text-sm font-semibold text-eden-navy">Eden path</p>
									<p class="mt-2 text-sm leading-6 text-slate-700">{eden}</p>
								</div>
								<div class="mt-3 rounded-md border border-eden-line p-4">
									<p class="text-sm font-semibold text-eden-navy">Generic alternative</p>
									<p class="mt-2 text-sm leading-6 text-slate-600">{other}</p>
								</div>
							</div>
						))}
					</div>
				</div>
			</div>
