<script>
	const starterSticky = document.querySelector<HTMLElement>("[data-peptide-starter-sticky]");
	const updateStarterSticky = () => {
		if (!starterSticky) return;
		const shouldShow = window.scrollY > window.innerHeight * 0.55;
		starterSticky.classList.toggle("opacity-0", !shouldShow);
		starterSticky.classList.toggle("translate-y-3", !shouldShow);
		starterSticky.classList.toggle("pointer-events-none", !shouldShow);
	};

	updateStarterSticky();
	window.addEventListener("scroll", updateStarterSticky, { passive: true });
	window.addEventListener("resize", updateStarterSticky);
</script>
