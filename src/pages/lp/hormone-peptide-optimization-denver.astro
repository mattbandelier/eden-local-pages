---
import LeadForm from "../../components/content/LeadForm.astro";
import Footer from "../../components/layout/Footer.astro";
import PremiumHeader from "../../components/layout/PremiumHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { canonicalUrl, homeUrl } from "../../lib/urls";
import type { JsonLd } from "../../lib/schema-org";

const canonical = canonicalUrl("/lp/hormone-peptide-optimization-denver");
const title = "$299 Longevity Starter Denver | Hormones, Peptides, Biomarkers | Eden";
const description =
	"Start with Eden's $299 Longevity Optimization Starter in Greenwood Village: private consult, lab or biomarker review, and clinician-guided wellness planning when appropriate.";

const proofPoints = [
	{
		kicker: "$299 start",
		title: "Consult + baseline review",
		body: "A concrete first step before choosing any protocol.",
	},
	{
		kicker: "Clinician-guided",
		title: "Eligibility first",
		body: "Goals, history, labs, and fit come before recommendations.",
	},
	{
		kicker: "Inside Eden",
		title: "Premium club setting",
		body: "Wellness, recovery, fitness, and aesthetics under one roof.",
	},
];

const searchMatches = [
	"Peptide Therapy Denver",
	"Peptide Consult Denver",
	"Hormone Specialist Denver",
	"TRT Consult Denver",
	"Medical Weight Loss Denver",
	"Longevity Clinic Denver",
];

const offerIncludes = [
	{
		title: "Private longevity consultation",
		body: "Review your goals, health history, current routines, and what you want to improve before deciding on the right next step.",
	},
	{
		title: "Lab or biomarker review",
		body: "Use available data, and determine what else may be needed, so the conversation is grounded in context instead of guesswork.",
	},
	{
		title: "Hormone + peptide pathway discussion",
		body: "Discuss hormone optimization, peptide therapy, medical weight management, recovery, and wellness support when clinically appropriate.",
	},
	{
		title: "First-month wellness credit",
		body: "If a provider determines a protocol is appropriate, a first-month wellness protocol credit can be applied to the next step.",
	},
];

const lanes = [
	{
		label: "Hormone optimization",
		body: "For people comparing hormone specialists, HRT consults, labs, and provider-guided wellness planning near DTC.",
	},
	{
		label: "Peptide therapy",
		body: "For people curious about peptide options who want screening, education, and a safer clinical starting point.",
	},
	{
		label: "Medical weight management",
		body: "For people exploring provider-guided metabolic support, body-composition context, and follow-up inside a real facility.",
	},
	{
		label: "Longevity club",
		body: "For adults who want biomarkers, recovery, fitness, aesthetics, and wellness support connected in one premium environment.",
	},
];

const differentiators = [
	["First step", "$299 starter visit with consult, lab or biomarker review, and eligibility discussion", "A menu of protocols before anyone understands fit"],
	["Environment", "Greenwood Village health club with recovery, fitness, aesthetics, and wellness in one location", "A single-service clinic or remote-only program"],
	["Clinical path", "Provider review determines whether hormones, peptides, weight management, or another path makes sense", "Medication-first messaging that can skip the why"],
	["Follow-through", "Eden One and Elevate can connect ongoing care, credits, training, recovery, bloodwork rhythm, and support", "A one-off visit with no day-to-day system"],
];

const process = [
	{
		step: "Start",
		body: "Book the $299 starter visit and tell Eden what you want to improve.",
	},
	{
		step: "Review",
		body: "Discuss goals, history, labs or biomarkers, body-composition context, and eligibility.",
	},
	{
		step: "Plan",
		body: "Compare the paths that may fit: hormones, peptides, medical weight management, recovery, training, or membership.",
	},
	{
		step: "Follow",
		body: "Move into the right next step with clear pricing, timing, and follow-up support.",
	},
];

const localSignals = [
	{
		area: "Greenwood Village",
		body: "Eden's home base at 5990 S University Blvd for clients who want in-person longevity care close to home.",
	},
	{
		area: "Denver Tech Center",
		body: "Convenient for executives, founders, and professionals comparing premium wellness options near work.",
	},
	{
		area: "Cherry Hills Village",
		body: "A polished local option for clients comparing premium hormone, peptide, recovery, and wellness care.",
	},
	{
		area: "Centennial, Englewood, Lone Tree, and Highlands Ranch",
		body: "Built for the south-metro buyer who wants a high-trust alternative to scattered single-service appointments.",
	},
];

const faqs = [
	{
		question: "What is the $299 Longevity Optimization Starter?",
		answer:
			"It is a private first visit designed for people exploring longevity, hormone optimization, peptides, medical weight management, recovery, and wellness planning. It includes a consultation, lab or biomarker review when appropriate, and a first-month wellness protocol credit if a provider determines a next step is clinically appropriate.",
	},
	{
		question: "Does the $299 starter include peptides or hormone treatment?",
		answer:
			"No. The starter visit does not guarantee medication, peptide therapy, hormone therapy, GLP-1 support, or any specific protocol. Eligibility and recommendations are determined by provider review.",
	},
	{
		question: "Why start with labs or biomarkers?",
		answer:
			"Hormones, peptides, medical weight management, and wellness protocols should be matched to the person. Labs, biomarkers, health history, goals, and provider review help Eden avoid guesswork.",
	},
	{
		question: "What happens after the starter visit?",
		answer:
			"If an ongoing plan makes sense, Eden can help you compare options such as Eden One, Elevate, member pricing, monthly credits, bloodwork rhythm, injection support, training, recovery, or other wellness support.",
	},
	{
		question: "Is Eden an online peptide clinic?",
		answer:
			"No. Eden is an in-person health club and medical wellness environment in Greenwood Village. The starter visit is built around review, fit, and follow-through, not remote product shopping.",
	},
	{
		question: "Where is Eden located?",
		answer:
			"Eden Health Club is located at 5990 S University Blvd in Greenwood Village, close to Denver Tech Center, Cherry Hills Village, Centennial, Englewood, Littleton, Lone Tree, Highlands Ranch, and South Denver.",
	},
];

const jsonLd: JsonLd[] = [
	{
		"@context": "https://schema.org",
		"@type": "MedicalBusiness",
		"@id": `${canonical}#medical-business`,
		name: "Eden Health Club",
		url: canonical,
		telephone: "+17206057678",
		address: {
			"@type": "PostalAddress",
			streetAddress: "5990 S University Blvd",
			addressLocality: "Greenwood Village",
			addressRegion: "CO",
			postalCode: "80121",
			addressCountry: "US",
		},
		geo: {
			"@type": "GeoCoordinates",
			latitude: 39.6088,
			longitude: -104.9583,
		},
		priceRange: "$$",
		medicalSpecialty: ["FunctionalMedicine", "SportsMedicine"],
		areaServed: [
			{ "@type": "City", name: "Denver", addressRegion: "CO" },
			{ "@type": "City", name: "Greenwood Village", addressRegion: "CO" },
			{ "@type": "City", name: "Centennial", addressRegion: "CO" },
			{ "@type": "City", name: "Littleton", addressRegion: "CO" },
		],
		sameAs: [
			"https://edenhealthclubs.com/",
			"https://www.facebook.com/edenhealthclubs",
			"https://www.instagram.com/edenhealthclubs",
			"https://www.tiktok.com/@edenhealthclubs",
		],
	},
	{
		"@context": "https://schema.org",
		"@type": "Service",
		"@id": `${canonical}#service`,
		name: "$299 Longevity Optimization Starter",
		serviceType: "Longevity consultation and wellness planning",
		url: canonical,
		description,
		offers: {
			"@type": "Offer",
			price: "299",
			priceCurrency: "USD",
			availability: "https://schema.org/InStock",
		},
		provider: {
			"@id": `${canonical}#medical-business`,
			"@type": "MedicalBusiness",
			name: "Eden Health Club",
		},
		areaServed:
			"Denver, Greenwood Village, Denver Tech Center, Cherry Hills Village, Centennial, Englewood, Littleton, Lone Tree, Highlands Ranch, and South Denver",
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		"@id": `${canonical}#faq`,
		mainEntity: faqs.map((faq) => ({
			"@type": "Question",
			name: faq.question,
			acceptedAnswer: {
				"@type": "Answer",
				text: faq.answer,
			},
		})),
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{ "@type": "ListItem", position: 1, name: "Home", item: homeUrl() },
			{ "@type": "ListItem", position: 2, name: "Longevity Optimization Starter", item: canonical },
		],
	},
];
---

<BaseLayout title={title} description={description} canonicalUrl={canonical} jsonLd={jsonLd} noindex={true}>
	<PremiumHeader servicesHref="#offer" pricingHref="#lead-form" contactHref="#lead-form" ctaLabel="$299 Starter" />
	<main class="bg-eden-paper">
		<section class="relative overflow-hidden bg-eden-forest text-white">
			<div class="absolute inset-0">
				<img src="/assets/eden-health-club-reception.webp" alt="" class="h-full w-full object-cover opacity-30" loading="eager" />
				<video
					class="absolute inset-0 hidden h-full w-full object-cover opacity-28 md:block"
					autoplay
					muted
					loop
					playsinline
					preload="none"
					poster="/assets/eden-health-club-reception.webp"
					aria-hidden="true"
				>
					<source src="https://edenhealthclubs.com/wp-content/uploads/2025/07/edenhealth-hero-video.mp4" type="video/mp4" />
				</video>
				<div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(28,45,38,0.98),rgba(25,79,57,0.9)_48%,rgba(25,79,57,0.48))]"></div>
			</div>
			<div class="relative mx-auto grid min-h-[calc(100vh-64px)] max-w-6xl gap-10 px-6 py-12 sm:py-16 lg:grid-cols-[1.02fr_0.98fr] lg:items-center">
				<div>
					<img
						src="/assets/eden-health-club-logo-white-transparent-tight.png"
						alt="Eden Health Club"
						class="mb-8 h-auto w-36 sm:w-44"
						loading="eager"
					/>
					<p class="text-sm font-semibold uppercase tracking-normal text-eden-sage">Premium longevity care in Greenwood Village</p>
					<h1 class="mt-4 max-w-3xl text-4xl font-semibold leading-tight sm:text-5xl lg:text-6xl">
						Start your hormone, peptide, and longevity plan for $299.
					</h1>
					<p class="mt-5 max-w-2xl text-base leading-8 text-white/86 sm:text-lg">
						Begin with a private consultation, baseline lab or biomarker review, and a first-month wellness protocol credit if clinically appropriate.
					</p>
					<div class="mt-8 flex flex-col gap-3 sm:flex-row">
						<a href="#lead-form" class="rounded-md bg-eden-sage px-6 py-3 text-center text-base font-semibold text-eden-forest shadow-sm">
							Book my $299 starter visit
						</a>
						<a href="tel:+17206057678" data-phone-link class="rounded-md border border-white/35 px-6 py-3 text-center text-base font-semibold text-white hover:bg-white/10">
							Call 720-605-7678
						</a>
					</div>
					<p class="mt-5 max-w-2xl text-xs leading-6 text-white/62">
						Eligibility, labs, therapies, and protocol recommendations are determined by provider review. Results vary. Not all guests will qualify for peptide therapy, hormone therapy, GLP-1 support, or any specific protocol.
					</p>
					<div class="mt-6 max-w-3xl">
						<p class="text-xs font-semibold uppercase text-eden-sage">Built for high-intent Denver searches</p>
						<div class="mt-3 flex flex-wrap gap-2">
							{searchMatches.map((term) => (
								<span class="rounded-full border border-white/15 bg-white/10 px-3 py-2 text-xs font-semibold text-white">{term}</span>
							))}
						</div>
					</div>
					<div class="mt-8 grid gap-3 text-sm text-white/88 sm:grid-cols-3">
						{proofPoints.map((point) => (
							<div class="rounded-lg border border-white/15 bg-white/8 p-4 backdrop-blur">
								<p class="text-xs font-semibold uppercase text-eden-sage">{point.kicker}</p>
								<p class="mt-2 text-lg font-semibold text-white">{point.title}</p>
								<p class="mt-2 leading-6 text-white/72">{point.body}</p>
							</div>
						))}
					</div>
				</div>
				<div class="relative">
					<div class="overflow-hidden rounded-lg border border-white/15 bg-white/10 p-3 shadow-2xl backdrop-blur">
						<div class="grid gap-3 sm:grid-cols-[0.88fr_1.12fr]">
							<div class="overflow-hidden rounded-md">
								<img src="/assets/mens-hormone-optimization.webp" alt="" class="h-full min-h-72 w-full object-cover object-center" loading="eager" />
							</div>
							<div class="grid gap-3">
								<div class="overflow-hidden rounded-md">
									<img src="/assets/fitness-recovery.webp" alt="" class="h-40 w-full object-cover sm:h-full" loading="lazy" />
								</div>
								<div class="grid grid-cols-2 gap-3">
									<div class="rounded-md bg-white p-4 text-eden-navy">
										<p class="text-xs font-semibold uppercase text-eden-green">Offer</p>
										<p class="mt-2 text-lg font-semibold">$299 starter visit.</p>
									</div>
									<div class="rounded-md bg-eden-sage p-4 text-eden-forest">
										<p class="text-xs font-semibold uppercase">Fit first</p>
										<p class="mt-2 text-lg font-semibold">Protocols only if appropriate.</p>
									</div>
								</div>
							</div>
						</div>
						<div class="mt-3 rounded-md border border-eden-line bg-white p-5 text-eden-navy shadow-sm">
							<p class="text-sm font-semibold uppercase text-eden-green">Data before protocols</p>
							<p class="mt-2 text-xl font-semibold leading-tight">
								A premium starting point for adults comparing hormones, peptides, medical weight management, and longevity care near Denver.
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section id="offer" class="bg-white px-6 py-12 sm:py-16">
			<div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
				<div>
					<p class="text-sm font-semibold uppercase text-eden-green">$299 Longevity Optimization Starter</p>
					<h2 class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
						A smarter first step before choosing a protocol.
					</h2>
					<p class="mt-4 text-base leading-8 text-slate-700">
						Peptides, hormones, GLP-1 support, and longevity protocols should not start with a product. They should start with goals, history, labs when appropriate, and provider review.
					</p>
				</div>
				<div class="grid gap-4 sm:grid-cols-2">
					{offerIncludes.map((item) => (
						<div class="rounded-lg border border-eden-line bg-eden-paper p-5 shadow-sm">
							<h3 class="text-xl font-semibold text-eden-navy">{item.title}</h3>
							<p class="mt-3 text-sm leading-6 text-slate-700">{item.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="px-6 py-12 sm:py-16">
			<div class="mx-auto max-w-6xl">
				<div class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
					<div>
						<p class="text-sm font-semibold uppercase text-eden-green">Search intent Eden should own</p>
						<h2 class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
							One page for the highest-value longevity demand lanes.
						</h2>
					</div>
					<p class="text-base leading-8 text-slate-700">
						This paid page is built for the searches Eden is already proving it can convert: hormone specialists, peptide therapy, GLP-1 support, medical weight management, TRT consults, and longevity clinic demand around South Denver.
					</p>
				</div>
				<div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
					{lanes.map((item) => (
						<div class="rounded-lg border border-eden-line bg-white p-5 shadow-sm">
							<p class="text-xs font-semibold uppercase text-eden-green">Intent lane</p>
							<h3 class="mt-2 text-xl font-semibold text-eden-navy">{item.label}</h3>
							<p class="mt-3 text-sm leading-6 text-slate-700">{item.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="bg-white px-6 py-12 sm:py-16">
			<div class="mx-auto max-w-6xl">
				<div class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
					<div>
						<p class="text-sm font-semibold uppercase text-eden-green">Why Eden</p>
						<h2 class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
							The advantage is what happens after the review.
						</h2>
						<p class="mt-4 text-base leading-8 text-slate-700">
							Online clinics can sell access. Single-service clinics can sell one modality. Eden can connect provider-guided wellness with recovery, training, InBody, aesthetics, and a premium local facility.
						</p>
					</div>
					<div class="hidden overflow-hidden rounded-lg border border-eden-line bg-eden-paper shadow-sm md:block">
						<div class="grid grid-cols-[0.72fr_1fr_1fr] bg-eden-forest text-sm font-semibold text-white">
							<div class="p-4">Decision point</div>
							<div class="border-l border-white/10 p-4">Eden path</div>
							<div class="border-l border-white/10 p-4">Generic alternative</div>
						</div>
						{differentiators.map(([label, eden, other]) => (
							<div class="grid grid-cols-[0.72fr_1fr_1fr] border-t border-eden-line text-sm">
								<div class="bg-white p-4 font-semibold text-eden-navy">{label}</div>
								<div class="border-l border-eden-line p-4 leading-6 text-slate-700">{eden}</div>
								<div class="border-l border-eden-line p-4 leading-6 text-slate-600">{other}</div>
							</div>
						))}
					</div>
					<div class="grid gap-4 md:hidden">
						{differentiators.map(([label, eden, other]) => (
							<div class="rounded-lg border border-eden-line bg-eden-paper p-5">
								<p class="text-sm font-semibold uppercase text-eden-green">{label}</p>
								<div class="mt-4 rounded-md bg-white p-4">
									<p class="text-sm font-semibold text-eden-navy">Eden path</p>
									<p class="mt-2 text-sm leading-6 text-slate-700">{eden}</p>
								</div>
								<div class="mt-3 rounded-md border border-eden-line p-4">
									<p class="text-sm font-semibold text-eden-navy">Generic alternative</p>
									<p class="mt-2 text-sm leading-6 text-slate-600">{other}</p>
								</div>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<section class="relative overflow-hidden bg-eden-forest px-6 py-12 text-white sm:py-16">
			<div class="absolute inset-y-0 right-0 hidden w-1/2 lg:block">
				<img src="/assets/fitness-strength-class.avif" alt="" class="h-full w-full object-cover opacity-24" loading="lazy" />
				<div class="absolute inset-0 bg-gradient-to-r from-eden-forest via-eden-forest/78 to-eden-forest/20"></div>
			</div>
			<div class="relative mx-auto max-w-6xl">
				<div class="max-w-3xl">
					<p class="text-sm font-semibold uppercase text-eden-sage">How it works</p>
					<h2 class="mt-3 text-3xl font-semibold leading-tight sm:text-4xl">Start. Review. Plan. Follow.</h2>
					<p class="mt-4 text-base leading-8 text-white/78">
						The offer is intentionally simple: a paid, serious first step that filters out low-intent shoppers and gives qualified guests a clear path into Eden's ongoing wellness system.
					</p>
				</div>
				<div class="relative mt-8 grid gap-4 md:grid-cols-4">
					{process.map((item, index) => (
						<div class="rounded-lg border border-white/15 bg-white/10 p-5 backdrop-blur">
							<div class="flex h-9 w-9 items-center justify-center rounded-full bg-eden-sage text-sm font-semibold text-eden-forest">{index + 1}</div>
							<h3 class="mt-4 text-xl font-semibold">{item.step}</h3>
							<p class="mt-3 text-sm leading-6 text-white/74">{item.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="px-6 py-12 sm:py-16">
			<div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[0.92fr_1.08fr] lg:items-start">
				<div>
					<p class="text-sm font-semibold uppercase text-eden-green">Local premium fit</p>
					<h2 class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
						Built for Greenwood Village, DTC, Cherry Hills, and the south Denver wellness buyer.
					</h2>
					<p class="mt-4 text-base leading-8 text-slate-700">
						Eden Health Club is located at 5990 S University Blvd in Greenwood Village. This page is built for paid search traffic that wants an in-person alternative to remote peptide access, scattered clinics, or generic wellness programs.
					</p>
					<div class="mt-6 grid gap-3 text-sm">
						{localSignals.map((item) => (
							<div class="rounded-lg border border-eden-line bg-white p-4">
								<p class="font-semibold text-eden-navy">{item.area}</p>
								<p class="mt-1 leading-6 text-slate-700">{item.body}</p>
							</div>
						))}
					</div>
				</div>
				<LeadForm
					serviceSlug="longevity-optimization-starter-299"
					suburbSlug="greenwood-village"
					heading="Book the $299 starter visit"
					subheading="Tell Eden what you want to explore. The team will follow up about fit, labs or biomarker review, and next steps."
					submitText="Request my $299 starter visit"
				/>
			</div>
		</section>

		<section class="bg-white px-6 py-12 sm:py-16" aria-labelledby="longevity-starter-faq-heading">
			<div class="mx-auto max-w-4xl">
				<p class="text-sm font-semibold uppercase text-eden-green">FAQ</p>
				<h2 id="longevity-starter-faq-heading" class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
					Questions before booking.
				</h2>
				<div class="mt-8 divide-y divide-eden-line rounded-lg border border-eden-line bg-eden-paper">
					{faqs.map((faq) => (
						<details class="group p-5">
							<summary class="cursor-pointer list-none text-lg font-semibold text-eden-navy">
								{faq.question}
							</summary>
							<p class="mt-3 text-sm leading-7 text-slate-700">{faq.answer}</p>
						</details>
					))}
				</div>
			</div>
		</section>

		<section class="bg-eden-forest px-6 py-10 text-white">
			<div class="mx-auto flex max-w-6xl flex-col gap-5 md:flex-row md:items-center md:justify-between">
				<div>
					<p class="text-sm font-semibold uppercase text-eden-sage">$299 Longevity Optimization Starter</p>
