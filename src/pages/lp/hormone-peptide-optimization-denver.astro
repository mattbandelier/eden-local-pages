---
import LeadForm from "../../components/content/LeadForm.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { canonicalUrl } from "../../lib/urls";
import type { JsonLd } from "../../lib/schema-org";

const canonical = canonicalUrl("/lp/hormone-peptide-optimization-denver");
const title = "$299 Longevity Baseline Starter | Eden Health Club Greenwood Village";
const description =
	"Claim Eden's $299 Longevity Baseline Starter in Greenwood Village: biomarkers, InBody body composition, clinician-guided plan, and a clear next step.";

const planSteps = [
	{
		step: "1",
		title: "Measure",
		body: "Start with biomarkers and an InBody body-composition baseline so the plan is built from real inputs.",
	},
	{
		step: "2",
		title: "Map",
		body: "Review your goals with Eden's clinician-guided team and choose the most logical starting path.",
	},
	{
		step: "3",
		title: "Move",
		body: "Turn the plan into action with Eden membership, recovery, training, and optimization support when appropriate.",
	},
];

const valueStack = [
	"Biomarker review or lab direction",
	"InBody body-composition baseline",
	"Clinician-guided optimization plan",
	"Recovery and training pathway",
	"Membership options with ongoing support",
];

const proofTiles = [
	{
		label: "Open now",
		value: "South Denver / DTC",
	},
	{
		label: "Eden ecosystem",
		value: "127,000+ members served",
	},
	{
		label: "One facility",
		value: "Medical + fitness + recovery",
	},
];

const jsonLd: JsonLd[] = [
	{
		"@context": "https://schema.org",
		"@type": "MedicalBusiness",
		"@id": `${canonical}#business`,
		name: "Eden Health Club",
		url: canonical,
		telephone: "+17206057678",
		address: {
			"@type": "PostalAddress",
			streetAddress: "5990 S University Blvd",
			addressLocality: "Greenwood Village",
			addressRegion: "CO",
			postalCode: "80121",
			addressCountry: "US",
		},
		priceRange: "$$",
		areaServed: "Greenwood Village, Denver Tech Center, Cherry Hills Village, Centennial, Littleton, Englewood, and South Denver",
	},
	{
		"@context": "https://schema.org",
		"@type": "Service",
		"@id": `${canonical}#offer`,
		name: "$299 Longevity Baseline Starter",
		serviceType: "Longevity baseline visit and optimization planning",
		url: canonical,
		description,
		provider: { "@id": `${canonical}#business` },
		offers: {
			"@type": "Offer",
			price: "299",
			priceCurrency: "USD",
			availability: "https://schema.org/InStock",
		},
	},
];
---

<BaseLayout
	title={title}
	description={description}
	canonicalUrl={canonical}
	jsonLd={jsonLd}
	noindex={true}
	preloadImages={["/assets/eden-health-club-reception.webp", "/assets/eden-health-club-logo-white-transparent-tight.png"]}
>
	<main class="min-h-screen overflow-hidden bg-[#061710] pb-28 text-white sm:pb-0">
		<section class="relative min-h-[100svh] overflow-hidden px-5 py-5 sm:px-8 lg:px-12">
			<div class="absolute inset-0">
				<img src="/assets/eden-health-club-reception.webp" alt="" class="h-full w-full object-cover opacity-34" loading="eager" fetchpriority="high" decoding="async" width="1388" height="1000" />
				<div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(3,18,12,0.98)_0%,rgba(3,18,12,0.92)_38%,rgba(3,18,12,0.62)_67%,rgba(3,18,12,0.35)_100%)]"></div>
				<div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-[#061710] to-transparent"></div>
			</div>

			<div class="relative mx-auto grid min-h-[calc(100svh-40px)] max-w-7xl items-center gap-8 lg:grid-cols-[1.03fr_0.97fr]">
				<div class="max-w-2xl">
					<img src="/assets/eden-health-club-logo-white-transparent-tight.png" alt="Eden Health Club" class="h-20 w-auto sm:h-24" loading="eager" fetchpriority="high" decoding="async" width="744" height="447" />
					<p class="mt-6 text-sm font-black uppercase tracking-normal text-[#d8bf78] sm:text-base">Open now in South Denver / DTC</p>
					<h1 class="mt-3 text-[3.7rem] font-black uppercase leading-[0.86] tracking-normal text-white sm:text-7xl lg:text-8xl">
						$299<br />Longevity Baseline
					</h1>
					<p class="mt-7 max-w-xl text-2xl font-black leading-tight text-white sm:text-3xl">
						Clinician-guided optimization, built from biomarkers and body composition.
					</p>

					<div class="mt-5 grid max-w-xl grid-cols-2 gap-3">
						{planSteps.map((item) => (
							<div class="border border-white/30 bg-white/8 p-4 backdrop-blur-sm">
								<p class="text-lg font-black uppercase tracking-normal text-white">{item.title}</p>
								<p class="mt-1 text-sm font-semibold leading-snug text-white/78">{item.title === "Measure" ? "Biomarkers + InBody" : item.title === "Map" ? "Clinician-guided plan" : "Membership + recovery"}</p>
							</div>
						))}
						<div class="border border-white/30 bg-white/8 p-4 backdrop-blur-sm">
							<p class="text-lg font-black uppercase tracking-normal text-white">Support</p>
							<p class="mt-1 text-sm font-semibold leading-snug text-white/78">Training + next steps</p>
						</div>
					</div>

					<div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center">
						<a href="#lead-form" class="inline-flex items-center justify-center rounded-full bg-[#f4eedf] px-7 py-4 text-base font-black text-[#063322] transition hover:bg-white">
							Claim My Baseline Slot
						</a>
						<p class="text-sm font-bold leading-5 text-white/72">Tap and our team will text or call to schedule.</p>
					</div>
				</div>

				<div class="relative hidden min-h-[650px] lg:block">
					<div class="absolute right-0 top-12 h-[560px] w-[82%] overflow-hidden border border-white/14 bg-white/8">
						<img src="/assets/mens-hormone-optimization.webp" alt="" class="h-full w-full object-cover object-center" loading="eager" fetchpriority="high" decoding="async" width="1024" height="1536" />
						<div class="absolute inset-0 bg-gradient-to-t from-[#061710]/55 via-transparent to-transparent"></div>
					</div>
					<div class="absolute bottom-16 left-0 w-[56%] border border-[#d8bf78]/70 bg-[#061710]/82 p-5 shadow-2xl backdrop-blur-md">
						<p class="text-xs font-black uppercase tracking-normal text-[#d8bf78]">Eden Health Ecosystem</p>
						<p class="mt-2 text-3xl font-black leading-none text-white">127,000+ members served</p>
						<p class="mt-3 text-sm font-semibold leading-5 text-white/76">A real facility for medical wellness, recovery, body composition, and follow-through.</p>
					</div>
				</div>
			</div>
		</section>

		<section class="relative bg-[#f6f0e4] px-5 py-10 text-[#082317] sm:px-8 sm:py-14 lg:px-12">
			<div class="mx-auto grid max-w-7xl gap-5 md:grid-cols-3">
				{proofTiles.map((tile) => (
					<div class="border border-[#082317]/14 bg-white p-5">
						<p class="text-xs font-black uppercase tracking-normal text-[#8b6d2c]">{tile.label}</p>
						<p class="mt-2 text-2xl font-black leading-tight">{tile.value}</p>
					</div>
				))}
			</div>
		</section>

		<section class="bg-[#f6f0e4] px-5 py-10 text-[#082317] sm:px-8 sm:py-16 lg:px-12">
			<div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.9fr_1.1fr]">
				<div>
					<p class="text-sm font-black uppercase tracking-normal text-[#8b6d2c]">The Eden 3-Step Baseline Plan</p>
					<h2 class="mt-3 text-4xl font-black leading-none tracking-normal sm:text-5xl">A smarter first step before you choose a program.</h2>
					<p class="mt-5 text-lg font-semibold leading-7 text-[#294237]">
						Most people are guessing between labs, peptides, hormones, training, recovery, and membership. Eden starts with a baseline, then routes you to the next best step.
					</p>
				</div>

				<div class="grid gap-4">
					{planSteps.map((item) => (
						<div class="grid gap-4 border border-[#082317]/14 bg-white p-5 sm:grid-cols-[72px_1fr]">
							<div class="flex h-14 w-14 items-center justify-center rounded-full bg-[#082317] text-2xl font-black text-[#f4eedf]">{item.step}</div>
							<div>
								<h3 class="text-2xl font-black">{item.title}</h3>
								<p class="mt-2 text-base font-semibold leading-6 text-[#345145]">{item.body}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="bg-[#061710] px-5 py-10 sm:px-8 sm:py-16 lg:px-12">
			<div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
				<div>
					<p class="text-sm font-black uppercase tracking-normal text-[#d8bf78]">$299 full-price starter</p>
					<h2 class="mt-3 text-4xl font-black leading-none tracking-normal sm:text-5xl">What your Baseline Starter includes.</h2>
					<div class="mt-7 grid gap-3 sm:grid-cols-2">
						{valueStack.map((item) => (
							<div class="border border-white/16 bg-white/8 p-4">
								<p class="text-lg font-black leading-tight text-white">{item}</p>
							</div>
						))}
					</div>
					<p class="mt-5 max-w-2xl text-sm font-semibold leading-6 text-white/70">
						The starter visit does not guarantee treatment, medication, or a specific protocol. Recommendations depend on goals, history, labs or biomarkers, and clinician review.
					</p>
				</div>

				<div class="overflow-hidden border border-white/14 bg-white/8">
					<img src="/assets/fitness-recovery.webp" alt="" class="h-80 w-full object-cover" loading="lazy" />
					<div class="p-5">
						<p class="text-xs font-black uppercase tracking-normal text-[#d8bf78]">Why Eden is different</p>
						<p class="mt-2 text-2xl font-black leading-tight">Medical wellness inside a working fitness and recovery facility.</p>
						<p class="mt-3 text-base font-semibold leading-6 text-white/72">That means the plan can connect to real daily execution, not just a one-time consult.</p>
					</div>
				</div>
			</div>
		</section>

		<section class="bg-[#f6f0e4] px-5 py-10 text-[#082317] sm:px-8 sm:py-16 lg:px-12">
			<div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[0.92fr_1.08fr] lg:items-start">
				<div>
					<p class="text-sm font-black uppercase tracking-normal text-[#8b6d2c]">Claim your baseline</p>
					<h2 class="mt-3 text-4xl font-black leading-none tracking-normal sm:text-5xl">$299 Longevity Baseline Starter</h2>
					<p class="mt-5 text-lg font-semibold leading-7 text-[#294237]">
						Leave your info and Eden will text or call to schedule the right visit time.
					</p>
				</div>
				<LeadForm
					serviceSlug="longevity-baseline-starter-299"
					suburbSlug="greenwood-village"
					heading="$299 Longevity Baseline Starter"
					subheading="Biomarkers, InBody body composition, and a clinician-guided plan in Greenwood Village."
					submitText="Claim My Baseline Slot"
					compact={true}
					underButtonText="Tap and our team will text or call to schedule."
					hiddenMessage="$299 Longevity Baseline Starter claimed: biomarkers, InBody body composition, clinician-guided plan, and Eden membership/recovery/training next-step discussion."
				/>
			</div>
		</section>
	</main>

	<div data-sticky-claim class="pointer-events-none fixed inset-x-0 bottom-0 z-50 translate-y-6 border-t border-white/12 bg-[#061710]/96 p-3 text-white opacity-0 shadow-2xl backdrop-blur transition duration-300 sm:hidden">
		<div class="mx-auto flex max-w-md items-center gap-3">
			<div class="min-w-0 flex-1">
				<p class="text-xs font-black uppercase tracking-normal text-[#d8bf78]">$299 Baseline Starter</p>
				<p class="truncate text-sm font-bold text-white/78">Biomarkers + InBody + plan</p>
			</div>
			<a href="#lead-form" class="shrink-0 rounded-full bg-[#f4eedf] px-4 py-3 text-sm font-black text-[#063322]">Claim Slot</a>
		</div>
	</div>

	<script>
		const stickyClaim = document.querySelector<HTMLElement>("[data-sticky-claim]");
		const syncStickyClaim = () => {
			if (!stickyClaim) return;
			const shouldShow = window.scrollY > window.innerHeight * 0.65;
			stickyClaim.classList.toggle("pointer-events-none", !shouldShow);
			stickyClaim.classList.toggle("translate-y-6", !shouldShow);
			stickyClaim.classList.toggle("opacity-0", !shouldShow);
		};
		syncStickyClaim();
		window.addEventListener("scroll", syncStickyClaim, { passive: true });
		window.addEventListener("resize", syncStickyClaim);
	</script>
</BaseLayout>
