---
import LeadForm from "../components/content/LeadForm.astro";
import Footer from "../components/layout/Footer.astro";
import PremiumHeader from "../components/layout/PremiumHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import type { JsonLd } from "../lib/schema-org";
import { canonicalUrl, homeUrl } from "../lib/urls";

const canonical = canonicalUrl("/longevity-baseline-visit");
const title = "Longevity Baseline Visit in Greenwood Village | Eden";
const description =
	"Start with a clinician-guided longevity baseline at Eden Health Club: body composition, recovery, fitness, and wellness next steps in Greenwood Village.";

const proof = [
	"Body composition baseline",
	"Provider-guided next steps",
	"Recovery and training connection",
	"Open now in Greenwood Village",
];

const baselineIncludes = [
	{
		title: "Body composition baseline",
		body: "Use InBody-style body composition context to move beyond the scale and understand where your starting point is today.",
	},
	{
		title: "Goals and lifestyle review",
		body: "Talk through energy, recovery, training, body composition, wellness goals, and what you have already tried.",
	},
	{
		title: "Clinician-guided direction",
		body: "Review the right next step with a local Eden team that can connect wellness, fitness, recovery, and medical context when appropriate.",
	},
	{
		title: "Clear next-step plan",
		body: "Leave with a practical route for what to do first, whether that is training, recovery, labs, wellness support, or a membership path.",
	},
];

const blueprint = [
	{
		step: "Test",
		body: "Start with your goals, intake, body composition, and lab discussion when clinically appropriate.",
	},
	{
		step: "Treat",
		body: "Use provider review to decide which wellness or medical path actually fits instead of guessing.",
	},
	{
		step: "Train",
		body: "Connect the plan to strength, consistency, and body composition inside a real health club.",
	},
	{
		step: "Track",
		body: "Use follow-up, InBody-style tracking, and provider context to see what is changing over time.",
	},
	{
		step: "Optimize",
		body: "Adjust the plan around goals, safety, recovery, performance, and long-term consistency.",
	},
];

const differentiators = [
	{
		label: "Not just a lab report",
		text: "A baseline matters only if someone helps you turn it into the next decision.",
	},
	{
		label: "Not just a gym assessment",
		text: "Training, recovery, body composition, and wellness support can live inside one plan.",
	},
	{
		label: "Not a treat-and-forget clinic",
		text: "Eden is built for ongoing relationships, not one disconnected appointment.",
	},
];

const audience = [
	"Adults 35-65 who want more clarity around energy, recovery, body composition, and long-term wellness.",
	"Active adults who train, hike, ski, ride, lift, or play hard and want a smarter starting point.",
	"People comparing longevity clinics, remote optimization programs, wellness centers, or functional medicine options near Denver.",
	"Current or future Eden members who want medical wellness, recovery, and training to point in the same direction.",
];

const nextSteps = [
	"Written baseline summary and recommended first move",
	"Recovery and training recommendations when they fit your goals",
	"Lab or bloodwork discussion when clinically appropriate",
	"Membership or program options if Eden is the right long-term fit",
];

const relatedPages = [
	{
		title: "Longevity clinic near Denver",
		href: "/longevity/",
		body: "The broader Eden longevity page for people comparing local clinics, recovery, biomarker testing, hormone care, peptides, NAD+, and training support.",
	},
	{
		title: "Hormone optimization",
		href: "/hormone-optimization/",
		body: "The authority page explaining Eden's test, treat, train, track, optimize model for hormone and performance medicine questions.",
	},
	{
		title: "Men's hormone optimization",
		href: "/mens-hormone-optimization/",
		body: "A dedicated path for men comparing energy, recovery, body composition, and provider-guided hormone conversations near Denver.",
	},
	{
		title: "Women's hormone optimization",
		href: "/womens-hormone-optimization/",
		body: "A dedicated path for women comparing energy, sleep, focus, recovery, and provider-guided hormone conversations near Denver.",
	},
	{
		title: "Menopause and perimenopause",
		href: "/menopause-hormone-therapy/",
		body: "A focused page for perimenopause and menopause questions, built around experience, labs, and provider-guided planning.",
	},
	{
		title: "Peptide and biomarker consult",
		href: "/peptide-biomarker-consult-denver/",
		body: "A higher-intent page for qualified clients exploring peptides, biomarkers, recovery, and optimization support.",
	},
];

const faqs = [
	{
		question: "What is a Longevity Baseline Visit?",
		answer:
			"A Longevity Baseline Visit is Eden's starting point for people who want a clearer plan. It can include body composition context, goals review, recovery and training discussion, and provider-guided next steps for wellness support in Greenwood Village.",
	},
	{
		question: "Do I need labs before booking?",
		answer:
			"No. You can start with the baseline visit. If labs or bloodwork are clinically appropriate for your goals, the Eden team can explain the options and next steps during the visit.",
	},
	{
		question: "Is this only for athletes?",
		answer:
			"No. The visit is useful for active adults, busy professionals, fitness members, and people who simply want a better starting point for energy, recovery, body composition, or wellness planning.",
	},
	{
		question: "What makes Eden different from a typical longevity clinic?",
		answer:
			"Eden connects wellness services with a real fitness and recovery environment. That means your plan can account for body composition, recovery, training, consistency, and provider-guided wellness support inside one local facility.",
	},
	{
		question: "Can this help me choose between training, recovery, and wellness services?",
		answer:
			"Yes. The goal is to make the first step clearer. Eden can help route you toward training, recovery, wellness consults, lab discussion, or membership options based on your baseline and goals.",
	},
	{
		question: "Where is Eden Health Club located?",
		answer:
			"Eden Health Club is at 5990 S University Blvd in Greenwood Village, CO 80121, near Denver Tech Center, Cherry Hills Village, Centennial, Littleton, Englewood, and South Denver.",
	},
];

const jsonLd: JsonLd[] = [
	{
		"@context": "https://schema.org",
		"@type": "MedicalBusiness",
		"@id": `${canonical}#medical-business`,
		name: "Eden Health Club",
		url: canonical,
		telephone: "+17206057678",
		address: {
			"@type": "PostalAddress",
			streetAddress: "5990 S University Blvd",
			addressLocality: "Greenwood Village",
			addressRegion: "CO",
			postalCode: "80121",
			addressCountry: "US",
		},
		geo: {
			"@type": "GeoCoordinates",
			latitude: 39.6088,
			longitude: -104.9583,
		},
		hasMap:
			"https://www.google.com/maps/search/?api=1&query=Eden%20Health%20Club%205990%20S%20University%20Blvd%20Greenwood%20Village%20CO%2080121",
		priceRange: "$$",
		medicalSpecialty: ["FunctionalMedicine", "SportsMedicine", "Dermatology"],
		areaServed: [
			{ "@type": "City", name: "Greenwood Village", addressRegion: "CO" },
			{ "@type": "City", name: "Denver", addressRegion: "CO" },
			{ "@type": "City", name: "Centennial", addressRegion: "CO" },
			{ "@type": "City", name: "Littleton", addressRegion: "CO" },
			{ "@type": "City", name: "Cherry Hills Village", addressRegion: "CO" },
			{ "@type": "City", name: "Denver Tech Center", addressRegion: "CO" },
		],
		sameAs: [
			"https://edenhealthclubs.com/",
			"https://www.facebook.com/edenhealthclubs",
			"https://www.instagram.com/edenhealthclubs",
			"https://www.tiktok.com/@edenhealthclubs",
		],
	},
	{
		"@context": "https://schema.org",
		"@type": "MedicalWebPage",
		"@id": `${canonical}#webpage`,
		url: canonical,
		name: title,
		description,
		about: "Longevity baseline visit, body composition, recovery, training, and wellness planning",
		isPartOf: homeUrl(),
		reviewedBy: {
			"@type": "Organization",
			name: "Eden Health Club",
		},
	},
	{
		"@context": "https://schema.org",
		"@type": "Service",
		"@id": `${canonical}#service`,
		name: "Longevity Baseline Visit",
		serviceType: "Longevity baseline and wellness planning",
		url: canonical,
		description,
		provider: {
			"@id": `${canonical}#medical-business`,
			"@type": "MedicalBusiness",
			name: "Eden Health Club",
		},
		areaServed: "Greenwood Village, Denver Tech Center, Cherry Hills Village, Centennial, Littleton, Englewood, and South Denver",
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		"@id": `${canonical}#faq`,
		mainEntity: faqs.map((faq) => ({
			"@type": "Question",
			name: faq.question,
			acceptedAnswer: {
				"@type": "Answer",
				text: faq.answer,
			},
		})),
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{ "@type": "ListItem", position: 1, name: "Home", item: homeUrl() },
			{ "@type": "ListItem", position: 2, name: "Longevity Baseline Visit", item: canonical },
		],
	},
];
---

<BaseLayout title={title} description={description} canonicalUrl={canonical} jsonLd={jsonLd}>
	<PremiumHeader servicesHref="#blueprint" pricingHref="#lead-form" contactHref="#lead-form" ctaLabel="Book Baseline" />
	<main class="bg-eden-paper">
		<section class="relative overflow-hidden bg-eden-forest text-white">
			<div class="absolute inset-0">
				<img
					src="/assets/fitness-recovery.webp"
					alt=""
					class="h-full w-full object-cover opacity-28"
					loading="eager"
				/>
				<div class="absolute inset-0 bg-gradient-to-r from-eden-forest via-eden-forest/92 to-eden-forest/58"></div>
			</div>

			<div class="relative mx-auto grid max-w-6xl gap-10 px-6 py-16 sm:py-20 lg:grid-cols-[1.03fr_0.97fr] lg:items-center">
				<div>
					<p class="text-sm font-semibold uppercase tracking-normal text-eden-sage">
						Longevity + Performance Medicine · Greenwood Village
					</p>
					<h1 class="mt-4 max-w-3xl text-4xl font-semibold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
						Start with a clinician-guided longevity baseline.
					</h1>
					<p class="mt-5 max-w-2xl text-lg leading-8 text-white/86">
						Body composition, recovery, training, and wellness planning inside one Eden ecosystem, built to help you choose the right first step.
					</p>
					<div class="mt-8 flex flex-col gap-3 sm:flex-row">
						<a href="#lead-form" class="rounded-md bg-eden-sage px-6 py-3 text-center text-base font-semibold text-eden-forest">
							Book your baseline visit
						</a>
						<a href="#what-it-is" class="rounded-md border border-white/30 px-6 py-3 text-center text-base font-semibold text-white">
							See how it works
						</a>
					</div>
				</div>

				<div class="rounded-lg border border-white/16 bg-white/10 p-5 shadow-2xl backdrop-blur">
					<p class="text-xs font-semibold uppercase tracking-normal text-eden-sage">The Eden Blueprint</p>
					<div class="mt-4 grid gap-3">
						{blueprint.map((item, index) => (
							<div class="grid grid-cols-[2.5rem_1fr] gap-3 rounded-md border border-white/12 bg-white/8 p-4">
								<div class="flex h-10 w-10 items-center justify-center rounded-full bg-eden-sage text-sm font-bold text-eden-forest">
									{index + 1}
								</div>
								<div>
									<p class="text-base font-semibold">{item.step}</p>
									<p class="mt-1 text-sm leading-6 text-white/75">{item.body}</p>
								</div>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<section class="border-b border-eden-line bg-white px-6 py-5">
			<div class="mx-auto grid max-w-6xl gap-3 sm:grid-cols-2 lg:grid-cols-4">
				{proof.map((item) => (
					<div class="rounded-md border border-eden-line bg-eden-paper px-4 py-3 text-sm font-semibold text-eden-navy">
						{item}
					</div>
				))}
			</div>
		</section>

		<section id="what-it-is" class="px-6 py-14 sm:py-18">
			<div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
				<div>
					<p class="text-sm font-semibold uppercase text-eden-green">What it is</p>
					<h2 class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
						What is the Longevity Baseline Visit?
					</h2>
					<p class="mt-5 text-base leading-8 text-slate-700">
						The Longevity Baseline Visit is Eden's starting point for people who want a clearer wellness plan. It can connect body composition, goals, recovery, training, and provider-guided next steps so your first move is based on context instead of guesswork.
					</p>
					<p class="mt-5 text-base leading-8 text-slate-700">
						It is built for the person comparing longevity clinics, remote optimization programs, functional medicine, recovery studios, and gym memberships, but wanting one local team that can help the pieces work together.
					</p>
				</div>
				<div class="grid gap-4 sm:grid-cols-2">
					{baselineIncludes.map((item) => (
						<div class="rounded-lg border border-eden-line bg-white p-5 shadow-sm">
							<h3 class="text-lg font-semibold text-eden-navy">{item.title}</h3>
							<p class="mt-2 text-sm leading-6 text-slate-700">{item.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="bg-white px-6 py-14 sm:py-18">
			<div class="mx-auto max-w-6xl">
				<div class="max-w-3xl">
					<p class="text-sm font-semibold uppercase text-eden-green">Why Eden</p>
					<h2 class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
						Data is where most programs stop. At Eden, it is where we start.
					</h2>
					<p class="mt-5 text-base leading-8 text-slate-700">
						Eden is not trying to be another generic med spa. The advantage is the whole environment: medical wellness, body composition, recovery tools, coaching, training, aesthetics, and ongoing membership relationships in one Greenwood Village facility.
					</p>
				</div>

				<div class="mt-8 grid gap-4 md:grid-cols-3">
					{differentiators.map((item) => (
						<div class="rounded-lg bg-eden-forest p-6 text-white">
							<p class="text-sm font-semibold uppercase tracking-normal text-eden-sage">{item.label}</p>
							<p class="mt-3 text-base leading-7 text-white/85">{item.text}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section id="blueprint" class="px-6 py-14 sm:py-18">
			<div class="mx-auto max-w-6xl">
				<div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
					<div>
						<p class="text-sm font-semibold uppercase text-eden-green">The loop</p>
						<h2 class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
							Test. Treat. Train. Track. Optimize.
						</h2>
						<p class="mt-5 text-base leading-8 text-slate-700">
							Competitors can talk about labs and protocols. Eden can connect the plan to the habits, recovery, body composition, and training environment that support the next step.
						</p>
					</div>
					<div class="grid gap-4">
						{blueprint.map((item, index) => (
							<div class="grid gap-4 rounded-lg border border-eden-line bg-white p-5 shadow-sm sm:grid-cols-[4rem_1fr]">
								<div class="flex h-14 w-14 items-center justify-center rounded-full bg-eden-green text-lg font-bold text-white">
									{index + 1}
								</div>
								<div>
									<h3 class="text-xl font-semibold text-eden-navy">{item.step}</h3>
									<p class="mt-2 text-sm leading-7 text-slate-700">{item.body}</p>
								</div>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<section class="bg-eden-forest px-6 py-14 text-white sm:py-18">
			<div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-2">
				<div>
					<p class="text-sm font-semibold uppercase text-eden-sage">Who it is for</p>
					<h2 class="mt-3 text-3xl font-semibold leading-tight sm:text-4xl">
						Built for people who want a smarter first move.
					</h2>
				</div>
				<div class="grid gap-3">
					{audience.map((item) => (
						<div class="rounded-md border border-white/14 bg-white/8 p-4 text-sm leading-7 text-white/84">
							{item}
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="px-6 py-14 sm:py-18">
			<div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[1fr_0.95fr] lg:items-start">
				<div>
					<p class="text-sm font-semibold uppercase text-eden-green">After the visit</p>
					<h2 class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
						Leave with direction, not another list of disconnected options.
					</h2>
					<div class="mt-7 grid gap-3">
						{nextSteps.map((item) => (
							<div class="rounded-lg border border-eden-line bg-white p-4 text-sm font-semibold text-eden-navy">
								{item}
							</div>
						))}
					</div>
				</div>

				<LeadForm
					serviceSlug="longevity-baseline-visit"
					suburbSlug="greenwood-village"
					heading="Book your baseline visit"
					subheading="Tell us where you want to start. Eden will follow up with the right next step."
					submitText="Request my baseline visit"
				/>
			</div>
		</section>

		<section class="bg-white px-6 py-14 sm:py-18" aria-labelledby="faq-heading">
			<div class="mx-auto max-w-4xl">
				<p class="text-sm font-semibold uppercase text-eden-green">FAQ</p>
				<h2 id="faq-heading" class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
					Questions before you book.
				</h2>
				<div class="mt-8 divide-y divide-eden-line rounded-lg border border-eden-line bg-eden-paper">
					{faqs.map((faq) => (
						<details class="group p-5">
							<summary class="cursor-pointer list-none text-lg font-semibold text-eden-navy">
								{faq.question}
							</summary>
							<p class="mt-3 text-sm leading-7 text-slate-700">{faq.answer}</p>
						</details>
					))}
				</div>
			</div>
		</section>

		<section class="px-6 py-14 sm:py-18" aria-labelledby="cluster-heading">
			<div class="mx-auto max-w-6xl">
				<div class="max-w-3xl">
					<p class="text-sm font-semibold uppercase text-eden-green">Optimization cluster</p>
					<h2 id="cluster-heading" class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
						Use the baseline as the front door. Let the deeper pages win the rest of the search demand.
					</h2>
					<p class="mt-5 text-base leading-8 text-slate-700">
						The baseline page is the clearest paid-search destination. These supporting pages help Eden cover the related searches people make before they are ready to book.
					</p>
				</div>
				<div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
					{relatedPages.map((page) => (
						<a href={page.href} class="rounded-lg border border-eden-line bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-eden-green">
							<h3 class="text-lg font-semibold text-eden-navy">{page.title}</h3>
							<p class="mt-2 text-sm leading-6 text-slate-700">{page.body}</p>
						</a>
					))}
				</div>
			</div>
		</section>

		<section class="bg-eden-forest px-6 py-10 text-white">
			<div class="mx-auto flex max-w-6xl flex-col gap-5 md:flex-row md:items-center md:justify-between">
				<div>
					<p class="text-sm font-semibold uppercase text-eden-sage">Open now near DTC</p>
					<h2 class="mt-2 text-3xl font-semibold">Start with the baseline. Build the plan from there.</h2>
				</div>
				<a href="#lead-form" class="rounded-md bg-eden-sage px-6 py-3 text-center text-base font-semibold text-eden-forest">
					Book your baseline visit
				</a>
			</div>
		</section>
	</main>
	<div class="fixed inset-x-0 bottom-0 z-40 border-t border-eden-line bg-white/96 p-3 shadow-lg backdrop-blur md:hidden">
		<div class="mx-auto flex max-w-md gap-2">
			<a href="#lead-form" class="flex-1 rounded-md bg-eden-green px-4 py-3 text-center text-sm font-semibold text-white">Book baseline</a>
			<a href="tel:+17206057678" data-phone-link class="rounded-md border border-eden-line px-4 py-3 text-center text-sm font-semibold text-eden-navy">Call</a>
		</div>
	</div>
	<Footer />
</BaseLayout>
