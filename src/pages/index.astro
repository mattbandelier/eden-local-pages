---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
	title="Eden Health Clubs — Coming Soon"
	description="NP-led medspa serving Greenwood Village and the south Denver corridor."
	canonicalUrl="https://landing.edenhealthclubs.com/"
>
	<main class="flex min-h-screen items-center justify-center px-6">
		<div class="max-w-xl text-center">
			<h1 class="text-3xl font-semibold tracking-tight text-eden-navy sm:text-4xl">
				Eden Health Clubs — coming soon.
			</h1>
			<div class="mx-auto mt-6 h-px w-16 bg-eden-green" aria-hidden="true"></div>
			<p class="mt-6 text-base leading-relaxed text-eden-navy/80 sm:text-lg">
				NP-led medspa serving Greenwood Village and the south Denver corridor.
			</p>
		</div>
	</main>
</BaseLayout>
