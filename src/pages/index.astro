---
import BaseLayout from "../layouts/BaseLayout.astro";
import { services } from "../data";
import CTAStrip from "../components/content/CTAStrip.astro";
import DenverDemandCluster from "../components/content/DenverDemandCluster.astro";
import PillarGrid from "../components/content/PillarGrid.astro";
import PriorityMoneyLinks from "../components/content/PriorityMoneyLinks.astro";
import ServiceCards from "../components/content/ServiceCards.astro";
import TrustBar from "../components/content/TrustBar.astro";
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";
import { homepageJsonLd } from "../lib/schema-org";
import { homepageMeta } from "../lib/seo";
import { homeUrl } from "../lib/urls";

const seo = homepageMeta();
---

<BaseLayout
	title={seo.title}
	description={seo.description}
	canonicalUrl={homeUrl()}
	jsonLd={homepageJsonLd()}
>
	<Header />
	<main>
		<section class="bg-white px-6 py-16 sm:py-20">
			<div class="mx-auto max-w-3xl text-center">
				<p class="text-sm font-semibold uppercase text-eden-green">Greenwood Village wellness clinic</p>
				<h1 class="mt-4 text-4xl font-semibold leading-tight text-eden-navy sm:text-5xl">
					Your Sanctuary of Wellness.
				</h1>
				<p class="mt-6 text-base leading-8 text-slate-700 sm:text-lg">
					Functional medicine, aesthetics, recovery, and fitness under one roof in Greenwood Village. Licensed Experts. Advanced Credentials. Unmatched Care.
				</p>
				<a href="#lead-form" class="mt-8 inline-flex rounded-md bg-eden-green px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-eden-green/90">
					Book a consult
				</a>
			</div>
		</section>
		<TrustBar />
		<section class="bg-eden-paper px-6 py-12 sm:py-14" aria-labelledby="market-momentum-heading">
			<div class="mx-auto max-w-6xl">
				<div class="max-w-3xl">
					<p class="text-sm font-semibold uppercase text-eden-green">High-intent Eden paths</p>
					<h2 id="market-momentum-heading" class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
						The highest-intent Eden paths are now connected from the front door.
					</h2>
					<p class="mt-4 text-base leading-7 text-slate-700">
						Start with the Eden page that matches the search: peptide starter program, longevity clinic, hormone optimization, med spa, medical weight loss support, GLP-1 strength training, or a premium fitness and recovery membership near Greenwood Village and DTC.
					</p>
				</div>
				<div class="mt-7 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
					<a href="/peptide-biomarker-consult-denver/" class="rounded-lg border border-eden-green/40 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-eden-green">
						<p class="text-xs font-semibold uppercase text-eden-green">$299 offer path</p>
						<h3 class="mt-3 text-lg font-semibold leading-tight text-eden-navy">Peptide starter program</h3>
						<p class="mt-3 text-sm leading-6 text-slate-700">Provider consult, labwork or biomarker review, and first month of peptide support if prescribed.</p>
					</a>
					<a href="/longevity/" class="rounded-lg border border-eden-green/40 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-eden-green">
						<p class="text-xs font-semibold uppercase text-eden-green">Denver longevity demand</p>
						<h3 class="mt-3 text-lg font-semibold leading-tight text-eden-navy">Longevity clinic Denver</h3>
						<p class="mt-3 text-sm leading-6 text-slate-700">Biomarkers, provider guidance, recovery, training, hormones, peptides, and follow-up near DTC.</p>
					</a>
					<a href="/longevity-baseline-visit/" class="rounded-lg border border-eden-green/40 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-eden-green">
						<p class="text-xs font-semibold uppercase text-eden-green">Best first step</p>
						<h3 class="mt-3 text-lg font-semibold leading-tight text-eden-navy">Longevity baseline visit</h3>
						<p class="mt-3 text-sm leading-6 text-slate-700">Body composition, goals, recovery, training, and provider-guided next steps in Greenwood Village.</p>
					</a>
					<a href="/medical-spa-denver/" class="rounded-lg border border-eden-green/40 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-eden-green">
						<p class="text-xs font-semibold uppercase text-eden-green">Med spa money hub</p>
						<h3 class="mt-3 text-lg font-semibold leading-tight text-eden-navy">Medical spa Denver</h3>
						<p class="mt-3 text-sm leading-6 text-slate-700">Aesthetic consult routing for Botox, fillers, DiamondGlow, microneedling, BBL, and skin treatments.</p>
					</a>
					<a href="/glp-1-strength-training-greenwood-village/" class="rounded-lg border border-eden-line bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-eden-green">
						<p class="text-xs font-semibold uppercase text-eden-green">Muscle preservation</p>
						<h3 class="mt-3 text-lg font-semibold leading-tight text-eden-navy">GLP-1 strength training</h3>
						<p class="mt-3 text-sm leading-6 text-slate-700">Strength, InBody tracking, recovery, and medical-wellness support around weight loss.</p>
					</a>
					<a href="/strength-training-greenwood-village/" class="rounded-lg border border-eden-line bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-eden-green">
						<p class="text-xs font-semibold uppercase text-eden-green">Strength foundation</p>
						<h3 class="mt-3 text-lg font-semibold leading-tight text-eden-navy">Strength training</h3>
						<p class="mt-3 text-sm leading-6 text-slate-700">Coached training for body composition, longevity, confidence, and performance near DTC.</p>
					</a>
					<a href="/group-fitness-classes-greenwood-village/" class="rounded-lg border border-eden-line bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-eden-green">
						<p class="text-xs font-semibold uppercase text-eden-green">Community coaching</p>
						<h3 class="mt-3 text-lg font-semibold leading-tight text-eden-navy">Group fitness classes</h3>
						<p class="mt-3 text-sm leading-6 text-slate-700">Small-format energy, coaching, and accountability inside Eden's wellness facility.</p>
					</a>
					<a href="/glp-1-fitness-membership-greenwood-village/" class="rounded-lg border border-eden-line bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-eden-green">
						<p class="text-xs font-semibold uppercase text-eden-green">Fully supported</p>
						<h3 class="mt-3 text-lg font-semibold leading-tight text-eden-navy">Perform Membership</h3>
						<p class="mt-3 text-sm leading-6 text-slate-700">Semi-private training, progress check-ins, recovery, and body-composition accountability.</p>
					</a>
					<a href="/medical-weight-loss-fitness-greenwood-village/" class="rounded-lg border border-eden-line bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-eden-green">
						<p class="text-xs font-semibold uppercase text-eden-green">Maintenance plan</p>
						<h3 class="mt-3 text-lg font-semibold leading-tight text-eden-navy">Medical weight loss fitness</h3>
						<p class="mt-3 text-sm leading-6 text-slate-700">Bridge weight-loss care into muscle, recovery, and long-term body-composition support.</p>
					</a>
					<a href="/mens-hormone-optimization/" class="rounded-lg border border-eden-line bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-eden-green">
						<p class="text-xs font-semibold uppercase text-eden-green">Provider-led</p>
						<h3 class="mt-3 text-lg font-semibold leading-tight text-eden-navy">Men's hormone optimization</h3>
						<p class="mt-3 text-sm leading-6 text-slate-700">Lab-backed consults for energy, recovery, strength, focus, and low T questions.</p>
					</a>
					<a href="/medical-weight-loss/greenwood-village/" class="rounded-lg border border-eden-line bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-eden-green">
						<p class="text-xs font-semibold uppercase text-eden-green">Local consult</p>
						<h3 class="mt-3 text-lg font-semibold leading-tight text-eden-navy">Medical weight loss</h3>
						<p class="mt-3 text-sm leading-6 text-slate-700">Provider-guided screening, follow-up, and a stronger bridge into long-term maintenance.</p>
					</a>
					<a href="/medical-weight-loss/denver/" class="rounded-lg border border-eden-line bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-eden-green">
						<p class="text-xs font-semibold uppercase text-eden-green">Denver money term</p>
						<h3 class="mt-3 text-lg font-semibold leading-tight text-eden-navy">Medical weight loss Denver</h3>
						<p class="mt-3 text-sm leading-6 text-slate-700">A Denver-facing path for labs, eligibility, monitoring, and weight-loss support near DTC.</p>
					</a>
					<a href="/red-light-therapy-denver/" class="rounded-lg border border-eden-line bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-eden-green">
						<p class="text-xs font-semibold uppercase text-eden-green">Recovery demand</p>
						<h3 class="mt-3 text-lg font-semibold leading-tight text-eden-navy">Red light therapy Denver</h3>
						<p class="mt-3 text-sm leading-6 text-slate-700">Recovery, readiness, sauna, compression, IV therapy, and performance support under one roof.</p>
					</a>
					<a href="/male-trt/denver/" class="rounded-lg border border-eden-line bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-eden-green">
						<p class="text-xs font-semibold uppercase text-eden-green">Integrative search</p>
						<h3 class="mt-3 text-lg font-semibold leading-tight text-eden-navy">TRT Denver</h3>
						<p class="mt-3 text-sm leading-6 text-slate-700">A lab-guided consult path for low T questions, safety review, symptoms, and follow-up.</p>
					</a>
				</div>
			</div>
		</section>
		<DenverDemandCluster currentPath="/" theme="light" />
		<PillarGrid />
		<ServiceCards services={services} heading="Popular services" limit={6} />
		<PriorityMoneyLinks currentPath="/" variant="hub" />
		<CTAStrip serviceSlug="general" suburbSlug={null} variant="primary" />
	</main>
	<Footer />
</BaseLayout>
