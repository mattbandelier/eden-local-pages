---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getService, services, suburbs } from "../../data";
import CTAStrip from "../../components/content/CTAStrip.astro";
import FAQAccordion from "../../components/content/FAQAccordion.astro";
import Hero from "../../components/content/Hero.astro";
import LocalProximity from "../../components/content/LocalProximity.astro";
import PriorityMoneyLinks from "../../components/content/PriorityMoneyLinks.astro";
import ServiceCards from "../../components/content/ServiceCards.astro";
import TrustBar from "../../components/content/TrustBar.astro";
import Breadcrumbs from "../../components/layout/Breadcrumbs.astro";
import Footer from "../../components/layout/Footer.astro";
import Header from "../../components/layout/Header.astro";
import { faqItemsJsonLd, suburbHubJsonLd, type BreadcrumbItem } from "../../lib/schema-org";
import { suburbHubMeta } from "../../lib/seo";
import { homeUrl, suburbHubUrl } from "../../lib/urls";

export async function getStaticPaths() {
	return suburbs.map((suburb) => ({
		params: { suburb: suburb.slug },
		props: { suburb },
	}));
}

const { suburb } = Astro.props;
const seo = suburbHubMeta(suburb);
const highlightedServices = (suburb.highlightedServices ?? [])
	.map((slug) => getService(slug))
	.filter((service) => service !== undefined);
const suburbFaqs = [
	{
		question: `Does Eden Health Club serve ${suburb.name}?`,
		answer:
			suburb.driveTimeMinutes === 0
				? "Yes. Eden Health Club is located in Greenwood Village at 5990 S University Blvd."
				: `Yes. Eden serves ${suburb.name} from our Greenwood Village clinic, about ${suburb.driveTimeMinutes} minutes away.`,
	},
	{
		question: "Where exactly is the clinic?",
		answer: "Eden Health Club is located at 5990 S University Blvd in Greenwood Village, CO 80121.",
	},
	{
		question: "Which services are available?",
		answer: "Eden offers functional medicine, aesthetics, wellness and recovery, and performance-focused services. Highlighted services vary by local page, but the clinical team can help you choose the right next step.",
	},
];
const breadcrumbItems: BreadcrumbItem[] = [
	{ label: "Home", href: homeUrl() },
	{ label: "Locations", href: null },
	{ label: suburb.name, href: null },
];
---

<BaseLayout
	title={seo.title}
	description={seo.description}
	canonicalUrl={suburbHubUrl(suburb.slug)}
	jsonLd={[...suburbHubJsonLd(suburb, breadcrumbItems), faqItemsJsonLd(suburbHubUrl(suburb.slug), suburbFaqs)]}
>
	<Header />
	<Breadcrumbs items={breadcrumbItems} />
	<main>
		<Hero variant="suburb-hub" suburb={suburb} />
		<LocalProximity suburb={suburb} />
		<TrustBar />
		<CTAStrip serviceSlug="general" suburbSlug={suburb.slug} variant="primary" />
		<ServiceCards
			services={highlightedServices.length ? highlightedServices : services.slice(0, 6)}
			suburbSlug={suburb.slug}
			heading={`Services we offer near ${suburb.name}`}
		/>
		<PriorityMoneyLinks currentPath={`/locations/${suburb.slug}/`} variant="hub" />
		<FAQAccordion faqs={suburbFaqs} heading={`${suburb.name} questions`} />
		<CTAStrip serviceSlug="general" suburbSlug={suburb.slug} variant="secondary" />
	</main>
	<Footer />
</BaseLayout>
