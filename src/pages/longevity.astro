---
import DenverDemandCluster from "../components/content/DenverDemandCluster.astro";
import LeadForm from "../components/content/LeadForm.astro";
import Footer from "../components/layout/Footer.astro";
import PremiumHeader from "../components/layout/PremiumHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { canonicalUrl, homeUrl } from "../lib/urls";
import type { JsonLd } from "../lib/schema-org";

const canonical = canonicalUrl("/longevity");
const title = "Longevity Clinic Denver | Open Now in Greenwood Village | Eden";
const description =
	"Longevity, hormone optimization, peptides, NAD+ IV, biomarker testing, medical weight loss, recovery, and training support at Eden Health Club near Denver and DTC.";

const services = [
	{
		name: "Hormone optimization",
		href: "/mens-hormone-optimization/",
		tag: "Labs + provider review",
		body: "TRT, HRT, and hormone consult paths start with goals, health history, labs, and provider review.",
	},
	{
		name: "$299 peptide starter program",
		href: "/peptide-biomarker-consult-denver/",
		tag: "Offer-led start",
		body: "A clear first step for qualified clients comparing peptide therapy, biomarker testing, recovery, performance, and longevity support.",
	},
	{
		name: "NAD+ and IV therapy",
		href: "/nad-iv-therapy/denver/",
		tag: "Cellular energy support",
		body: "NAD+ IV, IV therapy, and monitored wellness infusions for clients comparing cellular energy and recovery support.",
	},
	{
		name: "Medical weight loss",
		href: "/medical-weight-loss/denver/",
		tag: "Eligibility + follow-up",
		body: "Eligibility, lab review, body composition, and follow-up support for clients exploring medical weight loss options.",
	},
	{
		name: "Biomarker testing",
		href: "#lead-form",
		tag: "Data before guesswork",
		body: "A data-informed starting point for understanding hormones, metabolic markers, recovery, and next-step priorities.",
	},
	{
		name: "Training and recovery",
		href: "/elevate-membership-greenwood-village/",
		tag: "Daily habits connected",
		body: "Semi-private training, InBody tracking, red light, sauna, compression, and recovery support under one roof.",
	},
];

const proofPoints = [
	{
		kicker: "Open now",
		title: "No waitlist",
		body: "A real Greenwood Village facility ready for consults, training, recovery, and follow-up.",
	},
	{
		kicker: "Clinical path",
		title: "Provider-guided",
		body: "Labs, goals, eligibility, and safety context come before recommendations.",
	},
	{
		kicker: "Under one roof",
		title: "Clinic + fitness + recovery",
		body: "Hormones, peptides, NAD+, medical weight loss, aesthetics, strength, and recovery can connect.",
	},
];

const comparisonRows = [
	["Care model", "Local Eden team and provider-guided consult path", "Generic single-lane wellness membership"],
	["What happens after labs", "Training, recovery, body composition, and follow-up can be built into the plan", "Data without the daily environment to act on it"],
	["Facility advantage", "Medical wellness, aesthetics, recovery, and fitness in one Greenwood Village location", "Separate vendors for the pieces that should work together"],
	["Best fit", "People who want a plan they can actually live with week to week", "People only shopping for a single modality"],
];

const firstConsult = [
	{
		title: "Clarify the goal",
		body: "Start with what you want to change: energy, strength, body composition, recovery, confidence, or long-term wellness.",
	},
	{
		title: "Review the data",
		body: "Discuss labs, biomarkers, health history, InBody context, and what information is still needed before any recommendation.",
	},
	{
		title: "Choose the right path",
		body: "Compare whether hormones, peptides, NAD+ IV, medical weight loss, recovery, training, aesthetics, or a membership path fits best.",
	},
	{
		title: "Map next steps",
		body: "Leave with a clear route for pricing, timing, provider review, follow-up, and what to do first.",
	},
];

const localSignals = [
	{
		area: "Greenwood Village",
		body: "Eden's home base at 5990 S University Blvd for clients who want a local, in-person longevity clinic.",
	},
	{
		area: "Denver Tech Center",
		body: "A practical option for executives, founders, and professionals who want care close to work and home.",
	},
	{
		area: "Cherry Hills Village",
		body: "Nearby for clients comparing premium wellness, hormones, recovery, aesthetics, and performance support.",
	},
	{
		area: "Centennial and Littleton",
		body: "Convenient for south-metro clients looking for an integrated alternative to scattered single-service appointments.",
	},
];

const loop = [
	{
		step: "Test",
		body: "Start with goals, intake, labs, biomarkers, and body-composition context when appropriate.",
	},
	{
		step: "Treat",
		body: "Review options with a licensed provider and move forward only when there is a clear fit.",
	},
	{
		step: "Train",
		body: "Connect the plan to strength, muscle, conditioning, and habits that support long-term progress.",
	},
	{
		step: "Track",
		body: "Use follow-up, InBody, symptom context, and labs where appropriate to avoid guesswork.",
	},
	{
		step: "Optimize",
		body: "Adjust the plan over time around performance, recovery, energy, body composition, and safety.",
	},
];

const faqs = [
	{
		question: "Is Eden's longevity clinic open now?",
		answer:
			"Yes. Eden Health Club is open now in Greenwood Village at 5990 S University Blvd, minutes from Denver Tech Center, Cherry Hills Village, Centennial, Littleton, and South Denver.",
	},
	{
		question: "What does a longevity consult include?",
		answer:
			"A consult starts with your goals, health history, current routines, and what you want to improve. The team can discuss labs, biomarkers, hormone questions, medical weight loss, peptides, NAD+ IV, training, and recovery support when relevant.",
	},
	{
		question: "Do I need labs before starting?",
		answer:
			"Some services require labs before a provider can make recommendations. Eden uses labs and biomarkers when they are clinically appropriate so decisions are based on data, safety, and fit.",
	},
	{
		question: "How fast can I be seen?",
		answer:
			"Same-week appointments may be available depending on schedule and service fit. Submit the consult form or call 720-605-7678 and Eden will help route the right next step.",
	},
	{
		question: "What makes Eden different from a single-service longevity studio?",
		answer:
			"Eden combines medical wellness, aesthetics, recovery, and training in one local facility. That means the plan can connect labs and provider guidance with the daily habits that support strength, recovery, body composition, and consistency.",
	},
	{
		question: "What does it cost to start?",
		answer:
			"Pricing depends on the service path, medical eligibility, labs, and recommended plan. A consult is the clearest way to understand the right starting point and the costs that apply to your goals.",
	},
];

const jsonLd: JsonLd[] = [
	{
		"@context": "https://schema.org",
		"@type": "MedicalBusiness",
		"@id": `${canonical}#medical-business`,
		name: "Eden Health Club",
		url: canonical,
		telephone: "+17206057678",
		address: {
			"@type": "PostalAddress",
			streetAddress: "5990 S University Blvd",
			addressLocality: "Greenwood Village",
			addressRegion: "CO",
			postalCode: "80121",
			addressCountry: "US",
		},
		geo: {
			"@type": "GeoCoordinates",
			latitude: 39.6088,
			longitude: -104.9583,
		},
		hasMap:
			"https://www.google.com/maps/search/?api=1&query=Eden%20Health%20Club%205990%20S%20University%20Blvd%20Greenwood%20Village%20CO%2080121",
		priceRange: "$$",
		medicalSpecialty: ["FunctionalMedicine", "SportsMedicine", "Dermatology"],
		areaServed: [
			{ "@type": "City", name: "Denver", addressRegion: "CO" },
			{ "@type": "City", name: "Greenwood Village", addressRegion: "CO" },
			{ "@type": "City", name: "Centennial", addressRegion: "CO" },
			{ "@type": "City", name: "Littleton", addressRegion: "CO" },
		],
		sameAs: [
			"https://edenhealthclubs.com/",
			"https://www.facebook.com/edenhealthclubs",
			"https://www.instagram.com/edenhealthclubs",
			"https://www.tiktok.com/@edenhealthclubs",
		],
	},
	{
		"@context": "https://schema.org",
		"@type": "Service",
		"@id": `${canonical}#service`,
		name: "Longevity and Hormone Care",
		serviceType: "Longevity Clinic",
		url: canonical,
		description,
		provider: {
			"@id": `${canonical}#medical-business`,
			"@type": "MedicalBusiness",
			name: "Eden Health Club",
		},
		areaServed: "Denver, Greenwood Village, Denver Tech Center, Cherry Hills Village, Centennial, Littleton, and South Denver",
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		"@id": `${canonical}#faq`,
		mainEntity: faqs.map((faq) => ({
			"@type": "Question",
			name: faq.question,
			acceptedAnswer: {
				"@type": "Answer",
				text: faq.answer,
			},
		})),
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{ "@type": "ListItem", position: 1, name: "Home", item: homeUrl() },
			{ "@type": "ListItem", position: 2, name: "Longevity Clinic Denver", item: canonical },
		],
	},
];
---

<BaseLayout title={title} description={description} canonicalUrl={canonical} jsonLd={jsonLd}>
	<PremiumHeader servicesHref="#services" pricingHref="#lead-form" contactHref="#lead-form" />
	<main class="bg-eden-paper">
		<section class="relative overflow-hidden bg-eden-forest text-white">
			<div class="absolute inset-0">
				<img src="/assets/eden-health-club-reception.webp" alt="" class="h-full w-full object-cover opacity-30" loading="eager" />
				<video
					class="absolute inset-0 hidden h-full w-full object-cover opacity-32 md:block"
					autoplay
					muted
					loop
					playsinline
					preload="none"
					poster="/assets/eden-health-club-reception.webp"
					aria-hidden="true"
				>
					<source src="https://edenhealthclubs.com/wp-content/uploads/2025/07/edenhealth-hero-video.mp4" type="video/mp4" />
				</video>
				<div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(28,45,38,0.98),rgba(25,79,57,0.9)_46%,rgba(25,79,57,0.48))]"></div>
			</div>
			<div class="relative mx-auto grid min-h-[calc(100vh-64px)] max-w-6xl gap-10 px-6 py-12 sm:py-16 lg:grid-cols-[1.02fr_0.98fr] lg:items-center">
				<div>
					<img
						src="/assets/eden-health-club-logo-white-transparent-tight.png"
						alt="Eden Health Club"
						class="mb-8 h-auto w-36 sm:w-44"
						loading="eager"
					/>
					<p class="text-sm font-semibold uppercase tracking-normal text-eden-sage">Longevity clinic near Denver and DTC</p>
					<h1 class="mt-4 max-w-3xl text-4xl font-semibold leading-tight sm:text-5xl lg:text-6xl">
						The local longevity team already open in Greenwood Village.
					</h1>
					<p class="mt-5 max-w-2xl text-base leading-8 text-white/86 sm:text-lg">
						Physician-led clinical guidance, biomarker testing, hormone optimization, peptides, NAD+ IV, medical weight loss, training, recovery, and aesthetics in one Eden facility near Denver Tech Center.
					</p>
					<div class="mt-8 flex flex-col gap-3 sm:flex-row">
						<a href="#lead-form" class="rounded-md bg-eden-sage px-6 py-3 text-center text-base font-semibold text-eden-forest shadow-sm">
							Book your consult
						</a>
						<a href="tel:+17206057678" data-phone-link class="rounded-md border border-white/35 px-6 py-3 text-center text-base font-semibold text-white hover:bg-white/10">
							Call 720-605-7678
						</a>
					</div>
					<div class="mt-8 grid gap-3 text-sm text-white/88 sm:grid-cols-3">
						{proofPoints.map((point) => (
							<div class="rounded-lg border border-white/15 bg-white/8 p-4 backdrop-blur">
								<p class="text-xs font-semibold uppercase text-eden-sage">{point.kicker}</p>
								<p class="mt-2 text-lg font-semibold text-white">{point.title}</p>
								<p class="mt-2 leading-6 text-white/72">{point.body}</p>
							</div>
						))}
					</div>
				</div>
				<div class="relative">
					<div class="overflow-hidden rounded-lg border border-white/15 bg-white/10 p-3 shadow-2xl backdrop-blur">
						<div class="grid gap-3 sm:grid-cols-[0.82fr_1.18fr]">
							<div class="overflow-hidden rounded-md">
								<img src="/assets/mens-hormone-optimization.webp" alt="" class="h-full min-h-72 w-full object-cover object-center" loading="eager" />
							</div>
							<div class="grid gap-3">
								<div class="overflow-hidden rounded-md">
									<img src="/assets/fitness-recovery.webp" alt="" class="h-40 w-full object-cover sm:h-full" loading="lazy" />
								</div>
								<div class="grid grid-cols-2 gap-3">
									<div class="rounded-md bg-white p-4 text-eden-navy">
										<p class="text-xs font-semibold uppercase text-eden-green">Clinical path</p>
										<p class="mt-2 text-lg font-semibold">Labs, goals, care, and follow-up.</p>
									</div>
									<div class="rounded-md bg-eden-sage p-4 text-eden-forest">
										<p class="text-xs font-semibold uppercase">Near DTC</p>
										<p class="mt-2 text-lg font-semibold">Greenwood Village, Colorado.</p>
									</div>
								</div>
							</div>
						</div>
						<div class="mt-3 rounded-md border border-eden-line bg-white p-5 text-eden-navy shadow-sm">
							<p class="text-sm font-semibold uppercase text-eden-green">Look. Feel. Perform.</p>
							<p class="mt-2 text-xl font-semibold leading-tight">Clinical strategy plus the facility to execute it.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="bg-white px-6 py-10">
			<div class="mx-auto grid max-w-6xl gap-4 text-sm text-eden-navy sm:grid-cols-4">
				{[
					["Diagnostics", "Labs, intake, goals, and biomarker context."],
					["Protocols", "Provider-guided options matched to fit."],
					["Recovery", "IV therapy, red light, sauna, and compression."],
					["Performance", "Strength, body composition, and follow-up."],
				].map(([title, body]) => (
					<div class="rounded-lg border border-eden-line bg-eden-paper p-5">
						<p class="text-base font-semibold">{title}</p>
						<p class="mt-2 leading-6 text-slate-700">{body}</p>
					</div>
				))}
			</div>
		</section>

		<section id="services" class="px-6 py-12 sm:py-16">
			<div class="mx-auto max-w-6xl">
				<div class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
					<div>
					<p class="text-sm font-semibold uppercase text-eden-green">What you can start here</p>
					<h2 class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
						The services people search for when they want longevity care near Denver.
					</h2>
					</div>
					<p class="mt-4 text-base leading-8 text-slate-700">
						People searching for longevity clinic near me, biomarker testing, hormone optimization, peptide therapy, NAD+ IV therapy, and medical weight loss near Denver are usually not looking for one isolated service. They are looking for a credible starting point.
					</p>
				</div>
				<div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
					{services.map((service) => (
						<a href={service.href} class="group rounded-lg border border-eden-line bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-eden-green hover:shadow-md">
							<p class="text-xs font-semibold uppercase text-eden-green">{service.tag}</p>
							<h3 class="text-xl font-semibold text-eden-navy">{service.name}</h3>
							<p class="mt-3 text-sm leading-6 text-slate-700">{service.body}</p>
							<span class="mt-5 inline-block text-sm font-semibold text-eden-green group-hover:text-eden-navy">Learn more</span>
						</a>
					))}
				</div>
			</div>
		</section>

		<section class="bg-white px-6 py-12 sm:py-16">
			<div class="mx-auto max-w-6xl">
				<div class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
					<div>
					<p class="text-sm font-semibold uppercase text-eden-green">Why Eden</p>
					<h2 class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
						The difference is what happens after the consult.
					</h2>
					<p class="mt-4 text-base leading-8 text-slate-700">
						A premium longevity plan should not live in a vacuum. Eden is a local wellness facility where provider guidance can connect with the pieces that shape daily outcomes: training, recovery, body composition, aesthetics, and follow-up.
					</p>
					</div>
					<div class="hidden overflow-hidden rounded-lg border border-eden-line bg-eden-paper shadow-sm md:block">
						<div class="grid grid-cols-[0.72fr_1fr_1fr] bg-eden-forest text-sm font-semibold text-white">
							<div class="p-4">Decision point</div>
							<div class="border-l border-white/10 p-4">Eden model</div>
							<div class="border-l border-white/10 p-4">Single-lane model</div>
						</div>
						{comparisonRows.map(([label, eden, other]) => (
							<div class="grid grid-cols-[0.72fr_1fr_1fr] border-t border-eden-line text-sm">
								<div class="bg-white p-4 font-semibold text-eden-navy">{label}</div>
								<div class="border-l border-eden-line p-4 leading-6 text-slate-700">{eden}</div>
								<div class="border-l border-eden-line p-4 leading-6 text-slate-600">{other}</div>
							</div>
						))}
					</div>
					<div class="grid gap-4 md:hidden">
						{comparisonRows.map(([label, eden, other]) => (
							<div class="rounded-lg border border-eden-line bg-eden-paper p-5">
								<p class="text-sm font-semibold uppercase text-eden-green">{label}</p>
								<div class="mt-4 rounded-md bg-white p-4">
									<p class="text-sm font-semibold text-eden-navy">Eden model</p>
									<p class="mt-2 text-sm leading-6 text-slate-700">{eden}</p>
								</div>
								<div class="mt-3 rounded-md border border-eden-line p-4">
									<p class="text-sm font-semibold text-eden-navy">Single-lane model</p>
									<p class="mt-2 text-sm leading-6 text-slate-600">{other}</p>
								</div>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<section class="relative overflow-hidden bg-eden-forest px-6 py-12 text-white sm:py-16">
			<div class="absolute inset-y-0 right-0 hidden w-1/2 lg:block">
				<img src="/assets/fitness-recovery.webp" alt="" class="h-full w-full object-cover opacity-28" loading="lazy" />
				<div class="absolute inset-0 bg-gradient-to-r from-eden-forest via-eden-forest/75 to-eden-forest/20"></div>
			</div>
			<div class="mx-auto max-w-6xl">
				<div class="max-w-3xl">
					<p class="text-sm font-semibold uppercase text-eden-sage">The Eden loop</p>
					<h2 class="mt-3 text-3xl font-semibold leading-tight sm:text-4xl">Test. Treat. Train. Track. Optimize.</h2>
					<p class="mt-4 text-base leading-8 text-white/78">
						The advantage is not a single appointment. It is a connected path that turns goals into data, care, habits, follow-up, and refinement.
					</p>
				</div>
				<div class="relative mt-8 grid gap-4 md:grid-cols-5">
					{loop.map((item, index) => (
						<div class="rounded-lg border border-white/15 bg-white/10 p-5 backdrop-blur">
							<div class="flex h-9 w-9 items-center justify-center rounded-full bg-eden-sage text-sm font-semibold text-eden-forest">{index + 1}</div>
							<h3 class="mt-4 text-xl font-semibold">{item.step}</h3>
							<p class="mt-3 text-sm leading-6 text-white/74">{item.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="bg-white px-6 py-12 sm:py-16">
			<div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
				<div class="overflow-hidden rounded-lg">
					<img src="/assets/eden-health-club-office.webp" alt="" class="h-full min-h-80 w-full object-cover" loading="lazy" />
				</div>
				<div>
					<p class="text-sm font-semibold uppercase text-eden-green">First consult</p>
					<h2 class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
						A premium start should feel clear, not overwhelming.
					</h2>
					<p class="mt-4 text-base leading-8 text-slate-700">
						The first step is not guessing which treatment to buy. It is understanding what you want, what data matters, and which Eden path is the right starting point.
					</p>
					<div class="mt-6 grid gap-3 sm:grid-cols-2">
						{firstConsult.map((item) => (
							<div class="rounded-lg border border-eden-line bg-eden-paper p-5">
								<h3 class="text-lg font-semibold text-eden-navy">{item.title}</h3>
								<p class="mt-2 text-sm leading-6 text-slate-700">{item.body}</p>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<section class="px-6 py-12 sm:py-16">
			<div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[0.92fr_1.08fr] lg:items-start">
				<div>
					<p class="text-sm font-semibold uppercase text-eden-green">Local fit</p>
					<h2 class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
						Built for Greenwood Village, DTC, and the south Denver corridor.
					</h2>
					<p class="mt-4 text-base leading-8 text-slate-700">
						Eden Health Club is located at 5990 S University Blvd in Greenwood Village, close to Denver Tech Center, Cherry Hills Village, Centennial, Englewood, Littleton, Highlands Ranch, and South Denver.
					</p>
					<div class="mt-6 grid gap-3 text-sm">
						{localSignals.map((item) => (
							<div class="rounded-lg border border-eden-line bg-white p-4">
								<p class="font-semibold text-eden-navy">{item.area}</p>
								<p class="mt-1 leading-6 text-slate-700">{item.body}</p>
							</div>
						))}
					</div>
				</div>
				<LeadForm
					serviceSlug="longevity"
					suburbSlug="greenwood-village"
					heading="Book a longevity consult"
					subheading="Tell us where you want to start. Eden will follow up with the right next step."
					submitText="Request my consult"
				/>
			</div>
		</section>

		<DenverDemandCluster currentPath="/longevity/" theme="light" />

		<section class="bg-white px-6 py-12 sm:py-16" aria-labelledby="longevity-faq-heading">
			<div class="mx-auto max-w-4xl">
				<p class="text-sm font-semibold uppercase text-eden-green">FAQ</p>
				<h2 id="longevity-faq-heading" class="mt-3 text-3xl font-semibold leading-tight text-eden-navy sm:text-4xl">
					Questions people ask before booking.
